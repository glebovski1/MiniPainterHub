@using System.Net
@using Microsoft.AspNetCore.Components.Authorization
@using MiniPainterHub.Common.DTOs
@using MiniPainterHub.WebApp.Services.Http
@inject IPostService PostService

@if (!string.IsNullOrEmpty(loadError))
{
    <div class="status-panel status-panel--error" role="alert">
        <div class="status-panel__icon"><i class="bi bi-wifi-off" aria-hidden="true"></i></div>
        <div>
            <div class="status-panel__title">Couldn't load posts</div>
            <p class="status-panel__text mb-0">
                @loadError
                @if (errorStatus.HasValue)
                {
                    <span class="small">(Status: @((int)errorStatus.Value))</span>
                }
            </p>
        </div>
        <button class="btn btn-link btn-sm ms-auto" @onclick="() => LoadPosts(currentPage)">Retry</button>
    </div>
}
else if (isLoading)
{
    <div class="status-panel status-panel--info" aria-live="polite" aria-busy="true">
        <div class="status-panel__icon"><i class="bi bi-grid" aria-hidden="true"></i></div>
        <div>
            <div class="status-panel__title">Loading posts</div>
            <p class="status-panel__text mb-0">Preparing the latest gallery cards...</p>
        </div>
    </div>
}
else
{
    <AuthorizeView Roles="Moderator,Admin">
        <Authorized>
            <div class="mini-stat-bar mb-3" data-testid="post-visibility-filter">
                <label class="form-label mb-0" for="post-visibility-select">Visibility</label>
                <select id="post-visibility-select"
                        class="form-select w-auto"
                        data-testid="post-visibility-select"
                        value="@_visibilityFilter"
                        @onchange="OnVisibilityFilterChanged"
                        disabled="@isLoading">
                    <option value="active">Active only</option>
                    <option value="all">Include hidden</option>
                    <option value="hidden">Hidden only</option>
                </select>
            </div>
        </Authorized>
    </AuthorizeView>

    @if (!posts.Any())
    {
        <EmptyState IconClass="@EmptyIconClass"
                    Title="@EmptyTitle"
                    Description="@EmptyDescription"
                    TitleTag="h3"
                    TitleClass="empty-state__title h5">
            @if (EmptyContent is not null)
            {
                @EmptyContent
            }
        </EmptyState>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 g-4">
            @foreach (var post in posts)
            {
                <div class="col">
                    <PostCard Post="post" OnModerated="ReloadCurrentPageAsync" />
                </div>
            }
        </div>

        @if (totalPages > 1)
        {
            <div class="d-flex flex-column flex-md-row justify-content-md-between align-items-md-center gap-3 mt-4">
                <nav aria-label="Post pagination">
                    <ul class="pagination mb-0">
                        <li class="page-item @(hasPreviousPage ? string.Empty : "disabled")">
                            <button class="page-link" type="button" @onclick="() => ChangePage(currentPage - 1)" disabled="@(!hasPreviousPage || isLoading)">
                                Previous
                            </button>
                        </li>
                        <li class="page-item @(hasNextPage ? string.Empty : "disabled")">
                            <button class="page-link" type="button" @onclick="() => ChangePage(currentPage + 1)" disabled="@(!hasNextPage || isLoading)">
                                Next
                            </button>
                        </li>
                    </ul>
                </nav>

                <div class="mini-stat-bar">
                    <label class="form-label mb-0" for="pageSelector">Page</label>
                    <select id="pageSelector" class="form-select w-auto" @onchange="OnPageSelected" disabled="@isLoading">
                        @for (var page = 1; page <= totalPages; page++)
                        {
                            var selectPage = page;
                            if (page == currentPage)
                            {
                                <option value="@selectPage" selected>@selectPage</option>
                            }
                            else
                            {
                                <option value="@selectPage">@selectPage</option>
                            }
                        }
                    </select>
                    <span class="inline-note">of @totalPages</span>
                </div>
            </div>
        }
    }
}

@code {
    private List<PostSummaryDto> posts = new();
    private bool isLoading = true;
    private const int PageSize = 9;
    private string? loadError;
    private HttpStatusCode? errorStatus;
    private int currentPage = 1;
    private int totalPages = 1;
    private string _visibilityFilter = "active";
    private bool hasPreviousPage;
    private bool hasNextPage;

    [Parameter]
    public Func<IEnumerable<PostSummaryDto>, IEnumerable<PostSummaryDto>>? Query { get; set; } = source => source;

    [Parameter]
    public Func<int, int, Task<ApiResult<PagedResult<PostSummaryDto>>>>? LoadPostsHandler { get; set; }

    [Parameter]
    public string EmptyIconClass { get; set; } = "bi bi-brush";

    [Parameter]
    public string EmptyTitle { get; set; } = "No posts yet.";

    [Parameter]
    public string EmptyDescription { get; set; } = "When new work arrives, it will appear here.";

    [Parameter]
    public RenderFragment? EmptyContent { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        if (previousQuery != Query || previousLoader != LoadPostsHandler)
        {
            previousQuery = Query;
            previousLoader = LoadPostsHandler;
            await LoadPosts();
        }
    }

    private Func<IEnumerable<PostSummaryDto>, IEnumerable<PostSummaryDto>>? previousQuery;
    private Func<int, int, Task<ApiResult<PagedResult<PostSummaryDto>>>>? previousLoader;

    private async Task LoadPosts(int page = 1)
    {
        isLoading = true;
        loadError = null;
        errorStatus = null;
        await InvokeAsync(StateHasChanged);

        var result = LoadPostsHandler == null
            ? await PostService.GetAllAsync(
                page,
                PageSize,
                includeDeleted: _visibilityFilter is "all" or "hidden",
                deletedOnly: _visibilityFilter == "hidden")
            : await LoadPostsHandler(page, PageSize);

        if (!result.Success)
        {
            errorStatus = result.StatusCode;
            loadError = result.StatusCode == HttpStatusCode.NotFound
                ? "No posts could be found."
                : "We couldn't load posts right now. Please check your connection and try again.";
            posts = new List<PostSummaryDto>();
            isLoading = false;
            await InvokeAsync(StateHasChanged);
            return;
        }

        var pageResult = result.Value ?? new PagedResult<PostSummaryDto>();

        currentPage = pageResult.TotalPages == 0 ? 1 : pageResult.PageNumber;
        totalPages = Math.Max(pageResult.TotalPages, 1);
        hasPreviousPage = pageResult.HasPreviousPage && totalPages > 1;
        hasNextPage = pageResult.HasNextPage && totalPages > 1;

        var pageItems = pageResult.Items ?? Array.Empty<PostSummaryDto>();
        var items = Query != null ? (Query.Invoke(pageItems) ?? Array.Empty<PostSummaryDto>()) : pageItems;
        posts = items.ToList();

        isLoading = false;
    }

    private async Task ChangePage(int page)
    {
        if (page < 1 || page > totalPages || page == currentPage || isLoading)
        {
            return;
        }

        await LoadPosts(page);
    }

    private async Task OnPageSelected(ChangeEventArgs args)
    {
        if (args?.Value is null)
        {
            return;
        }

        if (int.TryParse(args.Value.ToString(), out var page))
        {
            await ChangePage(page);
        }
    }

    private Task ReloadCurrentPageAsync() => LoadPosts(currentPage);

    private async Task OnVisibilityFilterChanged(ChangeEventArgs args)
    {
        if (LoadPostsHandler != null)
        {
            return;
        }

        var selectedValue = args.Value?.ToString();
        if (selectedValue is not "active" and not "all" and not "hidden")
        {
            return;
        }

        if (string.Equals(_visibilityFilter, selectedValue, StringComparison.Ordinal))
        {
            return;
        }

        _visibilityFilter = selectedValue;
        await LoadPosts(1);
    }
}
