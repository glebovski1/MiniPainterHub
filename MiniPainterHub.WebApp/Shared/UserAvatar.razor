<div class="user-avatar @ClassName" style="@AvatarStyle" title="@Name">
    @if (!string.IsNullOrWhiteSpace(ImageUrl))
    {
        <img src="@ImageUrl"
             alt="@AltText"
             class="user-avatar__image"
             loading="lazy" />
    }
    else
    {
        <span class="user-avatar__fallback" aria-hidden="true">@Initials</span>
        <span class="visually-hidden">@AltText</span>
    }
</div>

@code {
    [Parameter] public string? ImageUrl { get; set; }
    [Parameter] public string? Name { get; set; }
    [Parameter] public int Size { get; set; } = 48;
    [Parameter] public string ClassName { get; set; } = string.Empty;

    private string AvatarStyle => $"--avatar-size: {Size}px;";
    private string AltText => string.IsNullOrWhiteSpace(Name) ? "User avatar" : $"{Name} avatar";

    private string Initials
    {
        get
        {
            if (string.IsNullOrWhiteSpace(Name))
            {
                return "MP";
            }

            var parts = Name.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            return parts.Length switch
            {
                0 => "MP",
                1 => parts[0][..Math.Min(2, parts[0].Length)].ToUpperInvariant(),
                _ => string.Concat(parts[0][0], parts[^1][0]).ToUpperInvariant()
            };
        }
    }
}
