@using MiniPainterHub.Common.DTOs
@using MiniPainterHub.WebApp.Services
@using System.Net
@using Microsoft.AspNetCore.Components.Authorization
@inject ICommentService CommentService

<div data-testid="comment-list-container">
    <AuthorizeView Roles="Moderator,Admin">
        <Authorized>
            <div class="mini-stat-bar mb-3" data-testid="comment-visibility-filter">
                <label class="form-label mb-0" for="comment-visibility-select">Visibility</label>
                <select id="comment-visibility-select"
                        class="form-select w-auto"
                        data-testid="comment-visibility-select"
                        value="@_visibilityFilter"
                        @onchange="OnVisibilityFilterChanged"
                        disabled="@isLoading">
                    <option value="active">Active only</option>
                    <option value="all">Include hidden</option>
                    <option value="hidden">Hidden only</option>
                </select>
            </div>
        </Authorized>
    </AuthorizeView>

    @if (!string.IsNullOrEmpty(_loadError))
    {
        <div class="status-panel status-panel--warning" role="alert">
            <div class="status-panel__icon"><i class="bi bi-exclamation-triangle-fill" aria-hidden="true"></i></div>
            <div>
                <div class="status-panel__title">Couldn’t load comments</div>
                <p class="status-panel__text mb-0">
                    @_loadError
                    @if (_errorStatus.HasValue)
                    {
                        <span class="small">(Status: @((int)_errorStatus.Value))</span>
                    }
                </p>
            </div>
            <button class="btn btn-link btn-sm ms-auto" @onclick="ReloadAsync">Retry</button>
        </div>
    }
    else if (_comments == null)
    {
        <div class="status-panel status-panel--info">
            <div class="status-panel__icon"><i class="bi bi-chat-left-text" aria-hidden="true"></i></div>
            <div>
                <div class="status-panel__title">Loading comments</div>
                <p class="status-panel__text mb-0">Pulling in the conversation around this post.</p>
            </div>
        </div>
    }
    else if (!_comments.Items.Any())
    {
        <section class="empty-state">
            <div class="empty-state__icon"><i class="bi bi-chat" aria-hidden="true"></i></div>
            <h3 class="empty-state__title h5">No comments yet</h3>
            <p class="empty-state__text mb-0">Be the first to add a helpful note.</p>
        </section>
    }
    else
    {
        @foreach (var comment in _comments.Items)
        {
            <CommentItem Comment="comment" OnModerated="ReloadAsync" />
        }

        <nav aria-label="Comment pagination">
            <ul class="pagination mb-0">
                <li class="page-item @(_page == 1 ? "disabled" : string.Empty)">
                    <button class="page-link" @onclick="() => ChangePage(_page - 1)">&lt;&lt;</button>
                </li>
                @for (var pageNumber = 1; pageNumber <= _comments.TotalPages; pageNumber++)
                {
                    var selectedPage = pageNumber;
                    <li class="page-item @(pageNumber == _page ? "active" : string.Empty)">
                        <button class="page-link" @onclick="() => ChangePage(selectedPage)">@selectedPage</button>
                    </li>
                }
                <li class="page-item @(_page == _comments.TotalPages ? "disabled" : string.Empty)">
                    <button class="page-link" @onclick="() => ChangePage(_page + 1)">&gt;&gt;</button>
                </li>
            </ul>
        </nav>
    }
</div>

@code {
    [Parameter] public int PostId { get; set; }

    private PagedResult<CommentDto>? _comments;
    private int _page = 1;
    private const int PageSize = 10;
    private string? _loadError;
    private HttpStatusCode? _errorStatus;
    private string _visibilityFilter = "active";
    private bool isLoading => _comments == null && string.IsNullOrWhiteSpace(_loadError);

    protected override async Task OnParametersSetAsync()
        => await LoadPageAsync();

    public async Task ReloadAsync()
    {
        await LoadPageAsync();
    }

    private async Task LoadPageAsync()
    {
        _loadError = null;
        _errorStatus = null;

        var includeDeleted = _visibilityFilter is "all" or "hidden";
        var deletedOnly = _visibilityFilter == "hidden";

        var response = await CommentService.GetByPostAsync(PostId, _page, PageSize, includeDeleted, deletedOnly);

        if (!response.Success)
        {
            _errorStatus = response.StatusCode;
            _loadError = response.StatusCode == HttpStatusCode.NotFound
                ? "Comments could not be found for this post."
                : "We couldn't load comments right now. Please try again.";
            _comments = null;
        }
        else
        {
            _comments = response.Value ?? new PagedResult<CommentDto>();
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task ChangePage(int newPage)
    {
        if (newPage < 1 || newPage > (_comments?.TotalPages ?? 1))
        {
            return;
        }

        _page = newPage;
        await LoadPageAsync();
    }

    private async Task OnVisibilityFilterChanged(ChangeEventArgs args)
    {
        var selectedValue = args.Value?.ToString();
        if (selectedValue is not "active" and not "all" and not "hidden")
        {
            return;
        }

        if (string.Equals(_visibilityFilter, selectedValue, StringComparison.Ordinal))
        {
            return;
        }

        _visibilityFilter = selectedValue;
        _page = 1;
        await LoadPageAsync();
    }
}
