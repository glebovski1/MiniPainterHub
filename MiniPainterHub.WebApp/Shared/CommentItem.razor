@using MiniPainterHub.Common.DTOs
@inject MiniPainterHub.WebApp.Services.Interfaces.IModerationService ModerationService

<div class="card shadow-sm mb-3 comment-item @(IsActive ? "comment-item--active" : null) @(IsViewerPanel ? "comment-item--viewer-panel" : null) @(CanViewerSurfaceToggle ? "comment-item--clickable" : null)"
     data-testid="comment-item"
     role="@(CanViewerSurfaceToggle ? "button" : null)"
     tabindex="@(CanViewerSurfaceToggle ? 0 : -1)"
     @onclick="HandleSurfaceClickAsync"
     @onkeydown="HandleSurfaceKeyDownAsync">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div class="d-flex align-items-center gap-2">
                <NavLink class="text-decoration-none fw-semibold"
                         href="@($"/users/{Comment.AuthorId}")"
                         @onclick:stopPropagation="true">@Comment.AuthorName</NavLink>
                <AuthorizeView Roles="Moderator,Admin">
                    <Authorized>
                        <span class="badge text-bg-secondary" data-testid="comment-id-badge">#@Comment.Id</span>
                    </Authorized>
                </AuthorizeView>
            </div>
            <small class="text-muted">
                @Comment.CreatedAt.ToLocalTime().ToString("g")
            </small>
        </div>

        <p class="mt-3 mb-0">@Comment.Content</p>

        <div class="d-flex flex-wrap align-items-center gap-2 mt-3">
            @if (Comment.HasViewerMark)
            {
                <span class="badge text-bg-light border comment-item__mark-badge" data-testid="comment-mark-badge">
                    <i class="bi bi-geo-alt-fill" aria-hidden="true"></i>
                    Marked
                </span>
            }

            @if (Comment.IsDeleted)
            {
                <span class="badge text-bg-warning" data-testid="comment-hidden-badge">Hidden</span>
            }
        </div>

        @if (CanToggleViewerMark)
        {
            <div class="d-flex flex-wrap align-items-center gap-2 mt-3">
                <button type="button"
                        class="btn btn-sm @(IsActive ? "btn-warning" : IsViewerPanel ? "btn-light" : "btn-outline-primary")"
                        data-testid="comment-show-mark"
                        disabled="@IsViewerMarkLoading"
                        @onclick:stopPropagation="true"
                        @onclick="ToggleViewerMarkAsync">
                    @(IsActive ? ViewerActionActiveLabel : ViewerActionLabel)
                </button>

                @if (IsViewerMarkLoading)
                {
                    <span class="text-muted small" data-testid="comment-mark-loading">Loading marker...</span>
                }

                @if (IsViewerPanel && Comment.HasViewerMark && !IsViewerMarkLoading)
                {
                    <span class="small text-muted comment-item__viewer-caption">
                        @(IsActive ? "Marker highlighted in the stage." : "Reveal this discussion anchor in the stage.")
                    </span>
                }
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(ViewerMarkError))
        {
            <div class="text-danger small mt-2" role="alert" data-testid="comment-mark-error">@ViewerMarkError</div>
        }

        @if (!IsViewerPanel)
        {
            <ReportAction TargetType="@ReportTargetTypes.Comment"
                          TargetId="@Comment.Id.ToString()"
                          OwnerUserId="@Comment.AuthorId"
                          TestIdPrefix="comment-report" />
        }

        @if (!IsViewerPanel)
        {
            <AuthorizeView Roles="Moderator,Admin">
                <Authorized>
                    <div class="d-flex flex-wrap gap-2 mt-2" data-testid="comment-inline-moderation-controls">
                        @if (Comment.IsDeleted)
                        {
                            <button class="btn btn-outline-secondary btn-sm"
                                    type="button"
                                    data-testid="comment-inline-restore"
                                    @onclick="RestoreCommentAsync"
                                    disabled="@_moderationBusy">
                                Restore comment
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-outline-warning btn-sm"
                                    type="button"
                                    data-testid="comment-inline-hide"
                                    @onclick="HideCommentAsync"
                                    disabled="@_moderationBusy">
                                Hide comment
                            </button>
                        }
                    </div>
                </Authorized>
            </AuthorizeView>

            @if (!string.IsNullOrWhiteSpace(_moderationError))
            {
                <div class="text-danger small mt-2" data-testid="comment-inline-moderation-error">@_moderationError</div>
            }
            else if (!string.IsNullOrWhiteSpace(_moderationResult))
            {
                <div class="text-success small mt-2" data-testid="comment-inline-moderation-result">@_moderationResult</div>
            }
        }
    </div>
</div>

@code {
    [Parameter] public CommentDto Comment { get; set; } = default!;
    [Parameter] public EventCallback OnModerated { get; set; }
    [Parameter] public bool IsActive { get; set; }
    [Parameter] public bool CanToggleViewerMark { get; set; }
    [Parameter] public bool IsViewerMarkLoading { get; set; }
    [Parameter] public string? ViewerMarkError { get; set; }
    [Parameter] public EventCallback OnToggleViewerMark { get; set; }
    [Parameter] public bool IsViewerPanel { get; set; }
    [Parameter] public string ViewerActionLabel { get; set; } = "Show on image";
    [Parameter] public string ViewerActionActiveLabel { get; set; } = "Hide marker";

    private bool _moderationBusy;
    private string? _moderationError;
    private string? _moderationResult;
    private bool CanViewerSurfaceToggle => IsViewerPanel && CanToggleViewerMark;

    private Task HideCommentAsync() => ModerateCommentAsync(hide: true);

    private Task RestoreCommentAsync() => ModerateCommentAsync(hide: false);

    private async Task ModerateCommentAsync(bool hide)
    {
        _moderationError = null;
        _moderationResult = null;

        _moderationBusy = true;
        try
        {
            var request = new ModerationActionRequestDto
            {
                Reason = "Inline moderation from comments list."
            };

            var success = hide
                ? await ModerationService.HideCommentAsync(Comment.Id, request)
                : await ModerationService.RestoreCommentAsync(Comment.Id, request);

            if (!success)
            {
                _moderationError = "Moderation action failed.";
                return;
            }

            _moderationResult = hide ? "Comment hidden." : "Comment restored.";

            if (OnModerated.HasDelegate)
            {
                await OnModerated.InvokeAsync();
            }
        }
        finally
        {
            _moderationBusy = false;
        }
    }

    private Task ToggleViewerMarkAsync() =>
        OnToggleViewerMark.HasDelegate ? OnToggleViewerMark.InvokeAsync() : Task.CompletedTask;

    private Task HandleSurfaceClickAsync() =>
        CanViewerSurfaceToggle ? ToggleViewerMarkAsync() : Task.CompletedTask;

    private Task HandleSurfaceKeyDownAsync(KeyboardEventArgs args) =>
        CanViewerSurfaceToggle && (args.Key == "Enter" || args.Key == " ")
            ? ToggleViewerMarkAsync()
            : Task.CompletedTask;
}
