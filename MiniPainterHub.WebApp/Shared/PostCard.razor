@using Microsoft.AspNetCore.Components.Authorization
@using MiniPainterHub.Common.DTOs
@inject NavigationManager Navigation
@inject MiniPainterHub.WebApp.Services.Interfaces.IModerationService ModerationService

<div class="card h-100 shadow-sm post-card">
    @if (!string.IsNullOrEmpty(Post.ImageUrl))
    {
        <NavLink class="text-decoration-none post-card__media-link" href="@($"/posts/{Post.Id}")">
            <img src="@DisplayImageUrl"
                 class="card-img-top post-card__image"
                 data-testid="post-card-image"
                 alt="Post image"
                 @onerror="HandleImageError"
                 loading="lazy" />
        </NavLink>
    }
    else
    {
        <div class="post-card__placeholder">
            <i class="bi bi-image" aria-hidden="true"></i>
            <span>No preview image</span>
        </div>
    }

    <div class="card-body post-card__body">
        <div class="d-flex align-items-start justify-content-between gap-2">
            <NavLink class="text-decoration-none text-dark flex-grow-1" href="@($"/posts/{Post.Id}")">
                <h5 class="card-title post-card__title mb-0">@Post.Title</h5>
            </NavLink>
            <AuthorizeView Roles="Moderator,Admin">
                <Authorized>
                    <span class="badge text-bg-secondary flex-shrink-0" data-testid="post-id-badge">#@Post.Id</span>
                </Authorized>
            </AuthorizeView>
        </div>

        <NavLink class="text-decoration-none text-dark" href="@($"/posts/{Post.Id}")">
            <p class="card-text post-card__snippet text-truncate">@Post.Snippet</p>
        </NavLink>

        <TagBadgeList Tags="Post.Tags" TestId="post-card-tags" />

        @if (Post.IsDeleted)
        {
            <span class="badge text-bg-warning mt-3" data-testid="post-hidden-badge">Hidden</span>
        }
    </div>

    <div class="card-footer post-card__footer mt-auto">
        <div class="post-card__footer-meta">
            <small class="text-muted">
                <NavLink class="text-decoration-none" href="@($"/users/{Post.AuthorId}")">@Post.AuthorName</NavLink>
                <span class="mx-1">&bull;</span> @Post.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")
            </small>
            <div class="mini-stat-bar">
                <span class="mini-stat"><i class="bi bi-chat-left-text" aria-hidden="true"></i> @Post.CommentCount</span>
                <span class="mini-stat"><i class="bi bi-heart" aria-hidden="true"></i> @Post.LikeCount</span>
            </div>
        </div>
    </div>

    <AuthorizeView Roles="Moderator,Admin">
        <Authorized>
            <div class="card-footer border-top-0 pt-0">
                <div class="d-flex gap-2">
                    @if (Post.IsDeleted)
                    {
                        <button class="btn btn-outline-secondary btn-sm"
                                type="button"
                                data-testid="post-card-restore"
                                @onclick="RestoreAsync"
                                disabled="@_moderationBusy">
                            Restore
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-outline-warning btn-sm"
                                type="button"
                                data-testid="post-card-hide"
                                @onclick="HideAsync"
                                disabled="@_moderationBusy">
                            Hide
                        </button>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(_moderationError))
                {
                    <div class="text-danger small mt-2" data-testid="post-card-moderation-error">@_moderationError</div>
                }
                else if (!string.IsNullOrWhiteSpace(_moderationResult))
                {
                    <div class="text-success small mt-2" data-testid="post-card-moderation-result">@_moderationResult</div>
                }
            </div>
        </Authorized>
    </AuthorizeView>
</div>

@code {
    [Parameter] public PostSummaryDto Post { get; set; } = default!;
    [Parameter] public EventCallback OnModerated { get; set; }

    private bool _useFullImage;
    private bool _moderationBusy;
    private string? _moderationError;
    private string? _moderationResult;

    private string FullImageUrl => MakeAbsoluteUrl(Post.ImageUrl);
    private string ThumbImageUrl => MakeAbsoluteUrl(ReplaceVariantSuffix(Post.ImageUrl, "_thumb."));
    private string DisplayImageUrl => _useFullImage ? FullImageUrl : ThumbImageUrl;

    private string MakeAbsoluteUrl(string? url) =>
        string.IsNullOrEmpty(url)
            ? string.Empty
            : url.StartsWith("http", StringComparison.OrdinalIgnoreCase)
                ? url
                : $"{Navigation.BaseUri.TrimEnd('/')}{url}";

    private static string ReplaceVariantSuffix(string? url, string replacement)
    {
        if (string.IsNullOrEmpty(url))
        {
            return string.Empty;
        }

        return url.Contains("_max.", StringComparison.OrdinalIgnoreCase)
            ? url.Replace("_max.", replacement, StringComparison.OrdinalIgnoreCase)
            : url;
    }

    private void HandleImageError()
    {
        if (_useFullImage)
        {
            return;
        }

        _useFullImage = true;
    }

    private Task HideAsync() => ModerateAsync(hide: true);
    private Task RestoreAsync() => ModerateAsync(hide: false);

    private async Task ModerateAsync(bool hide)
    {
        _moderationError = null;
        _moderationResult = null;

        _moderationBusy = true;
        try
        {
            var request = new ModerationActionRequestDto
            {
                Reason = "Inline moderation from post list."
            };

            var success = hide
                ? await ModerationService.HidePostAsync(Post.Id, request)
                : await ModerationService.RestorePostAsync(Post.Id, request);

            if (!success)
            {
                _moderationError = "Moderation action failed.";
                return;
            }

            _moderationResult = hide ? "Post hidden." : "Post restored.";
            if (OnModerated.HasDelegate)
            {
                await OnModerated.InvokeAsync();
            }
        }
        finally
        {
            _moderationBusy = false;
        }
    }
}
