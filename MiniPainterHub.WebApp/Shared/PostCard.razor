@using Microsoft.AspNetCore.Components.Authorization
@using MiniPainterHub.Common.DTOs
@inject NavigationManager Navigation
@inject MiniPainterHub.WebApp.Services.Interfaces.IModerationService ModerationService

<article class="@CardCssClass">
    @if (HasImage)
    {
        <NavLink class="text-decoration-none post-card__media-link" href="@($"/posts/{Post.Id}")">
            <img src="@DisplayImageUrl"
                 class="card-img-top post-card__image"
                 data-testid="post-card-image"
                 alt="@ImageAltText"
                 @onerror="HandleImageError"
                 loading="@ImageLoading"
                 fetchpriority="@ImageFetchPriority"
                 decoding="async" />
        </NavLink>
    }
    <div class="post-card__body">
        <div class="post-card__meta-row">
            <NavLink class="post-card__author-link" href="@($"/users/{Post.AuthorId}")">@Post.AuthorName</NavLink>
            <span>@Post.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</span>
        </div>

        <div class="post-card__title-row">
            <NavLink class="post-card__title-link" href="@($"/posts/{Post.Id}")">
                <h2 class="post-card__title">@Post.Title</h2>
            </NavLink>
            <AuthorizeView Roles="Moderator,Admin">
                <Authorized>
                    <span class="post-card__id-badge" data-testid="post-id-badge">#@Post.Id</span>
                </Authorized>
            </AuthorizeView>
        </div>

        <NavLink class="post-card__snippet-link" href="@($"/posts/{Post.Id}")">
            <p class="post-card__snippet">@Post.Snippet</p>
        </NavLink>

        @if (HasRecipeSummary)
        {
            <div class="post-card__recipe" data-testid="post-card-recipe">
                @if (!string.IsNullOrWhiteSpace(Post.MiniatureName))
                {
                    <span><i class="bi bi-brush" aria-hidden="true"></i>@Post.MiniatureName</span>
                }
                @if (!string.IsNullOrWhiteSpace(Post.Difficulty))
                {
                    <span><i class="bi bi-speedometer2" aria-hidden="true"></i>@Post.Difficulty</span>
                }
                @if (!string.IsNullOrWhiteSpace(Post.Techniques))
                {
                    <span><i class="bi bi-palette2" aria-hidden="true"></i>@Post.Techniques</span>
                }
            </div>
        }

        <TagBadgeList Tags="Post.Tags" TestId="post-card-tags" />

        @if (Post.IsDeleted)
        {
            <span class="post-card__status-badge" data-testid="post-hidden-badge">Hidden</span>
        }
    </div>

    <div class="post-card__footer mt-auto">
        <div class="post-card__footer-meta">
            <div class="mini-stat-bar">
                <span class="mini-stat"><i class="bi bi-chat-left-text" aria-hidden="true"></i> @Post.CommentCount</span>
                <span class="mini-stat"><i class="bi bi-heart" aria-hidden="true"></i> @Post.LikeCount</span>
            </div>
            <NavLink class="post-card__open" href="@($"/posts/{Post.Id}")">
                <span>Open post</span>
                <i class="bi bi-arrow-right-short" aria-hidden="true"></i>
            </NavLink>
        </div>
    </div>

    <AuthorizeView Roles="Moderator,Admin">
        <Authorized>
            <div class="post-card__moderation">
                <div class="post-card__moderation-actions">
                    @if (Post.IsDeleted)
                    {
                        <button class="btn btn-outline-secondary btn-sm"
                                type="button"
                                data-testid="post-card-restore"
                                @onclick="RestoreAsync"
                                disabled="@_moderationBusy">
                            Restore
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-outline-warning btn-sm"
                                type="button"
                                data-testid="post-card-hide"
                                @onclick="HideAsync"
                                disabled="@_moderationBusy">
                            Hide
                        </button>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(_moderationError))
                {
                    <div class="text-danger small mt-2" data-testid="post-card-moderation-error">@_moderationError</div>
                }
                else if (!string.IsNullOrWhiteSpace(_moderationResult))
                {
                    <div class="text-success small mt-2" data-testid="post-card-moderation-result">@_moderationResult</div>
                }
            </div>
        </Authorized>
    </AuthorizeView>
</article>

@code {
    [Parameter] public PostSummaryDto Post { get; set; } = default!;
    [Parameter] public EventCallback OnModerated { get; set; }
    [Parameter] public bool IsPriorityImage { get; set; }

    private bool _useFullImage;
    private bool _moderationBusy;
    private string? _moderationError;
    private string? _moderationResult;
    private bool HasImage => !string.IsNullOrWhiteSpace(Post.ImageUrl);
    private string CardCssClass => HasImage ? "post-card h-100" : "post-card post-card--text-only";
    private string ImageAltText => $"{Post.Title} by {Post.AuthorName}";
    private bool HasRecipeSummary =>
        !string.IsNullOrWhiteSpace(Post.MiniatureName)
        || !string.IsNullOrWhiteSpace(Post.Difficulty)
        || !string.IsNullOrWhiteSpace(Post.Techniques);

    private string FullImageUrl => MakeAbsoluteUrl(Post.ImageUrl);
    private string ThumbImageUrl => MakeAbsoluteUrl(ResolveThumbnailUrl());
    private string DisplayImageUrl => _useFullImage ? FullImageUrl : ThumbImageUrl;
    private string ImageLoading => IsPriorityImage ? "eager" : "lazy";
    private string ImageFetchPriority => IsPriorityImage ? "high" : "auto";

    private string MakeAbsoluteUrl(string? url) =>
        string.IsNullOrEmpty(url)
            ? string.Empty
            : url.StartsWith("http", StringComparison.OrdinalIgnoreCase)
                ? url
                : $"{Navigation.BaseUri.TrimEnd('/')}{url}";

    private static string ReplaceVariantSuffix(string? url, string replacement)
    {
        if (string.IsNullOrEmpty(url))
        {
            return string.Empty;
        }

        return url.Contains("_max.", StringComparison.OrdinalIgnoreCase)
            ? url.Replace("_max.", replacement, StringComparison.OrdinalIgnoreCase)
            : url;
    }

    private string? ResolveThumbnailUrl()
    {
        if (!string.IsNullOrWhiteSpace(Post.ThumbnailUrl)
            && !string.Equals(Post.ThumbnailUrl, Post.ImageUrl, StringComparison.OrdinalIgnoreCase))
        {
            return Post.ThumbnailUrl;
        }

        return ReplaceVariantSuffix(Post.ImageUrl, "_thumb.");
    }

    private void HandleImageError()
    {
        if (_useFullImage)
        {
            return;
        }

        _useFullImage = true;
    }

    private Task HideAsync() => ModerateAsync(hide: true);
    private Task RestoreAsync() => ModerateAsync(hide: false);

    private async Task ModerateAsync(bool hide)
    {
        _moderationError = null;
        _moderationResult = null;

        _moderationBusy = true;
        try
        {
            var request = new ModerationActionRequestDto
            {
                Reason = "Inline moderation from post list."
            };

            var success = hide
                ? await ModerationService.HidePostAsync(Post.Id, request)
                : await ModerationService.RestorePostAsync(Post.Id, request);

            if (!success)
            {
                _moderationError = "Moderation action failed.";
                return;
            }

            _moderationResult = hide ? "Post hidden." : "Post restored.";
            if (OnModerated.HasDelegate)
            {
                await OnModerated.InvokeAsync();
            }
        }
        finally
        {
            _moderationBusy = false;
        }
    }
}
