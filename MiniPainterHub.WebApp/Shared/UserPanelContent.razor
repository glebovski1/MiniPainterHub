@* Reusable content for the side panel and /me page *@
@using Microsoft.AspNetCore.Components.Authorization

<div class="dashboard-sidebar-content p-3 p-lg-4">
    @if (ShowPanelTitle)
    {
        <h2 class="h6 text-uppercase text-muted fw-semibold mb-3">My panel</h2>
    }

    <AuthorizeView Context="auth">
        <Authorized>
            <div class="d-flex align-items-center gap-2 rounded-3 border bg-white p-2 mb-4">
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-primary-subtle text-primary flex-shrink-0 dashboard-avatar">
                    <i class="bi bi-person-fill" aria-hidden="true"></i>
                </div>
                <div class="lh-sm overflow-hidden">
                    <div class="small text-muted">Signed in</div>
                    <div class="fw-semibold text-truncate">
                        @((auth.User.Identity?.Name) ?? "User")
                    </div>
                </div>
            </div>
        </Authorized>
    </AuthorizeView>

    <div class="small text-uppercase text-muted fw-semibold mb-2">Quick actions</div>
    <nav class="nav nav-pills flex-column dashboard-nav gap-1" aria-label="Personal panel navigation">
        <NavLink class="nav-link dashboard-nav-link" href="/profile">
            <i class="bi bi-person" aria-hidden="true"></i>
            <span>My profile</span>
        </NavLink>

        <NavLink class="nav-link dashboard-nav-link" href="/posts/mine">
            <i class="bi bi-file-earmark-text" aria-hidden="true"></i>
            <span>My posts</span>
        </NavLink>
    </nav>

    <hr class="my-3" />

    <NavLink class="btn btn-primary w-100 d-inline-flex align-items-center justify-content-center gap-2 dashboard-create-btn" href="/posts/new">
        <i class="bi bi-plus-circle" aria-hidden="true"></i>
        <span>Create a post</span>
    </NavLink>
</div>

@code {
    [Parameter]
    public bool ShowPanelTitle { get; set; } = true;
}
