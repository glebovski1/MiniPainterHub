@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider

@if (_checkedAuthentication && _isAuthenticated)
{
    <div class="page-shell py-4">
        <section class="surface-card content-stack" data-testid="access-denied-message">
            <p class="section-label mb-0">Restricted area</p>
            <div>
                <h1 class="h3 mb-2">You do not have access to this page.</h1>
                <p class="mb-0 text-muted">Your account is signed in, but it does not have permission to open this route.</p>
            </div>
            <div class="d-flex flex-wrap gap-2">
                <a class="btn btn-primary" href="/">Return to the feed</a>
            </div>
        </section>
    </div>
}
else if (!_checkedAuthentication)
{
    <div class="page-shell py-4">
        <div class="status-panel status-panel--info" data-testid="redirect-auth-check">
            <div class="status-panel__icon"><i class="bi bi-shield-lock" aria-hidden="true"></i></div>
            <div>
                <div class="status-panel__title">Checking access</div>
                <p class="status-panel__text mb-0">Preparing the correct sign-in state for this route.</p>
            </div>
        </div>
    </div>
}
else
{
    <div class="page-shell py-4">
        <section class="surface-card content-stack" data-testid="access-login-required">
            <p class="section-label mb-0">Sign in required</p>
            <div>
                <h1 class="h3 mb-2">You need to sign in to continue.</h1>
                <p class="mb-0 text-muted">This part of MiniPainterHub is only available after login. We will keep the return URL so you can come back here afterward.</p>
            </div>
            <div class="d-flex flex-wrap gap-2">
                <a class="btn btn-primary" data-testid="redirect-login-link" href="@BuildLoginUrl()">Go to login</a>
                <a class="btn btn-outline-secondary" href="/">Back to the feed</a>
            </div>
        </section>
    </div>
}

@code {
    private bool _checkedAuthentication;
    private bool _isAuthenticated;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _isAuthenticated = authState.User.Identity?.IsAuthenticated == true;
        _checkedAuthentication = true;
    }

    private string BuildLoginUrl()
    {
        var currentPath = "/" + Navigation.ToBaseRelativePath(Navigation.Uri);
        if (currentPath.StartsWith("/login", StringComparison.OrdinalIgnoreCase))
        {
            return "/login";
        }

        var returnUrl = Uri.EscapeDataString(Navigation.Uri);
        return $"/login?returnUrl={returnUrl}";
    }
}
