<header class="viewer-toolbar">
    <div class="viewer-toolbar__top">
        <div class="viewer-toolbar__identity">
            <div class="viewer-toolbar__eyebrow">@Eyebrow</div>
            <div class="viewer-toolbar__title" id="@TitleId">@Title</div>
        </div>

        <button type="button"
                class="btn btn-sm btn-light viewer-toolbar__close"
                data-testid="viewer-close"
                @onclick="OnClose">
            <i class="bi bi-x-lg" aria-hidden="true"></i>
            <span>Close</span>
        </button>
    </div>

    <div class="viewer-toolbar__status">
        <div class="viewer-toolbar__status-pill">
            <span class="viewer-toolbar__status-label">Image</span>
            <strong>@Math.Max(CurrentIndex, 1) / @Math.Max(TotalCount, 1)</strong>
        </div>
        <div class="viewer-toolbar__status-pill">
            <span class="viewer-toolbar__status-label">Zoom</span>
            <strong>@ZoomPercent%</strong>
        </div>
    </div>

    <section class="viewer-toolbar__cluster" aria-label="Image navigation">
        <div class="viewer-toolbar__label">Browse</div>
        <div class="viewer-toolbar__button-pair" role="group" aria-label="Image navigation">
            <button type="button"
                    class="btn btn-outline-light"
                    data-testid="viewer-prev"
                    disabled="@(!CanGoPrevious)"
                    @onclick="OnPrevious">
                <i class="bi bi-arrow-left" aria-hidden="true"></i>
                <span class="visually-hidden">Previous image</span>
            </button>
            <button type="button"
                    class="btn btn-outline-light"
                    data-testid="viewer-next"
                    disabled="@(!CanGoNext)"
                    @onclick="OnNext">
                <i class="bi bi-arrow-right" aria-hidden="true"></i>
                <span class="visually-hidden">Next image</span>
            </button>
        </div>
    </section>

    <section class="viewer-toolbar__cluster" aria-label="Zoom controls">
        <div class="viewer-toolbar__label">View</div>
        <div class="viewer-toolbar__button-trio" role="group" aria-label="Zoom controls">
            <button type="button" class="btn btn-outline-light" data-testid="viewer-zoom-out" @onclick="OnZoomOut">
                <i class="bi bi-dash-lg" aria-hidden="true"></i>
                <span class="visually-hidden">Zoom out</span>
            </button>
            <button type="button" class="btn btn-outline-light viewer-toolbar__fit" data-testid="viewer-reset" @onclick="OnResetView">
                Fit
            </button>
            <button type="button" class="btn btn-outline-light" data-testid="viewer-zoom-in" @onclick="OnZoomIn">
                <i class="bi bi-plus-lg" aria-hidden="true"></i>
                <span class="visually-hidden">Zoom in</span>
            </button>
        </div>

        @if (CanToggleFullscreen)
        {
            <button type="button"
                    class="btn btn-outline-light viewer-toolbar__wide-action"
                    data-testid="viewer-fullscreen"
                    @onclick="OnToggleFullscreen">
                <i class="bi @(IsFullscreen ? "bi-fullscreen-exit" : "bi-arrows-fullscreen")" aria-hidden="true"></i>
                <span>@(IsFullscreen ? "Exit fullscreen" : "Fullscreen")</span>
            </button>
        }
    </section>

    @if (CanAddAuthorMark)
    {
        <section class="viewer-toolbar__cluster" aria-label="Annotation controls">
            <div class="viewer-toolbar__label">Marks</div>
            <button type="button"
                    class="btn @(IsAuthorPlacementMode ? "btn-warning" : "btn-outline-light") viewer-toolbar__wide-action"
                    data-testid="viewer-add-note"
                    @onclick="OnToggleAuthorPlacement">
                <i class="bi bi-pin-angle" aria-hidden="true"></i>
                <span>@(IsAuthorPlacementMode ? "Cancel note" : "Add note")</span>
            </button>
        </section>
    }
</header>

@code {
    [Parameter] public string Eyebrow { get; set; } = "Rich viewer";
    [Parameter] public string Title { get; set; } = "Image viewer";
    [Parameter] public string? TitleId { get; set; }
    [Parameter] public int CurrentIndex { get; set; }
    [Parameter] public int TotalCount { get; set; }
    [Parameter] public int ZoomPercent { get; set; }
    [Parameter] public bool CanGoPrevious { get; set; }
    [Parameter] public bool CanGoNext { get; set; }
    [Parameter] public bool CanAddAuthorMark { get; set; }
    [Parameter] public bool IsAuthorPlacementMode { get; set; }
    [Parameter] public bool CanToggleFullscreen { get; set; }
    [Parameter] public bool IsFullscreen { get; set; }
    [Parameter] public EventCallback OnPrevious { get; set; }
    [Parameter] public EventCallback OnNext { get; set; }
    [Parameter] public EventCallback OnZoomIn { get; set; }
    [Parameter] public EventCallback OnZoomOut { get; set; }
    [Parameter] public EventCallback OnResetView { get; set; }
    [Parameter] public EventCallback OnToggleFullscreen { get; set; }
    [Parameter] public EventCallback OnToggleAuthorPlacement { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
}
