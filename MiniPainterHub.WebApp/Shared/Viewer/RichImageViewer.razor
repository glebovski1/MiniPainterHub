@using System.Globalization
@using System.Threading
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@using MiniPainterHub.Common.DTOs
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject MiniPainterHub.WebApp.Services.Interfaces.IAuthorMarkService AuthorMarkService

@if (IsOpen && Viewer.Images.Count == 0)
{
    <section class="viewer-empty" data-testid="viewer-empty">
        <div class="viewer-empty__icon"><i class="bi bi-image" aria-hidden="true"></i></div>
        <h3 class="viewer-empty__title">No images available</h3>
        <p class="viewer-empty__text">This post does not have any images to inspect yet.</p>
    </section>
}
else if (IsOpen)
{
    <div class="viewer-modal" data-testid="rich-image-viewer-modal">
        <button type="button"
                class="viewer-modal__backdrop"
                aria-label="Close viewer"
                data-testid="viewer-backdrop"
                @onclick="CloseAsync"></button>

        <section class="@ViewerShellClass"
                 data-testid="rich-image-viewer"
                 role="dialog"
                 aria-modal="true"
                 aria-labelledby="@TitleId"
                 @ref="_rootElement"
                 tabindex="-1"
                 @onkeydown="HandleModalKeyDown">
            <div class="viewer-shell__backdrop"></div>
            <div class="viewer-shell__wash"></div>

            <div class="viewer-shell__content">
                <div class="viewer-shell__body">
                    <div class="viewer-shell__stage-column">
                        @if (!string.IsNullOrWhiteSpace(CurrentInteractionHint))
                        {
                            <div class="viewer-banner" role="status" aria-live="polite" data-testid="viewer-banner">
                                <i class="bi bi-stars" aria-hidden="true"></i>
                                <span>@CurrentInteractionHint</span>
                            </div>
                        }

                        <div class="viewer-shell__stage-surface @StageControlsClass"
                             @onpointermove="RevealStageControlsTemporarilyAsync">
                            <div class="viewer-shell__stage-chrome">
                                @if (Viewer.Images.Count > 1)
                                {
                                    <button type="button"
                                            class="viewer-shell__stage-nav-button viewer-shell__stage-nav-button--previous"
                                            aria-label="Previous image"
                                            title="Previous image"
                                            data-testid="viewer-stage-prev"
                                            @onclick="PreviousImageAsync">
                                        <i class="bi bi-chevron-left" aria-hidden="true"></i>
                                    </button>

                                    <button type="button"
                                            class="viewer-shell__stage-nav-button viewer-shell__stage-nav-button--next"
                                            aria-label="Next image"
                                            title="Next image"
                                            data-testid="viewer-stage-next"
                                            @onclick="NextImageAsync">
                                        <i class="bi bi-chevron-right" aria-hidden="true"></i>
                                    </button>
                                }

                                <ViewerToolbar Eyebrow="@Eyebrow"
                                               Title="@Title"
                                               TitleId="@TitleId"
                                               CurrentIndex="@CurrentImageNumber"
                                               TotalCount="@Viewer.Images.Count"
                                               ZoomPercent="@ZoomPercent"
                                               ScaleMode="@_transform.ScaleMode"
                                               ScaleModeDescription="@ScaleModeDescription"
                                               CanGoPrevious="@(Viewer.Images.Count > 1)"
                                               CanGoNext="@(Viewer.Images.Count > 1)"
                                               CanAddAuthorMark="@Viewer.CanManageAuthorMarks"
                                               IsAuthorPlacementMode="@_isAuthorPlacementMode"
                                               CanToggleFullscreen="@ViewerInterop.IsFullscreenSupported"
                                               IsFullscreen="@ViewerInterop.IsFullscreen"
                                               OnPrevious="PreviousImageAsync"
                                               OnNext="NextImageAsync"
                                               OnZoomIn="ZoomInAsync"
                                               OnZoomOut="ZoomOutAsync"
                                               OnSetFitMode="SetFitModeAsync"
                                               OnSetFillMode="SetFillModeAsync"
                                               OnSetActualSizeMode="SetActualSizeModeAsync"
                                               OnToggleFullscreen="ToggleFullscreenAsync"
                                               OnToggleAuthorPlacement="ToggleAuthorPlacementAsync"
                                               OnClose="CloseAsync" />
                            </div>

                            <ViewerStage @ref="_viewerStage"
                                         StageClass="@StageClass"
                                         Style="@StageStyle"
                                         OnPointerDown="HandlePointerDown"
                                         OnPointerUp="HandlePointerUpAsync"
                                         OnPointerLeave="HandlePointerLeave"
                                         OnTouchStart="HandleTouchStart"
                                         OnTouchEnd="HandleTouchEndAsync"
                                         OnClick="HandleStageClickAsync"
                                         OnKeyDown="HandleKeyDown">
                                <div class="viewer-stage__viewport" data-testid="viewer-stage-viewport">
                                    @if (CurrentImage is not null)
                                    {
                                        <div class="viewer-stage__frame">
                                            @if (!CurrentImageFailed)
                                            {
                                                <div class="viewer-stage__fitbox" data-testid="viewer-stage-fitbox" style="@FitBoxStyle">
                                                    <div class="viewer-stage__transform @(CurrentImageReady ? "is-ready" : null)"
                                                         data-testid="viewer-stage-transform"
                                                         @ref="_transformElement"
                                                         style="@TransformStyle">
                                                        <img class="viewer-stage__image"
                                                             src="@CurrentImageSource"
                                                             data-testid="viewer-stage-image"
                                                             alt="@($"Artwork image {CurrentImageNumber}")"
                                                             draggable="false"
                                                             @ref="_imageElement"
                                                             @onload="@(() => OnImageLoaded(CurrentImage.Id))"
                                                             @onerror="@(() => OnImageFailed(CurrentImage.Id))" />

                                                        @if (CurrentImageReady)
                                                        {
                                                            <ViewerOverlay AuthorMarks="@VisibleAuthorMarks"
                                                                           SelectedAuthorMarkId="@_selectedAuthorMarkId"
                                                                           ActiveCommentMark="@VisibleCommentMark"
                                                                           DraftCommentMark="@VisibleDraftCommentMark"
                                                                           OnAuthorMarkSelected="HandleAuthorMarkSelectedAsync" />
                                                        }
                                                    </div>

                                                    @if (CurrentImageLoading)
                                                    {
                                                        <ViewerSkeleton />
                                                    }
                                                </div>
                                            }

                                            @if (CurrentImageFailed)
                                            {
                                                <div class="viewer-stage__status viewer-stage__status--error" role="alert" data-testid="viewer-image-error">
                                                    <div class="viewer-stage__status-icon"><i class="bi bi-exclamation-octagon" aria-hidden="true"></i></div>
                                                    <div>
                                                        <div class="viewer-stage__status-title">Image failed to load</div>
                                                        <p class="viewer-stage__status-text mb-0">Retry the image or switch to another thumbnail.</p>
                                                    </div>
                                                    <button type="button" class="btn btn-sm btn-outline-light" @onclick="RetryCurrentImageAsync">Retry</button>
                                                </div>
                                            }
                                            @if (ShowComposer)
                                            {
                                                <MarkComposer Title="@ComposerTitle"
                                                              Subtitle="@ComposerSubtitle"
                                                              Style="@ComposerStyle"
                                                              IsReadOnly="@ComposerIsReadOnly"
                                                              IsBusy="@_authorMarkBusy"
                                                              CanDelete="@CanDeleteSelectedAuthorMark"
                                                              SaveLabel="Save note"
                                                              Error="@_authorMarkError"
                                                              Value="@_composerValue"
                                                              OnSave="SaveAuthorMarkAsync"
                                                              OnDelete="DeleteAuthorMarkAsync"
                                                              OnCancel="DismissComposerAsync" />
                                            }
                                        </div>
                                    }
                                </div>
                            </ViewerStage>
                        </div>

                        @if (Viewer.Images.Count > 0)
                        {
                            <section class="viewer-shell__filmstrip viewer-rail-section viewer-rail-section--thumbnails" data-testid="viewer-thumbnail-rail">
                                <div class="viewer-rail-section__head">
                                    <span class="viewer-rail-section__eyebrow">@(Viewer.Images.Count > 1 ? "Frames" : "Preview")</span>
                                </div>

                                <ThumbnailRail Images="@Viewer.Images"
                                               ActiveImageId="@ResolvedImageId"
                                               OnSelect="SelectImageAsync" />

                                @if (Viewer.Images.Count > 1)
                                {
                                    <p class="viewer-rail-shortcuts" data-testid="viewer-shortcuts" aria-label="Viewer shortcuts">
                                        <span><kbd>Left</kbd><kbd>Right</kbd> navigate</span>
                                        <span><kbd>+</kbd><kbd>-</kbd> zoom</span>
                                        <span><kbd>Esc</kbd> close</span>
                                    </p>
                                }
                            </section>
                        }
                    </div>

                    <aside class="viewer-shell__side-panel" data-testid="viewer-side-panel" @ref="_sidePanelElement">
                        @if (SidePanelContent is not null)
                        {
                            @SidePanelContent
                        }
                    </aside>
                </div>
            </div>
        </section>
    </div>
}
