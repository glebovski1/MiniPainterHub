@using System.Net
@using MiniPainterHub.Common.DTOs
@using MiniPainterHub.WebApp.Services
@inject ICommentService CommentService

@if (!string.IsNullOrEmpty(_submitError))
{
    <div class="status-panel status-panel--warning mb-3" role="alert" data-testid="comment-error">
        <div class="status-panel__icon"><i class="bi bi-exclamation-triangle-fill" aria-hidden="true"></i></div>
        <div>
            <div class="status-panel__title">Couldn’t post comment</div>
            <p class="status-panel__text mb-0">
                @_submitError
                @if (_submitStatus.HasValue)
                {
                    <span class="small">(Status: @((int)_submitStatus.Value))</span>
                }
            </p>
        </div>
    </div>
}

<form class="@FormClass" @onsubmit="HandleSubmit" @onsubmit:preventDefault="true">
    @if (!string.IsNullOrWhiteSpace(_validationError))
    {
        <div class="text-danger small mb-0" role="alert" data-testid="comment-validation">
            @_validationError
        </div>
    }

    <textarea value="@_model.Text"
              @onchange="HandleTextChanged"
              class="form-control"
              placeholder="Write your comment..."
              data-testid="comment-input"
              rows="@(IsViewerCompact ? 2 : 3)"></textarea>

    @if (IsViewerCompact)
    {
        <div class="comment-form__actions comment-form__actions--viewer" data-testid="comment-actions">
            @if (CanAttachViewerMark)
            {
                <div class="comment-form__mark-controls d-flex flex-wrap align-items-center gap-2" data-testid="comment-mark-controls">
                    <button type="button"
                            class="btn btn-outline-light btn-sm"
                            data-testid="comment-attach-mark"
                            disabled="@(_isSubmitting || ViewerPlacementActive)"
                            @onclick="RequestAttachMarkAsync">
                        @(ViewerPlacementActive ? "Place mark" : DraftMark is null ? "Attach mark" : "Move mark")
                    </button>

                    @if (DraftMark is not null)
                    {
                        <span class="badge text-bg-light border" data-testid="comment-mark-chip">
                            Image @AttachedImageNumber point
                        </span>

                        <button type="button"
                                class="btn btn-link btn-sm p-0"
                                data-testid="comment-remove-mark"
                                disabled="@_isSubmitting"
                                @onclick="RemoveAttachedMarkAsync">
                            Remove
                        </button>
                    }
                </div>
            }

            <button type="submit"
                    class="btn btn-primary btn-sm"
                    data-testid="comment-submit"
                    disabled="@_isSubmitting">
                @(_isSubmitting ? "Posting..." : "Post")
            </button>
        </div>
    }
    else
    {
        <div class="comment-form__actions comment-form__actions--page" data-testid="comment-actions">
            @if (CanAttachViewerMark)
            {
                <div class="comment-form__mark-controls d-flex flex-wrap align-items-center gap-2" data-testid="comment-mark-controls">
                    <button type="button"
                            class="btn btn-outline-secondary"
                            data-testid="comment-attach-mark"
                            disabled="@(_isSubmitting || ViewerPlacementActive)"
                            @onclick="RequestAttachMarkAsync">
                        @(ViewerPlacementActive ? "Place mark" : DraftMark is null ? "Attach point" : "Reposition point")
                    </button>

                    @if (DraftMark is not null)
                    {
                        <span class="badge text-bg-light border" data-testid="comment-mark-chip">
                            Image @AttachedImageNumber point
                        </span>

                        <button type="button"
                                class="btn btn-link btn-sm p-0"
                                data-testid="comment-remove-mark"
                                disabled="@_isSubmitting"
                                @onclick="RemoveAttachedMarkAsync">
                            Remove
                        </button>
                    }
                </div>
            }

            <button type="submit"
                    class="btn btn-primary"
                    data-testid="comment-submit"
                    disabled="@_isSubmitting">
                @(_isSubmitting ? "Posting..." : "Post Comment")
            </button>
        </div>
    }
</form>

@code {
    [Parameter]
    public int PostId { get; set; }

    [Parameter]
    public EventCallback<CommentDto> OnCommentAdded { get; set; }

    [Parameter]
    public bool CanAttachViewerMark { get; set; }

    [Parameter]
    public bool ViewerPlacementActive { get; set; }

    [Parameter]
    public ViewerMarkDraftDto? DraftMark { get; set; }

    [Parameter]
    public int? AttachedImageNumber { get; set; }

    [Parameter]
    public EventCallback OnRequestAttachMark { get; set; }

    [Parameter]
    public EventCallback OnRemoveAttachedMark { get; set; }

    [Parameter]
    public bool IsViewerCompact { get; set; }

    private string FormClass => IsViewerCompact ? "form-grid form-grid--compact" : "form-grid";

    private CreateCommentDto _model = new();
    private bool _isSubmitting;
    private string? _submitError;
    private string? _validationError;
    private HttpStatusCode? _submitStatus;

    private void HandleTextChanged(ChangeEventArgs args)
    {
        _model.Text = args.Value?.ToString() ?? string.Empty;
        _validationError = null;
    }

    private async Task HandleSubmit()
    {
        _submitError = null;
        _submitStatus = null;
        _validationError = null;

        if (string.IsNullOrWhiteSpace(_model.Text))
        {
            _validationError = "Add a comment before posting.";
            return;
        }

        _isSubmitting = true;
        _model.PostId = PostId;
        _model.Mark = DraftMark;

        var response = await CommentService.CreateAsync(PostId, _model);

        if (response.Success && response.Value is not null)
        {
            _model.Text = string.Empty;
            _model.Mark = null;

            if (OnCommentAdded.HasDelegate)
            {
                await OnCommentAdded.InvokeAsync(response.Value);
            }
        }
        else
        {
            _submitStatus = response.StatusCode;
            _submitError = response.StatusCode == HttpStatusCode.Unauthorized
                ? "Please sign in to add a comment."
                : "We couldn't post your comment. Please try again.";
        }

        _isSubmitting = false;
    }

    private Task RequestAttachMarkAsync() =>
        OnRequestAttachMark.HasDelegate ? OnRequestAttachMark.InvokeAsync() : Task.CompletedTask;

    private Task RemoveAttachedMarkAsync() =>
        OnRemoveAttachedMark.HasDelegate ? OnRemoveAttachedMark.InvokeAsync() : Task.CompletedTask;
}
