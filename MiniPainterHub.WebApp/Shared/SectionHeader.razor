<div class="@CssClass" data-export-section="@SectionName">
    <div>
        @if (!string.IsNullOrWhiteSpace(Eyebrow))
        {
            <p class="section-label">@Eyebrow</p>
        }

        @RenderTitle()

        @if (!string.IsNullOrWhiteSpace(Description))
        {
            <p class="section-heading__subtitle">@Description</p>
        }
    </div>

    @if (Actions is not null)
    {
        <div class="section-heading__actions">
            @Actions
        </div>
    }
</div>

@code {
    [Parameter] public string Eyebrow { get; set; } = string.Empty;
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string? Description { get; set; }
    [Parameter] public string TitleTag { get; set; } = "h2";
    [Parameter] public string TitleClass { get; set; } = "section-heading__title";
    [Parameter] public string? ClassName { get; set; }
    [Parameter] public string? SectionName { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }

    private string CssClass => string.IsNullOrWhiteSpace(ClassName)
        ? "section-heading"
        : $"section-heading {ClassName}";

    private RenderFragment RenderTitle() => builder =>
    {
        builder.OpenElement(0, TitleTag);
        builder.AddAttribute(1, "class", TitleClass);
        builder.AddContent(2, Title);
        builder.CloseElement();
    };
}
