@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Routing
@inject IAuthService AuthService
@inject NavigationManager Nav
@inject UserPanelState UserPanel
@inject IJSRuntime JS

<nav class="navbar navbar-expand-lg atelier-nav">
    <div class="atelier-nav__bar">
        <NavLink class="navbar-brand atelier-brand" href="/" @onclick="CloseNavigationAsync">
            <img class="atelier-brand__mark" src="brand/roll-and-paint-mark.svg" alt="" data-testid="brand-mark" />
            <span class="atelier-brand__title">Roll &amp; Paint</span>
        </NavLink>

        <div class="atelier-nav__actions">
            <AuthorizeView>
                <Authorized>
                    <button type="button"
                            class="btn btn-sm btn-outline-secondary atelier-nav__utility d-none d-lg-inline-flex"
                            @onclick="ToggleDesktopPanel"
                            aria-label="Toggle desktop panel"
                            aria-pressed="@UserPanel.IsDesktopCollapsed">
                        <i class="bi @(UserPanel.IsDesktopCollapsed ? "bi-layout-sidebar-inset-reverse" : "bi-layout-sidebar-inset")" aria-hidden="true"></i>
                        <span>@(UserPanel.IsDesktopCollapsed ? "Show panel" : "Hide panel")</span>
                    </button>

                    <button type="button"
                            class="btn btn-sm btn-outline-secondary atelier-nav__utility d-inline-flex d-lg-none"
                            data-bs-toggle="offcanvas"
                            data-bs-target="#userPanelOffcanvas"
                            aria-controls="userPanelOffcanvas"
                            aria-label="Toggle personal panel">
                        <i class="bi bi-person-badge" aria-hidden="true"></i>
                        <span>Studio hub</span>
                    </button>
                </Authorized>
            </AuthorizeView>

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarNav"
                    data-testid="nav-toggle"
                    aria-controls="navbarNav"
                    aria-expanded="false"
                    aria-label="Toggle navigation">
                <span class="navbar-toggler-icon atelier-nav__toggle-icon" aria-hidden="true"></span>
            </button>
        </div>
    </div>

    <div class="collapse navbar-collapse atelier-nav__collapse align-items-center" id="navbarNav">
        <NavLink class="atelier-nav__search-link"
                 href="/search"
                 data-testid="nav-search-link"
                 @onclick="CloseNavigationAsync">
            <i class="bi bi-search" aria-hidden="true"></i>
            <span>Search</span>
        </NavLink>

        <ul class="navbar-nav atelier-nav__links mb-2 mb-xl-0">
            <li class="nav-item">
                <NavLink class="nav-link atelier-nav__link" href="/" Match="NavLinkMatch.All" @onclick="CloseNavigationAsync">
                    <i class="bi bi-clock-history" aria-hidden="true"></i>
                    <span>Latest</span>
                </NavLink>
            </li>
            <li class="nav-item">
                <NavLink class="nav-link atelier-nav__link" href="/posts/all" @onclick="CloseNavigationAsync">
                    <i class="bi bi-grid-1x2" aria-hidden="true"></i>
                    <span>Explore</span>
                </NavLink>
            </li>
            <li class="nav-item">
                <NavLink class="nav-link atelier-nav__link" href="/projects" data-testid="nav-projects" @onclick="CloseNavigationAsync">
                    <i class="bi bi-images" aria-hidden="true"></i>
                    <span>Projects</span>
                </NavLink>
            </li>
            <li class="nav-item">
                <NavLink class="nav-link atelier-nav__link" href="/guides" @onclick="CloseNavigationAsync">
                    <i class="bi bi-journal-text" aria-hidden="true"></i>
                    <span>Guides</span>
                </NavLink>
            </li>
            <li class="nav-item">
                <NavLink class="nav-link atelier-nav__link" href="/news" @onclick="CloseNavigationAsync">
                    <i class="bi bi-megaphone" aria-hidden="true"></i>
                    <span>News</span>
                </NavLink>
            </li>
            <li class="nav-item dropdown atelier-nav__more-menu">
                <button class="nav-link atelier-nav__link atelier-nav__more dropdown-toggle"
                        type="button"
                        id="navMoreMenu"
                        data-bs-toggle="dropdown"
                        data-testid="nav-more"
                        aria-expanded="false">
                    <i class="bi bi-three-dots" aria-hidden="true"></i>
                    <span>More</span>
                </button>
                <ul class="dropdown-menu dropdown-menu-end atelier-nav__dropdown" aria-labelledby="navMoreMenu">
                    <li>
                        <NavLink class="dropdown-item atelier-nav__dropdown-item"
                                 href="/posts/top"
                                 data-testid="nav-more-top-posts"
                                 @onclick="CloseNavigationAsync">
                            <i class="bi bi-trophy" aria-hidden="true"></i>
                            <span>Top posts</span>
                        </NavLink>
                    </li>
                    <li>
                        <NavLink class="dropdown-item atelier-nav__dropdown-item"
                                 href="/home"
                                 data-testid="nav-more-highlights"
                                 @onclick="CloseNavigationAsync">
                            <i class="bi bi-stars" aria-hidden="true"></i>
                            <span>Highlights</span>
                        </NavLink>
                    </li>
                    <li>
                        <NavLink class="dropdown-item atelier-nav__dropdown-item"
                                 href="/about"
                                 data-testid="nav-more-about"
                                 @onclick="CloseNavigationAsync">
                            <i class="bi bi-info-circle" aria-hidden="true"></i>
                            <span>About</span>
                        </NavLink>
                    </li>
                    <li>
                        <NavLink class="dropdown-item atelier-nav__dropdown-item"
                                 href="/privacy"
                                 data-testid="nav-more-privacy"
                                 @onclick="CloseNavigationAsync">
                            <i class="bi bi-shield-check" aria-hidden="true"></i>
                            <span>Privacy</span>
                        </NavLink>
                    </li>
                    <li>
                        <NavLink class="dropdown-item atelier-nav__dropdown-item"
                                 href="/terms"
                                 data-testid="nav-more-terms"
                                 @onclick="CloseNavigationAsync">
                            <i class="bi bi-file-earmark-text" aria-hidden="true"></i>
                            <span>Terms</span>
                        </NavLink>
                    </li>
                </ul>
            </li>
        </ul>

        <ul class="navbar-nav atelier-nav__session ms-auto mb-2 mb-xl-0">
            <AuthorizeView>
                <Authorized>
                    <li class="nav-item">
                        <button type="button" class="btn btn-link nav-link atelier-nav__logout" data-testid="nav-logout" @onclick="Logout">
                            <i class="bi bi-box-arrow-right" aria-hidden="true"></i>
                            <span>Logout</span>
                        </button>
                    </li>
                </Authorized>
                <NotAuthorized>
                    <li class="nav-item">
                        <NavLink class="nav-link atelier-nav__link" href="/login" data-testid="nav-login" @onclick="CloseNavigationAsync">
                            <i class="bi bi-box-arrow-in-right" aria-hidden="true"></i>
                            <span>Login</span>
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link atelier-nav__link atelier-nav__register" href="/register" @onclick="CloseNavigationAsync">
                            <i class="bi bi-person-plus" aria-hidden="true"></i>
                            <span>Register</span>
                        </NavLink>
                    </li>
                </NotAuthorized>
            </AuthorizeView>
        </ul>
    </div>
</nav>

@code {
    private void ToggleDesktopPanel()
    {
        UserPanel.ToggleDesktopCollapsed();
    }

    private async Task CloseNavigationAsync()
    {
        await JS.InvokeVoidAsync("miniPainterHubNavigation.closeMobileNavigation", "navbarNav");
    }

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        await CloseNavigationAsync();
        Nav.NavigateTo("/login");
    }
}
