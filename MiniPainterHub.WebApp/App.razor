@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.AspNetCore.Components.WebAssembly.Services
@using System.Reflection
@inject LazyAssemblyLoader AssemblyLoader

<ClientPerformanceReporter />

<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(App).Assembly"
            AdditionalAssemblies="@_lazyLoadedAssemblies"
            OnNavigateAsync="OnNavigateAsync">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                <Authorizing>
                    <LayoutView Layout="@typeof(MainLayout)">
                        <div class="page-shell">
                            <div class="status-panel status-panel--info mt-4" data-testid="route-authorizing">
                                <div class="status-panel__icon">
                                    <i class="bi bi-hourglass-split" aria-hidden="true"></i>
                                </div>
                                <div>
                                    <div class="status-panel__title">Checking access</div>
                                    <p class="status-panel__text mb-0">Preparing your studio view...</p>
                                </div>
                            </div>
                        </div>
                    </LayoutView>
                </Authorizing>
                <NotAuthorized>
                    <RedirectToLogin />
                </NotAuthorized>
            </AuthorizeRouteView>
        </Found>
        <NotFound>
            <LayoutView Layout="@typeof(MainLayout)">
                <div class="page-shell">
                    <EmptyState IconClass="bi bi-compass"
                                Title="Page not found"
                                Description="The trail ran cold. Head back to the community feed and keep exploring."
                                ClassName="mt-4" />
                </div>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>

@code {
    private static readonly string[] MessagingAssemblyNames =
    [
        "Microsoft.AspNetCore.Connections.Abstractions.wasm",
        "Microsoft.AspNetCore.Http.Connections.Client.wasm",
        "Microsoft.AspNetCore.Http.Connections.Common.wasm",
        "Microsoft.AspNetCore.SignalR.Client.wasm",
        "Microsoft.AspNetCore.SignalR.Client.Core.wasm",
        "Microsoft.AspNetCore.SignalR.Common.wasm",
        "Microsoft.AspNetCore.SignalR.Protocols.Json.wasm",
        "System.IO.Pipelines.wasm",
        "System.Net.WebSockets.wasm",
        "System.Net.WebSockets.Client.wasm",
        "System.Threading.Channels.wasm"
    ];

    private static readonly string[] FormAssemblyNames =
    [
        "Microsoft.AspNetCore.Components.Forms.wasm",
        "System.ComponentModel.Primitives.wasm",
        "System.ComponentModel.TypeConverter.wasm",
        "System.Linq.Expressions.wasm"
    ];

    private readonly List<Assembly> _lazyLoadedAssemblies = new();
    private bool _messagingAssembliesLoaded;
    private bool _formAssembliesLoaded;

    private async Task OnNavigateAsync(NavigationContext args)
    {
        if (!_formAssembliesLoaded && RequiresFormsAndValidation(args.Path))
        {
            var formAssemblies = await AssemblyLoader.LoadAssembliesAsync(FormAssemblyNames);
            args.CancellationToken.ThrowIfCancellationRequested();

            _lazyLoadedAssemblies.AddRange(formAssemblies);
            _formAssembliesLoaded = true;
        }

        if (_messagingAssembliesLoaded || !args.Path.StartsWith("messages", StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        var assemblies = await AssemblyLoader.LoadAssembliesAsync(MessagingAssemblyNames);
        args.CancellationToken.ThrowIfCancellationRequested();

        _lazyLoadedAssemblies.AddRange(assemblies);
        _messagingAssembliesLoaded = true;
    }

    private static bool RequiresFormsAndValidation(string path) =>
        path.Equals("login", StringComparison.OrdinalIgnoreCase)
        || path.Equals("register", StringComparison.OrdinalIgnoreCase)
        || path.Equals("profile", StringComparison.OrdinalIgnoreCase)
        || path.Equals("posts/new", StringComparison.OrdinalIgnoreCase)
        || path.StartsWith("messages", StringComparison.OrdinalIgnoreCase);
}
