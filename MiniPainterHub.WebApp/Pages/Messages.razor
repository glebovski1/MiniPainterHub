@page "/messages"
@page "/messages/{ConversationId:int}"
@attribute [Authorize]
@implements IDisposable
@using MiniPainterHub.Common.DTOs
@inject IConversationService Conversations
@inject NavigationManager Nav

<PageTitle>Messages</PageTitle>

<div class="page-shell content-stack">
    <PageHero Eyebrow="Direct messages"
              Title="Messages"
              Description="Keep hobby chats flowing with a clearer inbox, stronger thread separation, and a calmer reading layout."
              FrameName="Messages Header" />

    <div class="message-layout">
        <section class="surface-card @(ConversationId.HasValue ? "d-none d-lg-block" : string.Empty)">
            <SectionHeader Eyebrow="Inbox"
                           Title="Conversations"
                           Description="Recent painter-to-painter threads."
                           TitleTag="h2"
                           TitleClass="section-heading__title h3 mb-0"
                           SectionName="Conversations">
                <Actions>
                    @if (_loadingConversations)
                    {
                        <div class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></div>
                    }
                </Actions>
            </SectionHeader>

            @if (!string.IsNullOrWhiteSpace(_conversationError))
            {
                <div class="status-panel status-panel--error" role="alert" data-testid="messages-conversation-error">
                    <div class="status-panel__icon"><i class="bi bi-exclamation-octagon" aria-hidden="true"></i></div>
                    <div>
                        <div class="status-panel__title">Couldn't load conversations</div>
                        <p class="status-panel__text mb-0">@_conversationError</p>
                    </div>
                    <button type="button" class="btn btn-link btn-sm ms-auto" @onclick="ReloadConversationsAsync">Retry</button>
                </div>
            }
            else if (_conversations.Count == 0 && !_loadingConversations)
            {
                <EmptyState IconClass="bi bi-chat-square"
                            Title="No conversations yet"
                            Description="Open a profile and send the first message."
                            TitleTag="h3"
                            TitleClass="empty-state__title h5"
                            ClassName="empty-state empty-state--compact">
                    <div class="d-flex flex-wrap justify-content-center gap-2 mt-2">
                        <NavLink class="btn btn-primary btn-sm" href="/posts/all">
                            <i class="bi bi-grid-1x2" aria-hidden="true"></i>
                            <span>Browse painters</span>
                        </NavLink>
                        <NavLink class="btn btn-outline-secondary btn-sm" href="/connections">
                            <i class="bi bi-diagram-3" aria-hidden="true"></i>
                            <span>View connections</span>
                        </NavLink>
                    </div>
                </EmptyState>
            }
            else
            {
                <div class="list-group list-group-flush">
                    @foreach (var conversation in _conversations)
                    {
                        <button type="button"
                                class="list-group-item list-group-item-action text-start @(ConversationId == conversation.Id ? "active" : string.Empty)"
                                @onclick="@(() => OpenConversation(conversation.Id))">
                            <div class="d-flex justify-content-between align-items-start gap-2">
                                <div>
                                    <div class="fw-semibold">@conversation.OtherUser.DisplayName</div>
                                    <div class="small @(ConversationId == conversation.Id ? "text-white-50" : "text-muted")">
                                        @(string.IsNullOrWhiteSpace(conversation.LatestMessagePreview) ? "No messages yet." : conversation.LatestMessagePreview)
                                    </div>
                                </div>
                                @if (conversation.UnreadCount > 0)
                                {
                                    <span class="badge text-bg-primary">@conversation.UnreadCount</span>
                                }
                            </div>
                        </button>
                    }
                </div>
            }
        </section>

        <section class="surface-card">
            @if (!ConversationId.HasValue)
            {
                <EmptyState IconClass="bi bi-chat-right-text"
                            Title="Select a conversation"
                            Description="Open a profile and start messaging another painter."
                            TitleClass="empty-state__title h4">
                    <div class="d-flex flex-wrap justify-content-center gap-2 mt-2">
                        <NavLink class="btn btn-primary btn-sm" href="/posts/all">
                            <i class="bi bi-grid-1x2" aria-hidden="true"></i>
                            <span>Explore profiles</span>
                        </NavLink>
                        <NavLink class="btn btn-outline-secondary btn-sm" href="/connections">
                            <i class="bi bi-people" aria-hidden="true"></i>
                            <span>Open connections</span>
                        </NavLink>
                    </div>

                    <div class="message-empty-steps">
                        <div class="message-empty-steps__item">
                            <span class="message-empty-steps__number">1</span>
                            <span>Open a painter profile</span>
                        </div>
                        <div class="message-empty-steps__item">
                            <span class="message-empty-steps__number">2</span>
                            <span>Start a direct conversation</span>
                        </div>
                        <div class="message-empty-steps__item">
                            <span class="message-empty-steps__number">3</span>
                            <span>Reply here once the thread exists</span>
                        </div>
                    </div>
                </EmptyState>
            }
            else
            {
                <SectionHeader Eyebrow="Thread"
                               Title="@(_activeConversation?.OtherUser.DisplayName ?? "Conversation")"
                               Description="@(_activeConversation is not null ? "@" + _activeConversation.OtherUser.UserName : null)"
                               TitleTag="h2"
                               TitleClass="section-heading__title h3 mb-0"
                               SectionName="Message Thread">
                    <Actions>
                        <button type="button" class="btn btn-outline-secondary btn-sm d-lg-none" @onclick='() => Nav.NavigateTo("/messages")'>
                            Back
                        </button>
                    </Actions>
                </SectionHeader>

                <div class="message-thread">
                    @if (_loadingMessages)
                    {
                        <div class="status-panel status-panel--info">
                            <div class="status-panel__icon"><i class="bi bi-chat-left-dots" aria-hidden="true"></i></div>
                            <div>
                                <div class="status-panel__title">Loading messages</div>
                                <p class="status-panel__text mb-0">Pulling the latest thread updates.</p>
                            </div>
                        </div>
                    }
                    else if (!string.IsNullOrWhiteSpace(_threadError))
                    {
                        <div class="status-panel status-panel--error" role="alert" data-testid="messages-thread-error">
                            <div class="status-panel__icon"><i class="bi bi-exclamation-octagon" aria-hidden="true"></i></div>
                            <div>
                                <div class="status-panel__title">Couldn't load this thread</div>
                                <p class="status-panel__text mb-0">@_threadError</p>
                            </div>
                            <button type="button" class="btn btn-link btn-sm ms-auto" @onclick="LoadActiveConversationAsync">Retry</button>
                        </div>
                    }
                    else if (_messages.Count == 0)
                    {
                        <EmptyState IconClass="bi bi-pencil"
                                    Title="No messages yet"
                                    Description="Say hello and start the thread."
                                    TitleTag="h3"
                                    TitleClass="empty-state__title h5" />
                    }
                    else
                    {
                        @foreach (var message in _messages)
                        {
                            <div class="message-bubble @(message.IsMine ? "message-bubble--mine" : string.Empty)">
                                <div class="small fw-semibold mb-1">@message.SenderDisplayName</div>
                                <div>@message.Body</div>
                                <div class="message-bubble__meta mt-2">
                                    @message.SentUtc.ToLocalTime().ToString("MMM dd, HH:mm")
                                </div>
                            </div>
                        }
                    }
                </div>

                <EditForm Model="_draft" OnValidSubmit="SendAsync" class="mt-3">
                    <DataAnnotationsValidator />
                    @if (!string.IsNullOrWhiteSpace(_composerError))
                    {
                        <div class="status-panel status-panel--error mb-3" role="alert" data-testid="messages-send-error">
                            <div class="status-panel__icon"><i class="bi bi-exclamation-circle" aria-hidden="true"></i></div>
                            <div>
                                <div class="status-panel__title">Message not sent</div>
                                <p class="status-panel__text mb-0">@_composerError</p>
                            </div>
                        </div>
                    }
                    <div class="input-group">
                        <InputText class="form-control" @bind-Value="_draft.Body" placeholder="Write a message..." />
                        <button type="submit" class="btn btn-primary" disabled="@_sending">Send</button>
                    </div>
                </EditForm>
            }
        </section>
    </div>
</div>

@code {
    [Parameter] public int? ConversationId { get; set; }

    private IReadOnlyList<ConversationSummaryDto> _conversations = Array.Empty<ConversationSummaryDto>();
    private ConversationSummaryDto? _activeConversation;
    private readonly List<DirectMessageDto> _messages = new();
    private CreateDirectMessageDto _draft = new();
    private bool _loadingConversations = true;
    private bool _loadingMessages;
    private bool _sending;
    private int? _joinedConversationId;
    private string? _conversationError;
    private string? _threadError;
    private string? _composerError;

    protected override async Task OnInitializedAsync()
    {
        Conversations.OnChange += HandleConversationStateChanged;
        Conversations.MessageReceived += HandleMessageReceived;
        Conversations.ConversationRead += HandleConversationRead;

        await EnsureRealtimeBestEffortAsync();
        await ReloadConversationsAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        await ReloadConversationsAsync();
        await LoadActiveConversationAsync();
    }

    private async Task ReloadConversationsAsync()
    {
        _loadingConversations = true;
        _conversationError = null;
        try
        {
            _conversations = await Conversations.GetConversationsAsync(forceRefresh: true);
            _activeConversation = ConversationId.HasValue
                ? _conversations.FirstOrDefault(c => c.Id == ConversationId.Value)
                : null;
        }
        catch
        {
            _conversations = Array.Empty<ConversationSummaryDto>();
            _activeConversation = null;
            _conversationError = "We couldn't refresh your inbox. Please try again.";
        }
        finally
        {
            _loadingConversations = false;
        }
    }

    private async Task LoadActiveConversationAsync()
    {
        _threadError = null;
        if (!ConversationId.HasValue)
        {
            if (_joinedConversationId.HasValue)
            {
                await LeaveConversationBestEffortAsync(_joinedConversationId.Value);

                _joinedConversationId = null;
            }

            _messages.Clear();
            return;
        }

        _loadingMessages = true;
        try
        {
            if (_joinedConversationId.HasValue && _joinedConversationId.Value != ConversationId.Value)
            {
                await LeaveConversationBestEffortAsync(_joinedConversationId.Value);
            }

            _joinedConversationId = ConversationId.Value;
            await JoinConversationBestEffortAsync(ConversationId.Value);

            var page = await Conversations.GetMessagesAsync(ConversationId.Value);
            _messages.Clear();
            _messages.AddRange(page.Items);
            await Conversations.MarkReadAsync(ConversationId.Value);

            _activeConversation = _conversations.FirstOrDefault(c => c.Id == ConversationId.Value);
        }
        catch
        {
            _messages.Clear();
            _threadError = "We couldn't load this conversation. Please try again.";
        }
        finally
        {
            _loadingMessages = false;
        }
    }

    private void OpenConversation(int conversationId)
        => Nav.NavigateTo($"/messages/{conversationId}");

    private async Task SendAsync()
    {
        if (!ConversationId.HasValue || string.IsNullOrWhiteSpace(_draft.Body))
        {
            return;
        }

        _sending = true;
        _composerError = null;
        try
        {
            var message = await Conversations.SendMessageAsync(ConversationId.Value, _draft);
            if (_messages.All(existing => existing.Id != message.Id))
            {
                _messages.Add(message);
            }

            _draft = new CreateDirectMessageDto();
            await Conversations.MarkReadAsync(ConversationId.Value);
        }
        catch
        {
            _composerError = "We couldn't send your message. Please try again.";
        }
        finally
        {
            _sending = false;
        }
    }

    private void HandleConversationStateChanged()
    {
        _ = InvokeAsync(async () =>
        {
            try
            {
                _conversations = await Conversations.GetConversationsAsync();
                _activeConversation = ConversationId.HasValue
                    ? _conversations.FirstOrDefault(c => c.Id == ConversationId.Value)
                    : null;
                _conversationError = null;
            }
            catch
            {
                _conversationError = "We couldn't refresh your inbox. Please try again.";
            }

            StateHasChanged();
        });
    }

    private void HandleMessageReceived(DirectMessageDto message)
    {
        if (!ConversationId.HasValue || message.ConversationId != ConversationId.Value)
        {
            return;
        }

        _ = InvokeAsync(async () =>
        {
            try
            {
                if (_messages.All(existing => existing.Id != message.Id))
                {
                    _messages.Add(message);
                }

                await Conversations.MarkReadAsync(message.ConversationId);
                _threadError = null;
            }
            catch
            {
                _threadError = "We couldn't refresh the latest message. Please try again.";
            }

            StateHasChanged();
        });
    }

    private void HandleConversationRead(ConversationReadDto payload)
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task EnsureRealtimeBestEffortAsync()
    {
        try
        {
            await Conversations.EnsureRealtimeAsync();
        }
        catch
        {
            // Realtime should enhance the page, not block inbox or thread loading.
        }
    }

    private async Task JoinConversationBestEffortAsync(int conversationId)
    {
        try
        {
            await Conversations.JoinConversationAsync(conversationId);
        }
        catch
        {
            // Thread loading should still work even if the realtime channel is unavailable.
        }
    }

    private async Task LeaveConversationBestEffortAsync(int conversationId)
    {
        try
        {
            await Conversations.LeaveConversationAsync(conversationId);
        }
        catch
        {
            // Best effort during navigation and dispose cleanup.
        }
    }

    public void Dispose()
    {
        Conversations.OnChange -= HandleConversationStateChanged;
        Conversations.MessageReceived -= HandleMessageReceived;
        Conversations.ConversationRead -= HandleConversationRead;

        if (_joinedConversationId.HasValue)
        {
            _ = Conversations.LeaveConversationAsync(_joinedConversationId.Value);
        }
    }
}
