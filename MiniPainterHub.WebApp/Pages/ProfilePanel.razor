@using Microsoft.AspNetCore.Components.Forms
@using MiniPainterHub.Common.DTOs

<section class="surface-card profile-panel">
    <SectionHeader Eyebrow="@Title"
                   Title="@Title"
                   Description="Shape how other painters see you across the community."
                   SectionName="Profile Panel">
        <Actions>
            @if (IsOwner)
            {
                @if (!EditEnabled)
                {
                    <button class="btn btn-outline-primary btn-sm"
                            data-testid="profile-edit"
                            @onclick="BeginEdit"
                            disabled="@Busy">
                        <i class="bi bi-pencil-square" aria-hidden="true"></i>
                        <span>Edit</span>
                    </button>
                }
                else
                {
                    <div class="profile-panel__actions">
                        <button class="btn btn-primary btn-sm"
                                data-testid="profile-save"
                                @onclick="Save"
                                disabled="@Busy">
                            @if (Busy && BusyAction == "save")
                            {
                                <span class="spinner-border spinner-border-sm me-1" />
                            }
                            <span>Save</span>
                        </button>
                        <button class="btn btn-outline-secondary btn-sm"
                                data-testid="profile-cancel"
                                @onclick="Cancel"
                                disabled="@Busy">
                            <span>Cancel</span>
                        </button>
                    </div>
                }
            }
        </Actions>
    </SectionHeader>

    <div class="profile-panel__layout">
        <aside class="profile-panel__rail">
            <div class="profile-panel__rail-stack">
                <UserAvatar ImageUrl="@Profile?.AvatarUrl"
                            Name="@(_displayName ?? Profile?.UserName)"
                            Size="128"
                            ClassName="profile-panel__avatar" />

                <div class="profile-panel__identity">
                    <div class="profile-panel__name">@(_displayName ?? Profile?.DisplayName ?? Profile?.UserName)</div>
                    <div class="profile-panel__handle">@("@")@(Profile?.UserName ?? "painter")</div>
                </div>

                <div class="metric-grid metric-grid--profile">
                    <article class="metric-chip">
                        <span class="metric-chip__label">Followers</span>
                        <strong class="metric-chip__value">@Profile?.FollowerCount</strong>
                    </article>
                    <article class="metric-chip">
                        <span class="metric-chip__label">Following</span>
                        <strong class="metric-chip__value">@Profile?.FollowingCount</strong>
                    </article>
                </div>

                @if (IsOwner && EditEnabled)
                {
                    <div class="profile-panel__avatar-tools">
                        <InputFile OnChange="OnAvatarSelected"
                                   accept="image/*"
                                   data-testid="profile-avatar-input"
                                   class="form-control"
                                   disabled="@Busy" />
                        <div class="profile-panel__avatar-actions">
                            <button class="btn btn-outline-danger btn-sm"
                                    data-testid="profile-avatar-remove"
                                    @onclick="RemoveAvatar"
                                    disabled="@(!HasAvatar || Busy)">
                                @if (Busy && BusyAction == "remove-avatar")
                                {
                                    <span class="spinner-border spinner-border-sm me-1" />
                                }
                                <span>Remove avatar</span>
                            </button>
                        </div>
                        <div class="form-text text-center">
                            JPEG/PNG/WEBP, up to 5 MB.
                        </div>
                    </div>
                }
            </div>
        </aside>

        <div class="profile-panel__editor">
            <div class="form-grid profile-panel__form-grid">
                <div class="profile-panel__field">
                    <label class="form-label">Display name</label>
                    <input class="form-control"
                           data-testid="profile-display-name"
                           placeholder="e.g. Sam Painter"
                           @bind="_displayName"
                           disabled="@(!IsOwner || !EditEnabled || Busy)" />
                </div>

                <div class="profile-panel__field">
                    <label class="form-label">Bio</label>
                    <textarea class="form-control"
                              data-testid="profile-bio"
                              placeholder="A short bio..."
                              rows="6"
                              @bind="_bio"
                              disabled="@(!IsOwner || !EditEnabled || Busy)"></textarea>
                    <div class="form-text">Max 500 characters.</div>
                </div>
            </div>
        </div>
    </div>
</section>

@code {
    [Parameter] public string Title { get; set; } = "Profile";
    [Parameter] public UserProfileDto? Profile { get; set; }
    [Parameter] public bool IsOwner { get; set; }
    [Parameter] public bool EditEnabled { get; set; }
    [Parameter] public bool Busy { get; set; }
    [Parameter] public string BusyAction { get; set; } = string.Empty;

    [Parameter] public EventCallback OnBeginEdit { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public EventCallback<UpdateUserProfileDto> OnSave { get; set; }
    [Parameter] public EventCallback<IBrowserFile> OnUploadAvatar { get; set; }
    [Parameter] public EventCallback OnRemoveAvatar { get; set; }

    private string _displayName = string.Empty;
    private string? _bio;

    protected override void OnParametersSet()
    {
        _displayName = Profile?.DisplayName ?? "";
        _bio = Profile?.Bio;
    }

    private bool HasAvatar => !string.IsNullOrWhiteSpace(Profile?.AvatarUrl);

    private Task BeginEdit() => OnBeginEdit.InvokeAsync();
    private Task Cancel() => OnCancel.InvokeAsync();

    private async Task Save()
    {
        var dto = new UpdateUserProfileDto
        {
            DisplayName = _displayName,
            Bio = _bio ?? string.Empty
        };
        await OnSave.InvokeAsync(dto);
    }

    private async Task OnAvatarSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        await OnUploadAvatar.InvokeAsync(file);
    }

    private Task RemoveAvatar() => OnRemoveAvatar.InvokeAsync();
}
