@page "/profile"
@inject MiniPainterHub.WebApp.Services.Interfaces.IProfileService Profiles

<div class="page-shell content-stack">
    <PageHero Eyebrow="Your identity"
              Title="My Profile"
              Description="Adjust your public presentation without changing the underlying profile flow or save behavior."
              FrameName="Profile Header" />

    @if (_busyInit)
    {
        <div class="status-panel status-panel--info">
            <div class="status-panel__icon"><i class="bi bi-person-circle" aria-hidden="true"></i></div>
            <div>
                <div class="status-panel__title">Loading your profile</div>
                <p class="status-panel__text mb-0">Pulling in your current profile details.</p>
            </div>
        </div>
    }
    else if (_profile is null)
    {
        <section class="surface-card">
            <SectionHeader Eyebrow="Getting started"
                           Title="Create your profile"
                           Description="Add a name and short bio so other painters can find and follow you."
                           SectionName="Create Profile" />

            <EditForm Model="_create" OnValidSubmit="Create" class="form-grid">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger small mb-0" />

                <div>
                    <label class="form-label">Display name</label>
                    <InputText @bind-Value="_create.DisplayName" class="form-control" data-testid="profile-create-display-name" placeholder="e.g. Sam Painter" />
                    <ValidationMessage For="@(() => _create.DisplayName)" class="text-danger" />
                </div>

                <div>
                    <label class="form-label">Bio</label>
                    <InputTextArea @bind-Value="_create.Bio" class="form-control" data-testid="profile-create-bio" rows="5" placeholder="A short bio..." />
                    <div class="form-text">Max 500 characters.</div>
                    <ValidationMessage For="@(() => _create.Bio)" class="text-danger" />
                </div>

                <button class="btn btn-primary" type="submit" data-testid="profile-create-submit" disabled="@_busy">
                    @if (_busy)
                    {
                        <span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>
                    }
                    Create profile
                </button>
            </EditForm>
        </section>
    }
    else
    {
        <ProfilePanel Title="Profile"
                      Profile="_profile"
                      IsOwner="true"
                      EditEnabled="_editing"
                      Busy="_busy"
                      BusyAction="_busyAction"
                      OnBeginEdit="BeginEdit"
                      OnCancel="CancelEdit"
                      OnSave="Save"
                      OnUploadAvatar="UploadAvatar"
                      OnRemoveAvatar="RemoveAvatar" />

        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <div class="status-panel status-panel--error mt-3" role="alert">
                <div class="status-panel__icon"><i class="bi bi-exclamation-circle" aria-hidden="true"></i></div>
                <div>
                    <div class="status-panel__title">Profile update failed</div>
                    <p class="status-panel__text mb-0">@_error</p>
                </div>
            </div>
        }
    }
</div>

@code {
    private bool _busyInit = true;
    private bool _busy = false;
    private string _busyAction = string.Empty;
    private bool _editing = false;
    private string? _error;

    private UserProfileDto? _profile;
    private CreateUserProfileDto _create = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _profile = await Profiles.GetMineAsync();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busyInit = false; }
    }

    private async Task Create()
    {
        _error = null;
        _busy = true; _busyAction = "create";
        try
        {
            _profile = await Profiles.CreateMineAsync(_create);
            _editing = false;
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; _busyAction = string.Empty; }
    }

    private void BeginEdit() => _editing = true;
    private void CancelEdit() => _editing = false;

    private async Task Save(UpdateUserProfileDto dto)
    {
        _error = null;
        _busy = true; _busyAction = "save";
        try
        {
            _profile = await Profiles.UpdateMineAsync(dto);
            _editing = false;
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; _busyAction = string.Empty; }
    }

    private async Task UploadAvatar(IBrowserFile file)
    {
        if (!_editing) return;
        _error = null;
        _busy = true; _busyAction = "upload-avatar";
        try
        {
            _profile = await Profiles.UploadAvatarAsync(file);
            StateHasChanged();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; _busyAction = string.Empty; }
    }

    private async Task RemoveAvatar()
    {
        if (!_editing) return;
        _error = null;
        _busy = true; _busyAction = "remove-avatar";
        try
        {
            _profile = await Profiles.RemoveAvatarAsync();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; _busyAction = string.Empty; }
    }
}
