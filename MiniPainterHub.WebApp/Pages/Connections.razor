@page "/connections"
@attribute [Authorize]
@using MiniPainterHub.Common.DTOs
@inject IFollowService Follows

<PageTitle>Connections</PageTitle>

<div class="page-shell content-stack">
    <PageHero Eyebrow="Community ties"
              Title="Connections"
              Description="Track who follows your work, who you follow back, and where your conversations can deepen next."
              FrameName="Connections Header" />

    @if (_loading)
    {
        <div class="status-panel status-panel--info">
            <div class="status-panel__icon"><i class="bi bi-people" aria-hidden="true"></i></div>
            <div>
                <div class="status-panel__title">Loading connections</div>
                <p class="status-panel__text mb-0">Gathering your followers and followed painters...</p>
            </div>
        </div>
    }
    else
    {
        <div class="results-grid">
            <section class="surface-card">
                <SectionHeader Eyebrow="Followers"
                               Title="Followers"
                               Description="Painters who are following your work."
                               SectionName="Followers" />
                @RenderUsers(_followers, "No followers yet.")
            </section>

            <section class="surface-card">
                <SectionHeader Eyebrow="Following"
                               Title="Following"
                               Description="The creators you've chosen to keep up with."
                               SectionName="Following" />
                @RenderUsers(_following, "You are not following anyone yet.")
            </section>
        </div>
    }
</div>

@code {
    private IReadOnlyList<UserListItemDto> _followers = Array.Empty<UserListItemDto>();
    private IReadOnlyList<UserListItemDto> _following = Array.Empty<UserListItemDto>();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _followers = await Follows.GetFollowersAsync();
        _following = await Follows.GetFollowingAsync();
        _loading = false;
    }

    private RenderFragment RenderUsers(IReadOnlyList<UserListItemDto> users, string emptyText) => builder =>
    {
        if (users.Count == 0)
        {
            builder.OpenComponent<EmptyState>(0);
            builder.AddAttribute(1, "IconClass", "bi bi-person-plus");
            builder.AddAttribute(2, "Title", emptyText);
            builder.AddAttribute(3, "TitleTag", "h3");
            builder.AddAttribute(4, "TitleClass", "empty-state__title h5");
            builder.CloseComponent();
            return;
        }

        var seq = 10;
        builder.OpenElement(seq++, "div");
        builder.AddAttribute(seq++, "class", "entity-list");
        foreach (var user in users)
        {
            builder.OpenComponent<NavLink>(seq++);
            builder.AddAttribute(seq++, "class", "entity-row text-decoration-none");
            builder.AddAttribute(seq++, "href", $"/users/{user.UserId}");
            builder.AddAttribute(seq++, "ChildContent", (RenderFragment)(contentBuilder =>
            {
                var childSeq = 0;
                contentBuilder.OpenComponent<UserAvatar>(childSeq++);
                contentBuilder.AddAttribute(childSeq++, "ImageUrl", user.AvatarUrl);
                contentBuilder.AddAttribute(childSeq++, "Name", user.DisplayName);
                contentBuilder.AddAttribute(childSeq++, "Size", 56);
                contentBuilder.CloseComponent();

                contentBuilder.OpenElement(childSeq++, "div");
                contentBuilder.AddAttribute(childSeq++, "class", "entity-row__content");

                contentBuilder.OpenElement(childSeq++, "div");
                contentBuilder.AddAttribute(childSeq++, "class", "entity-row__title");
                contentBuilder.AddContent(childSeq++, user.DisplayName);
                contentBuilder.CloseElement();

                contentBuilder.OpenElement(childSeq++, "div");
                contentBuilder.AddAttribute(childSeq++, "class", "entity-row__meta");
                contentBuilder.AddContent(childSeq++, "@" + user.UserName);
                contentBuilder.CloseElement();

                contentBuilder.CloseElement();
            }));
            builder.CloseComponent();
        }

        builder.CloseElement();
    };
}
