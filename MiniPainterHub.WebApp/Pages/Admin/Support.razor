@page "/admin/support"
@attribute [Authorize(Roles = "Admin")]
@inject ISupportTicketService SupportTickets

<PageTitle>Admin Support</PageTitle>

<div class="page-shell content-stack admin-support-page">
    <section class="page-hero admin-tools-hero">
        <div class="content-stack">
            <div>
                <p class="page-hero__eyebrow">Admin tools</p>
                <h1 class="page-hero__title">Support queue</h1>
                <p class="page-hero__description">Read private support requests, reply as the admin team, and close conversations when the user has what they need.</p>
            </div>

            <div class="metric-grid">
                <div class="metric-chip">
                    <span class="metric-chip__label">Loaded</span>
                    <span class="metric-chip__value">@_tickets.Count</span>
                </div>
                <div class="metric-chip">
                    <span class="metric-chip__label">Awaiting admin</span>
                    <span class="metric-chip__value">@_tickets.Count(ticket => ticket.Status is SupportTicketStatuses.New or SupportTicketStatuses.WaitingForAdmin)</span>
                </div>
                <div class="metric-chip">
                    <span class="metric-chip__label">Page</span>
                    <span class="metric-chip__value">@_query.PageNumber / @_totalPages</span>
                </div>
            </div>
        </div>
    </section>

    <section class="admin-support-filters" aria-label="Support queue filters">
        <div>
            <label class="form-label" for="admin-support-status">Status</label>
            <select id="admin-support-status" class="form-select form-select-sm" data-testid="admin-support-status" @bind="_query.Status">
                <option value="">All</option>
                <option value="@SupportTicketStatuses.New">New</option>
                <option value="@SupportTicketStatuses.WaitingForAdmin">Waiting for admin</option>
                <option value="@SupportTicketStatuses.WaitingForUser">Waiting for user</option>
                <option value="@SupportTicketStatuses.Resolved">Resolved</option>
            </select>
        </div>
        <div>
            <label class="form-label" for="admin-support-category">Category</label>
            <select id="admin-support-category" class="form-select form-select-sm" data-testid="admin-support-category" @bind="_query.Category">
                <option value="">All</option>
                <option value="@SupportTicketCategories.Bug">Bug</option>
                <option value="@SupportTicketCategories.Account">Account</option>
                <option value="@SupportTicketCategories.Safety">Safety</option>
                <option value="@SupportTicketCategories.Suggestion">Suggestion</option>
                <option value="@SupportTicketCategories.Other">Other</option>
            </select>
        </div>
        <div>
            <label class="form-label" for="admin-support-page-size">Rows</label>
            <select id="admin-support-page-size" class="form-select form-select-sm" data-testid="admin-support-page-size" @bind="_query.PageSize">
                <option value="10">10</option>
                <option value="20">20</option>
                <option value="50">50</option>
            </select>
        </div>
        <div class="admin-support-filters__search">
            <label class="form-label" for="admin-support-search">Search</label>
            <input id="admin-support-search" class="form-control form-control-sm" data-testid="admin-support-search" placeholder="Subject, message, or user" @bind="_query.Search" />
        </div>
        <button class="btn btn-primary btn-sm" type="button" data-testid="admin-support-apply" @onclick="ApplyFiltersAsync" disabled="@_loading">
            @(_loading ? "Loading..." : "Apply")
        </button>
    </section>

    @if (!string.IsNullOrWhiteSpace(_queueError))
    {
        <div class="status-panel status-panel--error" role="alert" data-testid="admin-support-error">
            <div class="status-panel__icon"><i class="bi bi-exclamation-triangle" aria-hidden="true"></i></div>
            <div>
                <div class="status-panel__title">Support queue unavailable</div>
                <p class="status-panel__text mb-0">@_queueError</p>
            </div>
            <button class="btn btn-link btn-sm ms-auto" type="button" @onclick="LoadQueueAsync">Retry</button>
        </div>
    }

    <div class="admin-support-layout">
        <section class="admin-support-list-panel" aria-label="Support tickets">
            @if (_loading)
            {
                <div class="status-panel status-panel--info" data-testid="admin-support-loading">
                    <div class="status-panel__icon"><i class="bi bi-arrow-repeat" aria-hidden="true"></i></div>
                    <div>
                        <div class="status-panel__title">Loading support queue</div>
                        <p class="status-panel__text mb-0">Checking for new user requests.</p>
                    </div>
                </div>
            }
            else if (_tickets.Count == 0)
            {
                <EmptyState IconClass="bi bi-inbox"
                            Title="No matching requests"
                            Description="Try another status, category, or search term."
                            TitleClass="empty-state__title h4"
                            TestId="admin-support-empty" />
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm align-middle admin-support-table">
                        <thead>
                            <tr>
                                <th scope="col">Updated</th>
                                <th scope="col">Requester</th>
                                <th scope="col">Request</th>
                                <th scope="col">Status</th>
                                <th scope="col" class="text-end"><span class="visually-hidden">Actions</span></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ticket in _tickets)
                            {
                                <tr class="@(ticket.Id == _selectedTicket?.Id ? "is-selected" : string.Empty)" data-testid="admin-support-row">
                                    <td class="text-nowrap">@ticket.UpdatedUtc.ToLocalTime().ToString("MMM d, HH:mm")</td>
                                    <td>
                                        <div class="admin-support-cell-main">@ticket.RequesterDisplayName</div>
                                        <div class="admin-support-cell-muted">@@@ticket.RequesterUserName</div>
                                    </td>
                                    <td>
                                        <button class="admin-support-select-link" type="button" @onclick="() => SelectTicketAsync(ticket.Id)">
                                            @ticket.Subject
                                        </button>
                                        <div class="admin-support-cell-muted">@FormatCategory(ticket.Category) - @ticket.LatestMessagePreview</div>
                                    </td>
                                    <td><span class="@GetStatusClass(ticket.Status)">@FormatStatus(ticket.Status)</span></td>
                                    <td class="text-end">
                                        <button class="btn btn-outline-secondary btn-sm" type="button" data-testid="admin-support-select" @onclick="() => SelectTicketAsync(ticket.Id)">Inspect</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="paginator-bar">
                    <button class="btn btn-outline-secondary btn-sm" type="button" @onclick="PreviousPageAsync" disabled="@(_query.PageNumber <= 1 || _loading)">Previous</button>
                    <span class="text-muted">Page @_query.PageNumber of @_totalPages</span>
                    <button class="btn btn-outline-secondary btn-sm" type="button" @onclick="NextPageAsync" disabled="@(_query.PageNumber >= _totalPages || _loading)">Next</button>
                </div>
            }
        </section>

        <aside class="admin-support-inspector" data-testid="admin-support-inspector">
            @if (_detailLoading)
            {
                <div class="status-panel status-panel--info">
                    <div class="status-panel__icon"><i class="bi bi-search" aria-hidden="true"></i></div>
                    <div>
                        <div class="status-panel__title">Loading request</div>
                        <p class="status-panel__text mb-0">Fetching the complete conversation.</p>
                    </div>
                </div>
            }
            else if (_selectedTicket is null)
            {
                <div class="admin-support-inspector__empty">
                    <i class="bi bi-layout-sidebar-inset" aria-hidden="true"></i>
                    <div>
                        <strong>Select a request</strong>
                        <p class="mb-0">The conversation and reply tools will appear here.</p>
                    </div>
                </div>
            }
            else
            {
                <header class="admin-support-inspector__header">
                    <div>
                        <p class="section-label">@FormatCategory(_selectedTicket.Category) - #@_selectedTicket.Id</p>
                        <h2>@_selectedTicket.Subject</h2>
                        <p>@_selectedTicket.RequesterDisplayName - @@@_selectedTicket.RequesterUserName</p>
                    </div>
                    <span class="@GetStatusClass(_selectedTicket.Status)">@FormatStatus(_selectedTicket.Status)</span>
                </header>

                @if (!string.IsNullOrWhiteSpace(_actionError))
                {
                    <div class="status-panel status-panel--error" role="alert" data-testid="admin-support-action-error">
                        <div class="status-panel__icon"><i class="bi bi-exclamation-circle" aria-hidden="true"></i></div>
                        <div>
                            <div class="status-panel__title">Action failed</div>
                            <p class="status-panel__text mb-0">@_actionError</p>
                        </div>
                    </div>
                }

                <div class="admin-support-inspector__thread">
                    <SupportTicketThread Ticket="_selectedTicket" />
                </div>

                @if (_selectedTicket.Status == SupportTicketStatuses.Resolved)
                {
                    <div class="status-panel status-panel--success" data-testid="admin-support-resolved">
                        <div class="status-panel__icon"><i class="bi bi-check-circle" aria-hidden="true"></i></div>
                        <div>
                            <div class="status-panel__title">Request resolved</div>
                            <p class="status-panel__text mb-0">The requester can reopen it by sending another message.</p>
                        </div>
                    </div>
                }
                else
                {
                    <section class="admin-support-reply">
                        <h3>Reply as admin</h3>
                        <EditForm Model="_reply" OnValidSubmit="ReplyAsync">
                            <DataAnnotationsValidator />
                            <InputTextArea class="form-control" data-testid="admin-support-reply-input" maxlength="@SupportTicketRules.MaxMessageLength" @bind-Value="_reply.Body" />
                            <ValidationMessage For="@(() => _reply.Body)" />
                            <button class="btn btn-primary btn-sm mt-2" type="submit" data-testid="admin-support-reply-submit" disabled="@_actionBusy">
                                <i class="bi bi-send" aria-hidden="true"></i>
                                <span>@(_actionBusy ? "Working..." : "Send reply")</span>
                            </button>
                        </EditForm>
                    </section>
                }

                <section class="admin-support-status-control">
                    <div>
                        <strong>Request status</strong>
                        <p class="mb-0">@(_selectedTicket.Status == SupportTicketStatuses.Resolved ? "Closed by the admin team." : "Resolve this request when the user has what they need.")</p>
                    </div>
                    @if (_selectedTicket.Status != SupportTicketStatuses.Resolved)
                    {
                        <button class="btn btn-outline-success btn-sm" type="button" data-testid="admin-support-resolve" @onclick="ResolveAsync" disabled="@_actionBusy">
                            <i class="bi bi-check-circle" aria-hidden="true"></i>
                            <span>Resolve request</span>
                        </button>
                    }
                </section>
            }
        </aside>
    </div>
</div>

@code {
    private readonly SupportTicketQueryDto _query = new()
    {
        Status = null,
        Category = null,
        PageNumber = 1,
        PageSize = 20
    };
    private IReadOnlyList<SupportTicketSummaryDto> _tickets = Array.Empty<SupportTicketSummaryDto>();
    private SupportTicketDto? _selectedTicket;
    private CreateSupportTicketMessageDto _reply = new();
    private int _totalPages = 1;
    private int _selectionVersion;
    private bool _loading = true;
    private bool _detailLoading;
    private bool _actionBusy;
    private string? _queueError;
    private string? _actionError;

    protected override Task OnInitializedAsync() => LoadQueueAsync();

    private async Task LoadQueueAsync()
    {
        _loading = true;
        _queueError = null;
        try
        {
            var result = await SupportTickets.GetAdminQueueAsync(_query);
            if (!result.Success || result.Value is null)
            {
                _tickets = Array.Empty<SupportTicketSummaryDto>();
                _selectedTicket = null;
                _queueError = "We couldn't load the support queue. Please try again.";
                return;
            }

            _tickets = result.Value.Items.ToList();
            _totalPages = Math.Max(1, (int)Math.Ceiling(result.Value.TotalCount / (double)Math.Max(1, result.Value.PageSize)));

            var selectedStillVisible = _selectedTicket is not null && _tickets.Any(ticket => ticket.Id == _selectedTicket.Id);
            if (!selectedStillVisible)
            {
                _selectedTicket = null;
                if (_tickets.Count > 0)
                {
                    await SelectTicketAsync(_tickets[0].Id);
                }
            }
        }
        catch
        {
            _tickets = Array.Empty<SupportTicketSummaryDto>();
            _selectedTicket = null;
            _queueError = "We couldn't load the support queue. Please try again.";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SelectTicketAsync(int ticketId)
    {
        if (_selectedTicket?.Id != ticketId)
        {
            _reply = new CreateSupportTicketMessageDto();
        }

        var version = ++_selectionVersion;
        _detailLoading = true;
        _actionError = null;
        try
        {
            var result = await SupportTickets.GetAdminTicketAsync(ticketId);
            if (version != _selectionVersion)
            {
                return;
            }

            if (!result.Success || result.Value is null)
            {
                _selectedTicket = null;
                _actionError = "We couldn't load this support request.";
                return;
            }

            SetSelectedTicket(result.Value);
        }
        catch
        {
            if (version == _selectionVersion)
            {
                _selectedTicket = null;
                _actionError = "We couldn't load this support request.";
            }
        }
        finally
        {
            if (version == _selectionVersion)
            {
                _detailLoading = false;
            }
        }
    }

    private async Task ReplyAsync()
    {
        if (_selectedTicket is null)
        {
            return;
        }

        _actionBusy = true;
        _actionError = null;
        try
        {
            var result = await SupportTickets.ReplyAsAdminAsync(_selectedTicket.Id, _reply);
            if (!result.Success || result.Value is null)
            {
                _actionError = "The reply wasn't sent. Your draft is still available.";
                return;
            }

            SetSelectedTicket(result.Value);
            _reply = new CreateSupportTicketMessageDto();
            await RefreshQueueAfterActionAsync();
        }
        catch
        {
            _actionError = "The reply wasn't sent. Your draft is still available.";
        }
        finally
        {
            _actionBusy = false;
        }
    }

    private async Task ResolveAsync()
    {
        if (_selectedTicket is null)
        {
            return;
        }

        _actionBusy = true;
        _actionError = null;
        try
        {
            var result = await SupportTickets.UpdateStatusAsync(_selectedTicket.Id, new UpdateSupportTicketStatusDto { Status = SupportTicketStatuses.Resolved });
            if (!result.Success || result.Value is null)
            {
                _actionError = "The request status couldn't be updated.";
                return;
            }

            SetSelectedTicket(result.Value);
            await RefreshQueueAfterActionAsync();
        }
        catch
        {
            _actionError = "The request status couldn't be updated.";
        }
        finally
        {
            _actionBusy = false;
        }
    }

    private async Task RefreshQueueAfterActionAsync()
    {
        var selected = _selectedTicket;
        var result = await SupportTickets.GetAdminQueueAsync(_query);
        if (result.Success && result.Value is not null)
        {
            _tickets = result.Value.Items.ToList();
            _totalPages = Math.Max(1, (int)Math.Ceiling(result.Value.TotalCount / (double)Math.Max(1, result.Value.PageSize)));
        }

        if (selected is not null)
        {
            SetSelectedTicket(selected);
        }
    }

    private void SetSelectedTicket(SupportTicketDto ticket)
    {
        _selectedTicket = ticket;
    }

    private async Task ApplyFiltersAsync()
    {
        _query.PageNumber = 1;
        await LoadQueueAsync();
    }

    private async Task PreviousPageAsync()
    {
        _query.PageNumber--;
        await LoadQueueAsync();
    }

    private async Task NextPageAsync()
    {
        _query.PageNumber++;
        await LoadQueueAsync();
    }

    private static string FormatCategory(string category) => category switch
    {
        SupportTicketCategories.Bug => "Bug",
        SupportTicketCategories.Account => "Account",
        SupportTicketCategories.Safety => "Safety",
        SupportTicketCategories.Suggestion => "Suggestion",
        _ => "Other"
    };

    private static string FormatStatus(string status) => status switch
    {
        SupportTicketStatuses.WaitingForAdmin => "Waiting for admin",
        SupportTicketStatuses.WaitingForUser => "Waiting for user",
        SupportTicketStatuses.Resolved => "Resolved",
        _ => "New"
    };

    private static string GetStatusClass(string status) => status switch
    {
        SupportTicketStatuses.WaitingForUser => "badge text-bg-warning",
        SupportTicketStatuses.Resolved => "badge text-bg-success",
        SupportTicketStatuses.WaitingForAdmin => "badge text-bg-danger",
        _ => "badge text-bg-primary"
    };
}
