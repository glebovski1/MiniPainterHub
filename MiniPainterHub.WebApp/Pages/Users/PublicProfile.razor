@page "/users/{UserId}/admin"
@attribute [AllowAnonymous]
@using Microsoft.AspNetCore.Components.Authorization
@using MiniPainterHub.Common.DTOs
@using System.Linq
@inject MiniPainterHub.WebApp.Services.Interfaces.IProfileService Profiles
@inject MiniPainterHub.WebApp.Services.Interfaces.IModerationService Moderation
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Profile</PageTitle>

<div class="page-shell content-stack">
    @if (_loading)
    {
        <div class="status-panel status-panel--info">
            <div class="status-panel__icon"><i class="bi bi-person-circle" aria-hidden="true"></i></div>
            <div>
                <div class="status-panel__title">Loading profile</div>
                <p class="status-panel__text mb-0">Preparing profile details and moderation status.</p>
            </div>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(_loadError))
    {
        <div class="status-panel status-panel--error" role="alert" data-testid="public-profile-error">
            <div class="status-panel__icon"><i class="bi bi-exclamation-triangle" aria-hidden="true"></i></div>
            <div>
                <div class="status-panel__title">Could not load profile</div>
                <p class="status-panel__text mb-0">@_loadError</p>
            </div>
        </div>
    }
    else if (_profile is null)
    {
        <section class="empty-state">
            <div class="empty-state__icon"><i class="bi bi-person-x" aria-hidden="true"></i></div>
            <h1 class="empty-state__title h4">Profile not found</h1>
            <p class="empty-state__text mb-0">The requested painter profile is no longer available.</p>
        </section>
    }
    else
    {
        <section class="page-hero">
            <div class="d-flex flex-column flex-lg-row gap-4 align-items-lg-center">
                <UserAvatar ImageUrl="@_profile.AvatarUrl"
                            Name="@(_profile.DisplayName ?? _profile.UserId)"
                            Size="112" />

                <div class="flex-grow-1">
                    <p class="page-hero__eyebrow">Admin profile review</p>
                    <h1 class="page-hero__title mb-0" data-testid="public-profile-name">@(_profile.DisplayName ?? _profile.UserId)</h1>
                    <p class="page-hero__description mb-0" data-testid="public-profile-userid">@_profile.UserId</p>
                    <p class="page-hero__description mt-3" data-testid="public-profile-bio">@(!string.IsNullOrWhiteSpace(_profile.Bio) ? _profile.Bio : "No bio yet.")</p>
                </div>
            </div>
        </section>

        <AuthorizeView Roles="Admin">
            <Authorized>
                <section class="surface-card">
                    <div class="surface-card__header">
                        <div>
                            <p class="section-label">Admin actions</p>
                            <h2 class="surface-card__title">Account status</h2>
                            <p class="surface-card__subtitle">Review current suspension state, then update or remove the suspension without leaving the profile.</p>
                        </div>
                    </div>

                    @if (_statusLoading)
                    {
                        <div class="status-panel status-panel--info">
                            <div class="status-panel__icon"><i class="bi bi-hourglass-split" aria-hidden="true"></i></div>
                            <div>
                                <div class="status-panel__title">Loading status</div>
                                <p class="status-panel__text mb-0">Checking the current suspension state for this user.</p>
                            </div>
                        </div>
                    }
                    else if (!string.IsNullOrWhiteSpace(_statusError))
                    {
                        <div class="status-panel status-panel--warning" role="alert" data-testid="public-profile-status-error">
                            <div class="status-panel__icon"><i class="bi bi-exclamation-circle" aria-hidden="true"></i></div>
                            <div>
                                <div class="status-panel__title">Status unavailable</div>
                                <p class="status-panel__text mb-0">@_statusError</p>
                            </div>
                        </div>
                    }
                    else if (_status is not null)
                    {
                        <div class="surface-card mb-4" data-testid="public-profile-status">
                            <div class="section-heading">
                                <div>
                                    <p class="section-label">Suspension status</p>
                                    <h3 class="section-heading__title h4 mb-0">@(_status.IsSuspended ? "Suspended" : "Active")</h3>
                                </div>
                                <div class="mini-stat-bar">
                                    <span class="@(_status.IsSuspended ? "badge text-bg-danger" : "badge text-bg-success")">
                                        @(_status.IsSuspended ? "Suspended" : "Active")
                                    </span>
                                    @if (_status.SuspendedUntilUtc.HasValue)
                                    {
                                        <span class="mini-stat">Until <strong>@_status.SuspendedUntilUtc.Value.ToLocalTime().ToString("g")</strong></span>
                                    }
                                </div>
                            </div>
                        </div>
                    }

                    <div class="form-grid">
                        <div>
                            <label class="form-label" for="admin-suspend-until">Suspend until</label>
                            <input id="admin-suspend-until"
                                   type="datetime-local"
                                   class="form-control"
                                   data-testid="public-profile-suspend-until"
                                   @bind="_suspendUntilLocal" />
                        </div>

                        <div>
                            <label class="form-label" for="admin-reason">Reason</label>
                            <textarea id="admin-reason"
                                      class="form-control"
                                      rows="4"
                                      data-testid="public-profile-reason"
                                      @bind="_reason"></textarea>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_actionError))
                        {
                            <div class="status-panel status-panel--error" role="alert" data-testid="public-profile-action-error">
                                <div class="status-panel__icon"><i class="bi bi-exclamation-triangle" aria-hidden="true"></i></div>
                                <div>
                                    <div class="status-panel__title">Action failed</div>
                                    <p class="status-panel__text mb-0">@_actionError</p>
                                </div>
                            </div>
                        }
                        else if (!string.IsNullOrWhiteSpace(_actionResult))
                        {
                            <div class="status-panel status-panel--success" role="alert" data-testid="public-profile-action-result">
                                <div class="status-panel__icon"><i class="bi bi-check-circle" aria-hidden="true"></i></div>
                                <div>
                                    <div class="status-panel__title">Action applied</div>
                                    <p class="status-panel__text mb-0">@_actionResult</p>
                                </div>
                            </div>
                        }

                        <div class="page-toolbar">
                            <button class="btn btn-warning"
                                    type="button"
                                    data-testid="public-profile-suspend"
                                    @onclick="SuspendAsync"
                                    disabled="@_actionBusy">
                                @(_actionBusy && _actionBusyName == "suspend" ? "Working..." : (_status?.IsSuspended == true ? "Update suspension" : "Suspend user"))
                            </button>
                            <button class="btn btn-outline-secondary"
                                    type="button"
                                    data-testid="public-profile-unsuspend"
                                    @onclick="UnsuspendAsync"
                                    disabled="@(_actionBusy || _status?.IsSuspended != true)">
                                @(_actionBusy && _actionBusyName == "unsuspend" ? "Working..." : "Unsuspend")
                            </button>
                        </div>
                    </div>
                </section>
            </Authorized>
        </AuthorizeView>
    }
</div>

@code {
    [Parameter] public string UserId { get; set; } = string.Empty;

    private bool _loading = true;
    private string? _loadError;
    private PublicUserProfileDto? _profile;

    private bool _statusLoading;
    private string? _statusError;
    private ModerationUserLookupDto? _status;

    private DateTime _suspendUntilLocal = DateTime.UtcNow.AddDays(7).ToLocalTime();
    private string _reason = string.Empty;
    private bool _actionBusy;
    private string? _actionBusyName;
    private string? _actionError;
    private string? _actionResult;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _loadError = null;
        _profile = null;

        _status = null;
        _statusError = null;
        _actionError = null;
        _actionResult = null;

        try
        {
            if (string.IsNullOrWhiteSpace(UserId))
            {
                _loadError = "User id is missing.";
                return;
            }

            _profile = await Profiles.GetPublicProfileById(UserId);
        }
        catch
        {
            _loadError = "Could not load profile.";
        }
        finally
        {
            _loading = false;
        }

        await TryLoadAdminStatusAsync();
    }

    private async Task TryLoadAdminStatusAsync()
    {
        _statusLoading = false;
        _statusError = null;

        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            if (user.Identity?.IsAuthenticated != true || !user.IsInRole("Admin"))
            {
                return;
            }

            _statusLoading = true;
            var result = await Moderation.SearchUsersAsync(UserId, 10);
            if (!result.Success || result.Value is null)
            {
                _statusError = "Could not load admin status.";
                return;
            }

            _status = result.Value.FirstOrDefault(u => string.Equals(u.UserId, UserId, StringComparison.Ordinal));
            if (_status is null && result.Value.Count > 0)
            {
                _status = result.Value[0];
            }
        }
        catch
        {
            _statusError = "Could not load admin status.";
        }
        finally
        {
            _statusLoading = false;
        }
    }

    private async Task SuspendAsync()
    {
        _actionError = null;
        _actionResult = null;

        _actionBusy = true;
        _actionBusyName = "suspend";
        try
        {
            var success = await Moderation.SuspendUserAsync(UserId, new SuspendUserRequestDto
            {
                SuspendedUntilUtc = _suspendUntilLocal.ToUniversalTime(),
                Reason = NormalizeReason(_reason)
            });

            if (!success)
            {
                _actionError = "Suspend failed.";
                return;
            }

            _actionResult = "User suspended.";
            await TryLoadAdminStatusAsync();
        }
        finally
        {
            _actionBusy = false;
            _actionBusyName = null;
        }
    }

    private async Task UnsuspendAsync()
    {
        _actionError = null;
        _actionResult = null;

        _actionBusy = true;
        _actionBusyName = "unsuspend";
        try
        {
            var success = await Moderation.UnsuspendUserAsync(UserId, new ModerationActionRequestDto
            {
                Reason = NormalizeReason(_reason)
            });

            if (!success)
            {
                _actionError = "Unsuspend failed.";
                return;
            }

            _actionResult = "User unsuspended.";
            await TryLoadAdminStatusAsync();
        }
        finally
        {
            _actionBusy = false;
            _actionBusyName = null;
        }
    }

    private static string? NormalizeReason(string? reason)
    {
        if (string.IsNullOrWhiteSpace(reason))
        {
            return null;
        }

        return reason.Trim();
    }
}
