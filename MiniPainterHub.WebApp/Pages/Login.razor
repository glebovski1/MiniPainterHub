@page "/login"
@inject IAuthService AuthService
@inject NavigationManager Nav
@using MiniPainterHub.WebApp.Services.Auth

<PageTitle>Login</PageTitle>

<div class="page-shell">
    <div class="auth-shell auth-shell--split">
        <section class="surface-card auth-shell__intro">
            <p class="section-label mb-2">Studio access</p>
            <h1 class="auth-shell__headline">Return to your workbench.</h1>
            <p class="auth-shell__copy">Jump back into the latest posts, private hobby messages, and the personal hub without losing your place in the community.</p>

            <div class="auth-shell__metrics">
                <div class="metric-chip">
                    <span class="metric-chip__label">Community</span>
                    <strong class="metric-chip__value">Fresh feed</strong>
                </div>
                <div class="metric-chip">
                    <span class="metric-chip__label">Personal</span>
                    <strong class="metric-chip__value">Your panel</strong>
                </div>
                <div class="metric-chip">
                    <span class="metric-chip__label">Direct</span>
                    <strong class="metric-chip__value">Messages</strong>
                </div>
            </div>

            <div class="auth-shell__note">
                <div class="auth-shell__note-icon"><i class="bi bi-brush" aria-hidden="true"></i></div>
                <div>
                    <div class="auth-shell__note-title">What you can do after signing in</div>
                    <p class="mb-0">Share new posts, manage your profile, follow painters you like, and keep conversations moving.</p>
                </div>
            </div>
        </section>

        <EditForm Model="@_credentials"
                  OnValidSubmit="HandleLogin"
                  OnInvalidSubmit="HandleInvalidLogin"
                  aria-busy="@_isSubmitting.ToString().ToLowerInvariant()"
                  data-testid="login-form"
                  class="w-100">
            <DataAnnotationsValidator />

            <section class="surface-card auth-card mx-auto">
                <SectionHeader Eyebrow="Welcome back"
                               Title="Sign in to your studio"
                               Description="Pick up where you left off, check the feed, and get back to the hobby conversations waiting for you."
                               TitleTag="h1"
                               TitleClass="auth-card__title"
                               ClassName="section-heading section-heading--auth"
                               SectionName="Login Card" />

                <div class="form-grid mt-4">
                    <div>
                        <label for="login-username" class="form-label">Username</label>
                        <input id="login-username"
                               name="username"
                               class="form-control"
                               autocomplete="username"
                               data-testid="login-username"
                               value="@_credentials.UserName"
                               @oninput="HandleUserNameInput"
                               @onchange="HandleUserNameInput" />
                    </div>

                    <div>
                        <label for="login-password" class="form-label">Password</label>
                        <input id="login-password"
                               name="password"
                               type="password"
                               class="form-control"
                               autocomplete="current-password"
                               data-testid="login-password"
                               value="@_credentials.Password"
                               @oninput="HandlePasswordInput"
                               @onchange="HandlePasswordInput" />
                    </div>
                </div>

                <button type="submit"
                        class="btn btn-primary w-100 mt-4"
                        data-testid="login-submit"
                        disabled="@_isSubmitting">
                    @(_isSubmitting ? "Signing in..." : "Sign In")
                </button>

                @if (!string.IsNullOrEmpty(_error))
                {
                    <div id="login-error"
                         class="status-panel status-panel--error mt-3"
                         role="alert"
                         tabindex="-1"
                         data-testid="login-error"
                         @ref="_errorElement">
                        <div class="status-panel__icon"><i class="bi bi-exclamation-circle" aria-hidden="true"></i></div>
                        <div>
                            <div class="status-panel__title">Sign-in failed</div>
                            <p class="status-panel__text mb-0">@_error</p>
                        </div>
                    </div>
                }

                <div class="auth-card__footer">
                    Don't have an account?
                    <NavLink href="/register">Register</NavLink>
                </div>
            </section>
        </EditForm>
    </div>
</div>

@code {
    private readonly LoginDto _credentials = new();
    private ElementReference _errorElement;
    private string? _error;
    private bool _isSubmitting;
    private bool _shouldFocusError;

    private async Task HandleLogin()
    {
        if (_isSubmitting)
        {
            return;
        }

        _error = null;
        _shouldFocusError = false;
        _isSubmitting = true;

        try
        {
            var outcome = await AuthService.LoginAsync(_credentials);
            if (outcome == LoginOutcome.Success)
            {
                Nav.NavigateTo("/");
                return;
            }

            _error = GetErrorMessage(outcome);
            _shouldFocusError = true;
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private void HandleInvalidLogin(EditContext _)
    {
        _error = "Enter your username and password.";
        _shouldFocusError = true;
    }

    private void HandleUserNameInput(ChangeEventArgs args)
    {
        _credentials.UserName = args.Value?.ToString() ?? string.Empty;
        ClearError();
    }

    private void HandlePasswordInput(ChangeEventArgs args)
    {
        _credentials.Password = args.Value?.ToString() ?? string.Empty;
        ClearError();
    }

    private void ClearError()
    {
        _error = null;
        _shouldFocusError = false;
    }

    private static string GetErrorMessage(LoginOutcome outcome) => outcome switch
    {
        LoginOutcome.InvalidCredentials => "Invalid username or password.",
        LoginOutcome.ValidationFailure => "Check your username and password, then try again.",
        LoginOutcome.Forbidden => "This account cannot sign in right now. Contact an administrator if you need help.",
        LoginOutcome.RateLimited => "Too many sign-in attempts. Wait a moment and try again.",
        _ => "Sign-in is unavailable right now. Please try again."
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_shouldFocusError || string.IsNullOrEmpty(_error))
        {
            return;
        }

        _shouldFocusError = false;
        await _errorElement.FocusAsync();
    }
}
