@page "/login"
@inject IAuthService AuthService
@inject NavigationManager Nav

<PageTitle>Login</PageTitle>

<EditForm Model="@credentials" OnValidSubmit="HandleLogin" data-testid="login-form">
    <div class="container">
        <div class="row justify-content-center align-items-center vh-100">
            <div class="col-12 col-sm-8 col-md-6 col-lg-4">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h1 class="visually-hidden">Login</h1>
                        <h4 class="card-title text-center mb-4">Login</h4>

                        <div class="mb-3">
                            <label for="login-username" class="form-label">Username</label>
                            <InputText id="login-username"
                                       class="form-control"
                                       autocomplete="username"
                                       data-testid="login-username"
                                       @bind-Value="credentials.UserName" />
                        </div>

                        <div class="mb-4">
                            <label for="login-password" class="form-label">Password</label>
                            <InputText id="login-password"
                                       type="password"
                                       class="form-control"
                                       autocomplete="current-password"
                                       data-testid="login-password"
                                       @bind-Value="credentials.Password" />
                        </div>

                        <button type="submit" class="btn btn-primary w-100 mb-3" data-testid="login-submit">
                            Sign In
                        </button>

                        @if (!string.IsNullOrEmpty(error))
                        {
                            <div class="alert alert-danger text-center mb-0" data-testid="login-error">@error</div>
                        }

                        <div class="text-center mt-3">
                            <small>
                                Don’t have an account?
                                <NavLink href="/register">Register</NavLink>
                            </small>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</EditForm>

@code {
    private LoginDto credentials = new();
    private string error = string.Empty;

    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    private async Task HandleLogin()
    {
        var success = await AuthService.LoginAsync(credentials);
        if (success)
        {
            var target = string.IsNullOrWhiteSpace(ReturnUrl) ? "/" : ReturnUrl;
            Nav.NavigateTo(target);
        }
        else
        {
            error = "Invalid username or password.";
        }
    }
}
