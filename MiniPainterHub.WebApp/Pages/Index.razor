@page "/"

<PageTitle>Latest posts</PageTitle>

<div class="page-shell content-stack">
    <PageHero Eyebrow="Community feed"
              Title="Latest Posts"
              Description="Fresh workbench drops, finished miniatures, and technique notes from painters across the community."
              FrameName="Home Feed Header">
        <Actions>
            <NavLink class="btn btn-primary" href="/posts/all">
                <i class="bi bi-grid-1x2" aria-hidden="true"></i>
                <span>Explore the archive</span>
            </NavLink>
            <NavLink class="btn btn-outline-secondary" href="/posts/top">
                <i class="bi bi-trophy" aria-hidden="true"></i>
                <span>View top posts</span>
            </NavLink>
        </Actions>
    </PageHero>

    <section class="surface-card">
        <SectionHeader Eyebrow="Live feed"
                       Title="Latest community posts"
                       Description="Image-first updates with quick access to tags, comments, and likes."
                       SectionName="Latest Posts" />
        <CardList></CardList>
    </section>
</div>
