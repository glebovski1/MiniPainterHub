@page "/posts/{PostId:int}"
@using MiniPainterHub.Common.DTOs
@inject ApiClient Api
@inject NavigationManager Nav
@inject MiniPainterHub.WebApp.Services.Interfaces.IModerationService ModerationService
@using MiniPainterHub.WebApp.Services.Http
@using System.Net
@using System.Net.Http
@using MiniPainterHub.WebApp.Shared
@using System
@using System.Linq
@using System.Collections.Generic

<div class="page-shell content-stack">
    @if (isLoading)
    {
        <div class="status-panel status-panel--info">
            <div class="status-panel__icon"><i class="bi bi-image" aria-hidden="true"></i></div>
            <div>
                <div class="status-panel__title">Loading post</div>
                <p class="status-panel__text mb-0">Preparing the gallery and conversation for this post.</p>
            </div>
        </div>
    }
    else if (!string.IsNullOrEmpty(loadError))
    {
        <div class="status-panel status-panel--error">
            <div class="status-panel__icon"><i class="bi bi-exclamation-octagon" aria-hidden="true"></i></div>
            <div>
                <div class="status-panel__title">Couldn’t load post</div>
                <p class="status-panel__text mb-0">
                    @loadError
                    @if (loadStatus.HasValue)
                    {
                        <span class="small">(Status: @((int)loadStatus.Value))</span>
                    }
                </p>
            </div>
            <button class="btn btn-link btn-sm ms-auto" @onclick="LoadPost">Retry</button>
        </div>
    }
    else if (post is null)
    {
        <EmptyState IconClass="bi bi-binoculars"
                    Title="Post not found"
                    Description="This post may have been removed or never existed."
                    TitleClass="empty-state__title h4" />
    }
    else
    {
        <PageHero Eyebrow="Post details"
                  Title="@post.Title"
                  TitleTestId="post-title"
                  Description="@($"Shared on {post.CreatedAt.ToLocalTime():MMM dd, yyyy}")"
                  FrameName="Post Details Header">
            <Actions>
                <div class="mini-stat-bar">
                    <LikeButton PostId="@PostId" TestId="post-like-toggle" />
                    <button class="btn btn-outline-secondary btn-sm" @onclick='() => Nav.NavigateTo("/")'>
                        Back
                    </button>
                    <AuthorizeView Roles="Moderator,Admin">
                        <Authorized>
                            <span class="badge text-bg-secondary" data-testid="post-id-badge">#@PostId</span>
                        </Authorized>
                    </AuthorizeView>
                </div>
            </Actions>
            <ChildContent>
                <div class="mini-stat-bar">
                    <NavLink class="mini-stat text-decoration-none" href="@($"/users/{post.CreatedById}")">
                        By @post.AuthorName
                    </NavLink>
                </div>
            </ChildContent>
        </PageHero>

        <div class="split-grid post-details-grid">
            <section class="surface-card post-details-media">
                @if (HasImages)
                {
                    <div class="post-details-stage">
                        <img src="@SelectedPreviewUrl"
                             class="img-fluid rounded shadow-sm"
                             data-testid="post-details-image"
                             alt="Post image"
                             loading="lazy"
                             @onclick="ShowZoomModal" />
                    </div>

                    <div class="post-details-thumbnails">
                        @for (int i = 0; i < PostImages!.Count; i++)
                        {
                            int imageIndex = i;
                            var img = PostImages[i];
                            <img src="@GetThumbnailUrl(img)"
                                 class="img-thumbnail post-details-thumbnail @(selectedIndex == imageIndex ? "is-active" : string.Empty)"
                                 data-testid="post-details-thumbnail"
                                 @onclick="@(() => SelectImage(imageIndex))" />
                        }
                    </div>
                }
                else if (!string.IsNullOrEmpty(post.ImageUrl))
                {
                    <div class="post-details-stage">
                        <img src="@GetAbsoluteUrl(ReplaceVariantSuffix(post.ImageUrl, "_preview."))"
                             class="img-fluid rounded shadow-sm"
                             data-testid="post-details-image"
                             alt="Post image"
                             loading="lazy"
                             @onclick="ShowZoomModal" />
                    </div>
                }
                else
                {
                    <EmptyState IconClass="bi bi-image"
                                Title="No images on this post"
                                TitleTag="h3"
                                TitleClass="empty-state__title h5" />
                }
            </section>

            <section class="surface-card post-details-aside">
                @if (post.Tags is { Count: > 0 })
                {
                    <section class="mb-4" data-testid="post-details-tag-section">
                        <p class="section-label">Tags</p>
                        <TagBadgeList Tags="post.Tags" TestId="post-details-tags" />
                    </section>
                }

                <div class="post-details-copy mb-4">
                    @post.Content
                </div>

                <ReportAction TargetType="@ReportTargetTypes.Post"
                              TargetId="@PostId.ToString()"
                              OwnerUserId="@post.CreatedById"
                              TestIdPrefix="post-report" />

                <AuthorizeView Roles="Moderator,Admin">
                    <Authorized>
                        <div class="d-flex flex-wrap gap-2 mb-3" data-testid="post-inline-moderation-controls">
                            <button class="btn btn-outline-warning btn-sm"
                                    type="button"
                                    data-testid="post-inline-hide"
                                    @onclick="HidePostAsync"
                                    disabled="@_postModerationBusy">
                                Hide post
                            </button>
                            <button class="btn btn-outline-secondary btn-sm"
                                    type="button"
                                    data-testid="post-inline-restore"
                                    @onclick="RestorePostAsync"
                                    disabled="@_postModerationBusy">
                                Restore post
                            </button>
                        </div>
                    </Authorized>
                </AuthorizeView>

                @if (!string.IsNullOrWhiteSpace(_postModerationError))
                {
                    <div class="status-panel status-panel--error mb-3" role="alert" data-testid="post-inline-moderation-error">
                        <div class="status-panel__icon"><i class="bi bi-exclamation-circle" aria-hidden="true"></i></div>
                        <div>
                            <div class="status-panel__title">Moderation action failed</div>
                            <p class="status-panel__text mb-0">@_postModerationError</p>
                        </div>
                    </div>
                }
                else if (!string.IsNullOrWhiteSpace(_postModerationResult))
                {
                    <div class="status-panel status-panel--success mb-3" role="alert" data-testid="post-inline-moderation-result">
                        <div class="status-panel__icon"><i class="bi bi-check2-circle" aria-hidden="true"></i></div>
                        <div>
                            <div class="status-panel__title">Moderation updated</div>
                            <p class="status-panel__text mb-0">@_postModerationResult</p>
                        </div>
                    </div>
                }
            </section>
        </div>

        <section class="surface-card">
            <SectionHeader Eyebrow="Conversation"
                           Title="Comments"
                           Description="Feedback, encouragement, and technique discussion."
                           TitleTag="h2"
                           TitleClass="section-heading__title h3 mb-0"
                           SectionName="Comments" />

            <AuthorizeView>
                <Authorized>
                    <CommentForm PostId="@PostId" OnCommentAdded="ReloadComments" />
                </Authorized>
                <NotAuthorized>
                    <div class="status-panel status-panel--info" role="alert">
                        <div class="status-panel__icon"><i class="bi bi-info-circle" aria-hidden="true"></i></div>
                        <div>
                            <div class="status-panel__title">Join the conversation</div>
                            <p class="status-panel__text mb-0">
                                Sign in to join the conversation.
                                <button class="btn btn-link p-0 align-baseline" @onclick="GoToLogin">Login</button>
                            </p>
                        </div>
                    </div>
                </NotAuthorized>
            </AuthorizeView>
            <CommentList @ref="_commentList" PostId="@PostId" />
        </section>
    }
</div>

@if (showModal)
{
    <div class="modal fade show d-block post-details-modal-backdrop" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content bg-transparent border-0">
                <img src="@SelectedMaxUrl" class="img-fluid rounded zoomed-image" alt="Zoomed image" />
                <button type="button" class="btn-close position-absolute top-0 end-0 m-3 bg-white rounded-circle"
                        aria-label="Close"
                        @onclick="CloseZoomModal"></button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int PostId { get; set; }
    private CommentList? _commentList;
    private PostDto? post;
    private bool isLoading;
    private string? loadError;
    private HttpStatusCode? loadStatus;
    private bool showModal = false;
    private bool _postModerationBusy;
    private string? _postModerationError;
    private string? _postModerationResult;

    private int selectedIndex = 0;

    private List<dynamic>? PostImages
        => TryGetImages(post);

    private bool HasImages => PostImages != null && PostImages.Count > 0;

    private string SelectedPreviewUrl
        => HasImages ? GetPreviewUrl(PostImages![selectedIndex])
                     : GetAbsoluteUrl(ReplaceVariantSuffix(post?.ImageUrl, "_preview."));

    private string SelectedMaxUrl
        => HasImages ? GetMaxUrl(PostImages![selectedIndex])
                     : GetAbsoluteUrl(post?.ImageUrl);

    protected override async Task OnInitializedAsync()
    {
        await LoadPost();
    }

    private async Task LoadPost()
    {
        isLoading = true;
        loadError = null;
        loadStatus = null;
        try
        {
            var request = new HttpRequestMessage(HttpMethod.Get, $"api/posts/{PostId}");
            var response = await Api.SendForResultAsync<PostDto>(request, new ApiRequestOptions { SuppressErrorNotifications = true });

            if (response.Success && response.Value is not null)
            {
                post = response.Value;
                selectedIndex = 0;
                loadStatus = null;
            }
            else
            {
                loadStatus = response.StatusCode;
                loadError = response.StatusCode == HttpStatusCode.NotFound
                    ? "This post could not be found."
                    : "We couldn't load this post. Please check your connection and try again.";
                post = null;
            }
        }
        catch
        {
            post = null;
            loadStatus = null;
            loadError = "We couldn't load this post. Please try again in a moment.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ReloadComments()
    {
        if (_commentList != null)
            await _commentList.ReloadAsync();
    }

    private void GoToLogin()
    {
        var returnUrl = Uri.EscapeDataString(Nav.Uri);
        Nav.NavigateTo($"/login?returnUrl={returnUrl}", true);
    }

    private void ShowZoomModal() => showModal = true;
    private void CloseZoomModal() => showModal = false;

    private Task HidePostAsync() => ModeratePostAsync(hide: true);

    private Task RestorePostAsync() => ModeratePostAsync(hide: false);

    private async Task ModeratePostAsync(bool hide)
    {
        _postModerationError = null;
        _postModerationResult = null;

        _postModerationBusy = true;
        try
        {
            var request = new ModerationActionRequestDto
            {
                Reason = "Inline moderation from post details."
            };

            var success = hide
                ? await ModerationService.HidePostAsync(PostId, request)
                : await ModerationService.RestorePostAsync(PostId, request);

            if (!success)
            {
                _postModerationError = "Moderation action failed.";
                return;
            }

            _postModerationResult = hide ? "Post hidden." : "Post restored.";
            await LoadPost();
            await ReloadComments();
        }
        finally
        {
            _postModerationBusy = false;
        }
    }

    private void SelectImage(int index)
    {
        if (!HasImages) return;
        if (index < 0 || index >= PostImages!.Count) return;
        selectedIndex = index;
    }

    private static List<dynamic>? TryGetImages(PostDto? p)
    {
        if (p is null) return null;

        try
        {
            dynamic dyn = p;
            var imgs = dyn.Images;

            if (imgs is null) return null;

            if (imgs is IEnumerable<object> seq)
                return seq.Select(x => (dynamic)x).ToList();

            return null;
        }
        catch
        {
            return null;
        }
    }

    private string GetMaxUrl(dynamic img)
    {
        var baseUrl =
            TryGetString(img, nameof(PostImageDto.ImageUrl)) ??
            TryGetString(img, "Url") ??
            TryGetString(img, "imageUrl") ??
            TryGetString(img, "url");

        return GetAbsoluteUrl(baseUrl);
    }

    private string GetPreviewUrl(dynamic img)
    {
        var preview =
            TryGetString(img, nameof(PostImageDto.PreviewUrl)) ??
            TryGetString(img, "PreviewUrl") ??
            TryGetString(img, "previewUrl");

        if (!string.IsNullOrEmpty(preview))
        {
            return GetAbsoluteUrl(preview);
        }

        return GetMaxUrl(img);
    }

    private string GetThumbnailUrl(dynamic img)
    {
        var thumb =
            TryGetString(img, nameof(PostImageDto.ThumbnailUrl)) ??
            TryGetString(img, "thumbnailUrl");

        if (!string.IsNullOrEmpty(thumb))
        {
            return GetAbsoluteUrl(thumb);
        }

        var baseUrl =
            TryGetString(img, nameof(PostImageDto.ImageUrl)) ??
            TryGetString(img, "Url") ??
            TryGetString(img, "imageUrl") ??
            TryGetString(img, "url");

        return GetAbsoluteUrl(ReplaceVariantSuffix(baseUrl, "_thumb."));
    }

    private static string? TryGetString(dynamic obj, string property)
    {
        if (obj is null) return null;

        try
        {
            var prop = obj.GetType().GetProperty(property);
            if (prop != null)
            {
                var propValue = prop.GetValue(obj) as string;
                if (!string.IsNullOrWhiteSpace(propValue))
                    return propValue;
            }
        }
        catch { }

        if (obj is IDictionary<string, object> dict &&
            dict.TryGetValue(property, out var value) &&
            value is string val && !string.IsNullOrWhiteSpace(val))
        {
            return val;
        }

        return null;
    }

    private static string ReplaceVariantSuffix(string? url, string replacement)
    {
        if (string.IsNullOrEmpty(url))
        {
            return string.Empty;
        }

        return url.Contains("_max.", StringComparison.OrdinalIgnoreCase)
            ? url.Replace("_max.", replacement, StringComparison.OrdinalIgnoreCase)
            : url;
    }

    private string GetAbsoluteUrl(string? url)
    {
        if (string.IsNullOrEmpty(url))
            return string.Empty;

        return url.StartsWith("http", StringComparison.OrdinalIgnoreCase)
            ? url
            : $"{Nav.BaseUri.TrimEnd('/')}{url}";
    }
}
