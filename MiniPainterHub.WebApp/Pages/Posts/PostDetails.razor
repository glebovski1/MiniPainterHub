@page "/posts/{PostId:int}"
@using System.Net
@using System.Net.Http
@using MiniPainterHub.Common.DTOs
@using MiniPainterHub.WebApp.Services.Http
@using MiniPainterHub.WebApp.Shared
@using MiniPainterHub.WebApp.Shared.Viewer
@inject ApiClient Api
@inject NavigationManager Nav
@inject MiniPainterHub.WebApp.Services.Interfaces.IModerationService ModerationService
@inject MiniPainterHub.WebApp.Services.Interfaces.ICommentMarkService CommentMarkService

<div class="page-shell content-stack">
    @if (isLoading)
    {
        <div class="status-panel status-panel--info">
            <div class="status-panel__icon"><i class="bi bi-image" aria-hidden="true"></i></div>
            <div>
                <div class="status-panel__title">Loading post</div>
                <p class="status-panel__text mb-0">Preparing the gallery and conversation for this post.</p>
            </div>
        </div>
    }
    else if (!string.IsNullOrEmpty(loadError))
    {
        <div class="status-panel status-panel--error">
            <div class="status-panel__icon"><i class="bi bi-exclamation-octagon" aria-hidden="true"></i></div>
            <div>
                <div class="status-panel__title">Couldn't load post</div>
                <p class="status-panel__text mb-0">
                    @loadError
                    @if (loadStatus.HasValue)
                    {
                        <span class="small">(Status: @((int)loadStatus.Value))</span>
                    }
                </p>
            </div>
            <button class="btn btn-link btn-sm ms-auto" @onclick="LoadPostAsync">Retry</button>
        </div>
    }
    else if (post is null || viewer is null)
    {
        <EmptyState IconClass="bi bi-binoculars"
                    Title="Post not found"
                    Description="This post may have been removed or never existed."
                    TitleClass="empty-state__title h4" />
    }
    else
    {
        <PageHero Eyebrow="Post details"
                  Title="@post.Title"
                  TitleTestId="post-title"
                  Description="@($"Shared on {post.CreatedAt.ToLocalTime():MMM dd, yyyy}")"
                  FrameName="Post Details Header">
            <Actions>
                <div class="mini-stat-bar">
                    <LikeButton PostId="@PostId" TestId="post-like-toggle" />
                    <button class="btn btn-outline-secondary btn-sm" @onclick='() => Nav.NavigateTo("/")'>
                        Back
                    </button>
                    <AuthorizeView Roles="Moderator,Admin">
                        <Authorized>
                            <span class="badge text-bg-secondary" data-testid="post-id-badge">#@PostId</span>
                        </Authorized>
                    </AuthorizeView>
                </div>
            </Actions>
            <ChildContent>
                <div class="mini-stat-bar">
                    <NavLink class="mini-stat text-decoration-none" href="@($"/users/{post.CreatedById}")">
                        By @post.AuthorName
                    </NavLink>
                </div>
            </ChildContent>
        </PageHero>

        <div class="split-grid post-details-grid">
            <section class="post-details-media-stack">
                <section class="surface-card post-details-gallery" data-testid="post-details-gallery">
                    <div class="post-details-gallery__header">
                        <div>
                            <p class="section-label mb-2">Gallery preview</p>
                            <h2 class="post-details-gallery__title">Open the rich viewer from the artwork.</h2>
                        </div>
                        <button type="button"
                                class="btn btn-dark post-details-gallery__launch"
                                data-testid="post-details-open-viewer"
                                @onclick="OpenViewerAsync">
                            <i class="bi bi-arrows-angle-expand" aria-hidden="true"></i>
                            Launch viewer
                        </button>
                    </div>

                    @if (CurrentPreviewImage is not null)
                    {
                        <button type="button"
                                class="post-details-gallery__hero"
                                data-testid="post-details-open-viewer-hero"
                                @onclick="OpenViewerAsync">
                            <img src="@GetPreviewSource(CurrentPreviewImage)"
                                 class="post-details-gallery__image"
                                 data-testid="post-details-image"
                                 alt="@post.Title" />
                            <span class="post-details-gallery__hint">
                                <span class="post-details-gallery__hint-title">Open the premium viewer</span>
                                <span class="post-details-gallery__hint-copy">Zoom, pan, fullscreen, marks, and discussion anchors live in the overlay.</span>
                            </span>
                        </button>
                    }
                    else
                    {
                        <div class="post-details-gallery__empty">
                            <i class="bi bi-image" aria-hidden="true"></i>
                            <span>No post images available.</span>
                        </div>
                    }

                    @if (viewer.Images.Count > 1)
                    {
                        <div class="post-details-gallery__thumbs" data-testid="post-details-thumbnails">
                            @for (var index = 0; index < viewer.Images.Count; index++)
                            {
                                var image = viewer.Images[index];
                                var isActive = image.Id == ResolvedActiveImageId;

                                <button type="button"
                                        class="post-details-gallery__thumb @(isActive ? "is-active" : null)"
                                        data-testid="post-details-thumbnail"
                                        @onclick="@(() => OpenViewerAtImageAsync(image.Id))">
                                    <img src="@GetThumbnailSource(image)" alt="" loading="lazy" />
                                    <span class="post-details-gallery__thumb-index">@((index + 1).ToString("00"))</span>
                                </button>
                            }
                        </div>
                    }

                    <div class="post-details-gallery__footer">
                        <div class="mini-stat-bar">
                            <span class="mini-stat"><i class="bi bi-images" aria-hidden="true"></i> @viewer.Images.Count image(s)</span>
                            <span class="mini-stat"><i class="bi bi-pin-angle" aria-hidden="true"></i> @viewer.AuthorMarks.Count author note(s)</span>
                            <span class="mini-stat"><i class="bi bi-chat-square-text" aria-hidden="true"></i> @(viewer.CanAttachCommentMark ? "Comment anchors available" : "Sign in to add anchors")</span>
                        </div>
                    </div>
                </section>
            </section>

            <section class="surface-card post-details-aside">
                @if (post.Tags is { Count: > 0 })
                {
                    <section class="mb-4" data-testid="post-details-tag-section">
                        <p class="section-label">Tags</p>
                        <TagBadgeList Tags="post.Tags" TestId="post-details-tags" />
                    </section>
                }

                <section class="post-details-aside__panel">
                    <p class="section-label">About this piece</p>
                    <div class="post-details-copy">
                        @post.Content
                    </div>
                </section>

                <section class="post-details-aside__panel">
                    <p class="section-label">Viewer state</p>
                    <div class="post-details-aside__meta">
                        <span><strong>@viewer.Images.Count</strong> image(s)</span>
                        <span><strong>@viewer.AuthorMarks.Count</strong> author note(s)</span>
                        <span><strong>@(viewer.CanAttachCommentMark ? "Comment marks enabled" : "Sign in to attach comment marks")</strong></span>
                    </div>

                    @if (_activeCommentId.HasValue)
                    {
                        <div class="post-details-aside__callout">
                            <i class="bi bi-chat-square-text" aria-hidden="true"></i>
                            <span>Comment #@_activeCommentId.Value is currently pinned in the viewer.</span>
                        </div>
                    }
                    else if (_draftCommentMark is not null)
                    {
                        <div class="post-details-aside__callout">
                            <i class="bi bi-crosshair2" aria-hidden="true"></i>
                            <span>Comment draft linked to image @GetImageNumber(_draftCommentMark.PostImageId).</span>
                        </div>
                    }
                </section>

                <ReportAction TargetType="@ReportTargetTypes.Post"
                              TargetId="@PostId.ToString()"
                              OwnerUserId="@post.CreatedById"
                              TestIdPrefix="post-report" />

                <AuthorizeView Roles="Moderator,Admin">
                    <Authorized>
                        <div class="d-flex flex-wrap gap-2 mb-3" data-testid="post-inline-moderation-controls">
                            <button class="btn btn-outline-warning btn-sm"
                                    type="button"
                                    data-testid="post-inline-hide"
                                    @onclick="HidePostAsync"
                                    disabled="@_postModerationBusy">
                                Hide post
                            </button>
                            <button class="btn btn-outline-secondary btn-sm"
                                    type="button"
                                    data-testid="post-inline-restore"
                                    @onclick="RestorePostAsync"
                                    disabled="@_postModerationBusy">
                                Restore post
                            </button>
                        </div>
                    </Authorized>
                </AuthorizeView>

                @if (!string.IsNullOrWhiteSpace(_postModerationError))
                {
                    <div class="status-panel status-panel--error mb-3" role="alert" data-testid="post-inline-moderation-error">
                        <div class="status-panel__icon"><i class="bi bi-exclamation-circle" aria-hidden="true"></i></div>
                        <div>
                            <div class="status-panel__title">Moderation action failed</div>
                            <p class="status-panel__text mb-0">@_postModerationError</p>
                        </div>
                    </div>
                }
                else if (!string.IsNullOrWhiteSpace(_postModerationResult))
                {
                    <div class="status-panel status-panel--success mb-3" role="alert" data-testid="post-inline-moderation-result">
                        <div class="status-panel__icon"><i class="bi bi-check2-circle" aria-hidden="true"></i></div>
                        <div>
                            <div class="status-panel__title">Moderation updated</div>
                            <p class="status-panel__text mb-0">@_postModerationResult</p>
                        </div>
                    </div>
                }
            </section>
        </div>

        <section class="surface-card">
            <SectionHeader Eyebrow="Conversation"
                           Title="Comments"
                           Description="Feedback, encouragement, and technique discussion."
                           TitleTag="h2"
                           TitleClass="section-heading__title h3 mb-0"
                           SectionName="Comments" />

            <AuthorizeView>
                <Authorized>
                    <CommentForm PostId="@PostId"
                                 CanAttachViewerMark="@(viewer.CanAttachCommentMark && viewer.Images.Count > 0)"
                                 ViewerPlacementActive="@_isCommentPlacementMode"
                                 DraftMark="@_draftCommentMark"
                                 AttachedImageNumber="@GetImageNumber(_draftCommentMark?.PostImageId)"
                                 OnRequestAttachMark="BeginCommentPlacementAsync"
                                 OnRemoveAttachedMark="RemoveDraftCommentMarkAsync"
                                 OnCommentAdded="HandleCommentAddedAsync" />
                </Authorized>
                <NotAuthorized>
                    <div class="status-panel status-panel--info" role="alert">
                        <div class="status-panel__icon"><i class="bi bi-info-circle" aria-hidden="true"></i></div>
                        <div>
                            <div class="status-panel__title">Join the conversation</div>
                            <p class="status-panel__text mb-0">
                                Sign in to join the conversation.
                                <button class="btn btn-link p-0 align-baseline" @onclick="GoToLogin">Login</button>
                            </p>
                        </div>
                    </div>
                </NotAuthorized>
            </AuthorizeView>

            <CommentList @ref="_commentList"
                         PostId="@PostId"
                         ActiveCommentId="@_activeCommentId"
                         LoadingViewerMarkCommentId="@_markLoadingCommentId"
                         ViewerMarkErrorCommentId="@_markErrorCommentId"
                         ViewerMarkError="@_markError"
                         OnToggleViewerMark="ToggleCommentMarkAsync"
                         ViewerActionLabel="Open in viewer"
                         ViewerActionActiveLabel="Hide marker" />
        </section>

        <RichImageViewer IsOpen="@_isViewerOpen"
                         Eyebrow="Rich viewer"
                         Title="@post.Title"
                         Viewer="@viewer"
                         ActiveImageId="@_activeImageId"
                         ActiveImageIdChanged="HandleActiveImageChangedAsync"
                         ActiveCommentMark="@_activeCommentMark"
                         ActiveCommentId="@_activeCommentId"
                         DraftCommentMark="@_draftCommentMark"
                         IsCommentPlacementMode="@_isCommentPlacementMode"
                         OnCommentPlacementSelected="HandleCommentPlacementSelectedAsync"
                         OnCommentPlacementCancelled="CancelCommentPlacementAsync"
                         OnClearActiveCommentMark="ClearActiveCommentMarkAsync"
                         OnClose="CloseViewerAsync">
            <SidePanelContent>
                <div class="viewer-panel">
                    <div class="viewer-panel__tabs" role="tablist" aria-label="Viewer details" data-testid="viewer-side-tabs">
                        <button type="button"
                                class="viewer-panel__tab @(_viewerSideTab == ViewerSideTab.Info ? "is-active" : null)"
                                data-testid="viewer-side-tab-info"
                                aria-pressed="@(_viewerSideTab == ViewerSideTab.Info)"
                                @onclick='() => SetViewerSideTab(ViewerSideTab.Info)'>
                            Info
                        </button>
                        <button type="button"
                                class="viewer-panel__tab @(_viewerSideTab == ViewerSideTab.Comments ? "is-active" : null)"
                                data-testid="viewer-side-tab-comments"
                                aria-pressed="@(_viewerSideTab == ViewerSideTab.Comments)"
                                @onclick='() => SetViewerSideTab(ViewerSideTab.Comments)'>
                            Comments
                        </button>
                    </div>

                    @if (_viewerSideTab == ViewerSideTab.Info)
                    {
                        <div class="viewer-panel__content" data-testid="viewer-panel-info">
                            <section class="viewer-panel-section viewer-panel-section--hero">
                                <p class="viewer-panel__eyebrow">About this piece</p>
                                <div class="viewer-panel__meta">
                                    <NavLink class="viewer-panel__author" href="@($"/users/{post.CreatedById}")">By @post.AuthorName</NavLink>
                                    <span>@post.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</span>
                                </div>
                                <div class="viewer-panel__copy">@post.Content</div>
                            </section>

                            @if (post.Tags is { Count: > 0 })
                            {
                                <section class="viewer-panel-section">
                                    <p class="viewer-panel__eyebrow">Tags</p>
                                    <TagBadgeList Tags="post.Tags" TestId="viewer-panel-tags" />
                                </section>
                            }

                            <section class="viewer-panel-section" data-testid="viewer-mark-summary">
                                <p class="viewer-panel__eyebrow">Mark system</p>
                                <div class="viewer-panel__legend">
                                    <div class="viewer-panel__legend-item viewer-panel__legend-item--author">
                                        <span class="viewer-panel__legend-dot"></span>
                                        <span>Author notes stay visible and are styled as permanent annotations.</span>
                                    </div>
                                    <div class="viewer-panel__legend-item viewer-panel__legend-item--comment">
                                        <span class="viewer-panel__legend-dot"></span>
                                        <span>Comment anchors load on demand and only one is active at a time.</span>
                                    </div>
                                </div>
                            </section>
                        </div>
                    }
                    else
                    {
                        <div class="viewer-panel__content viewer-panel__content--comments" data-testid="viewer-panel-comments">
                            @if (_activeCommentId.HasValue)
                            {
                                <div class="post-details-aside__callout" data-testid="viewer-comment-state">
                                    <i class="bi bi-chat-square-text" aria-hidden="true"></i>
                                    <span>Comment #@_activeCommentId.Value is highlighted on image @GetImageNumber(_activeImageId).</span>
                                </div>
                            }
                            else if (_draftCommentMark is not null)
                            {
                                <div class="post-details-aside__callout" data-testid="viewer-draft-state">
                                    <i class="bi bi-crosshair2" aria-hidden="true"></i>
                                    <span>Draft anchor placed on image @GetImageNumber(_draftCommentMark.PostImageId).</span>
                                </div>
                            }

                            <section class="viewer-panel-section viewer-panel-section--comments">
                                <div class="viewer-panel__comments-header">
                                    <div>
                                        <p class="viewer-panel__eyebrow">Comments</p>
                                        <h3 class="viewer-panel__title">Discuss the piece without leaving the viewer.</h3>
                                    </div>
                                </div>

                                <div class="viewer-panel__comments-thread" data-testid="viewer-comments-thread">
                                    <div class="viewer-panel__comments-scroll" data-testid="viewer-comments-scroll">
                                        <div class="viewer-panel__comments-list">
                                            <CommentList @ref="_viewerCommentList"
                                                         PostId="@PostId"
                                                         ActiveCommentId="@_activeCommentId"
                                                         LoadingViewerMarkCommentId="@_markLoadingCommentId"
                                                         ViewerMarkErrorCommentId="@_markErrorCommentId"
                                                         ViewerMarkError="@_markError"
                                                         OnToggleViewerMark="ToggleCommentMarkAsync"
                                                         IsViewerPanel="true"
                                                         ViewerActionLabel="Reveal anchor"
                                                         ViewerActionActiveLabel="Hide anchor" />
                                        </div>
                                    </div>

                                    <div class="viewer-panel__composer-sticky" data-testid="viewer-composer-sticky">
                                        <AuthorizeView>
                                            <Authorized>
                                                <div class="viewer-panel__composer" data-testid="viewer-comment-composer">
                                                    <CommentForm PostId="@PostId"
                                                                 CanAttachViewerMark="@(viewer.CanAttachCommentMark && viewer.Images.Count > 0)"
                                                                 ViewerPlacementActive="@_isCommentPlacementMode"
                                                                 DraftMark="@_draftCommentMark"
                                                                 AttachedImageNumber="@GetImageNumber(_draftCommentMark?.PostImageId)"
                                                                 OnRequestAttachMark="BeginCommentPlacementAsync"
                                                                 OnRemoveAttachedMark="RemoveDraftCommentMarkAsync"
                                                                 OnCommentAdded="HandleCommentAddedAsync"
                                                                 IsViewerCompact="true" />
                                                </div>
                                            </Authorized>
                                            <NotAuthorized>
                                                <div class="status-panel status-panel--info viewer-panel__auth-callout" role="alert">
                                                    <div class="status-panel__icon"><i class="bi bi-info-circle" aria-hidden="true"></i></div>
                                                    <div>
                                                        <div class="status-panel__title">Join the conversation</div>
                                                        <p class="status-panel__text mb-0">
                                                            Sign in to add anchored feedback.
                                                            <button class="btn btn-link p-0 align-baseline" @onclick="GoToLogin">Login</button>
                                                        </p>
                                                    </div>
                                                </div>
                                            </NotAuthorized>
                                        </AuthorizeView>
                                    </div>
                                </div>
                            </section>
                        </div>
                    }
                </div>
            </SidePanelContent>
        </RichImageViewer>
    }
</div>

@code {
    [Parameter] public int PostId { get; set; }

    private CommentList? _commentList;
    private CommentList? _viewerCommentList;
    private PostDto? post;
    private PostViewerDto? viewer;
    private bool isLoading;
    private string? loadError;
    private HttpStatusCode? loadStatus;
    private bool _postModerationBusy;
    private string? _postModerationError;
    private string? _postModerationResult;
    private bool _isViewerOpen;
    private ViewerSideTab _viewerSideTab = ViewerSideTab.Info;
    private int _activeImageId;
    private bool _isCommentPlacementMode;
    private ViewerMarkDraftDto? _draftCommentMark;
    private int? _activeCommentId;
    private CommentMarkDto? _activeCommentMark;
    private int? _markLoadingCommentId;
    private int? _markErrorCommentId;
    private string? _markError;
    private int _commentMarkRequestVersion;
    private readonly Dictionary<int, CommentMarkDto> _commentMarkCache = new();

    private PostViewerImageDto? CurrentPreviewImage =>
        viewer?.Images.FirstOrDefault(image => image.Id == ResolvedActiveImageId) ?? viewer?.Images.FirstOrDefault();

    private int ResolvedActiveImageId =>
        viewer?.Images.Any(image => image.Id == _activeImageId) == true
            ? _activeImageId
            : viewer?.Images.FirstOrDefault()?.Id ?? 0;

    private ViewerSideTab PreferredViewerSideTab =>
        _isCommentPlacementMode || _draftCommentMark is not null || _activeCommentId.HasValue
            ? ViewerSideTab.Comments
            : ViewerSideTab.Info;

    protected override async Task OnParametersSetAsync()
    {
        await LoadPostAsync();
    }

    private async Task LoadPostAsync()
    {
        isLoading = true;
        loadError = null;
        loadStatus = null;

        var postRequest = new HttpRequestMessage(HttpMethod.Get, $"api/posts/{PostId}");
        var viewerRequest = new HttpRequestMessage(HttpMethod.Get, $"api/posts/{PostId}/viewer");

        try
        {
            var postTask = Api.SendForResultAsync<PostDto>(postRequest, new ApiRequestOptions { SuppressErrorNotifications = true });
            var viewerTask = Api.SendForResultAsync<PostViewerDto>(viewerRequest, new ApiRequestOptions { SuppressErrorNotifications = true });

            await Task.WhenAll(postTask, viewerTask);

            var postResponse = postTask.Result;
            var viewerResponse = viewerTask.Result;

            if (postResponse.Success && postResponse.Value is not null && viewerResponse.Success && viewerResponse.Value is not null)
            {
                post = postResponse.Value;
                viewer = viewerResponse.Value;
                _activeImageId = viewer.Images.FirstOrDefault()?.Id ?? 0;
                _isViewerOpen = false;
                ResetCommentViewerState();
            }
            else
            {
                post = null;
                viewer = null;
                loadStatus = viewerResponse.StatusCode ?? postResponse.StatusCode;
                loadError = loadStatus == HttpStatusCode.NotFound
                    ? "This post could not be found."
                    : "We couldn't load this post. Please check your connection and try again.";
            }
        }
        catch
        {
            post = null;
            viewer = null;
            loadStatus = null;
            loadError = "We couldn't load this post. Please try again in a moment.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ReloadCommentsAsync()
    {
        if (_commentList is not null)
        {
            await _commentList.ReloadAsync();
        }

        if (_viewerCommentList is not null)
        {
            await _viewerCommentList.ReloadAsync();
        }
    }

    private void GoToLogin()
    {
        var returnUrl = Uri.EscapeDataString(Nav.Uri);
        Nav.NavigateTo($"/login?returnUrl={returnUrl}", true);
    }

    private Task HidePostAsync() => ModeratePostAsync(hide: true);

    private Task RestorePostAsync() => ModeratePostAsync(hide: false);

    private async Task ModeratePostAsync(bool hide)
    {
        _postModerationError = null;
        _postModerationResult = null;
        _postModerationBusy = true;

        try
        {
            var request = new ModerationActionRequestDto
            {
                Reason = "Inline moderation from post details."
            };

            var success = hide
                ? await ModerationService.HidePostAsync(PostId, request)
                : await ModerationService.RestorePostAsync(PostId, request);

            if (!success)
            {
                _postModerationError = "Moderation action failed.";
                return;
            }

            _postModerationResult = hide ? "Post hidden." : "Post restored.";
            await LoadPostAsync();
            await ReloadCommentsAsync();
        }
        finally
        {
            _postModerationBusy = false;
        }
    }

    private async Task HandleActiveImageChangedAsync(int imageId)
    {
        _activeImageId = imageId;

        if (_activeCommentId.HasValue && (_activeCommentMark is null || _activeCommentMark.PostImageId != imageId))
        {
            await ClearActiveCommentMarkAsync();
        }
    }

    private Task OpenViewerAsync()
    {
        if (viewer is null || viewer.Images.Count == 0)
        {
            return Task.CompletedTask;
        }

        _viewerSideTab = PreferredViewerSideTab;
        _activeImageId = ResolvedActiveImageId == 0 ? viewer.Images[0].Id : ResolvedActiveImageId;
        _isViewerOpen = true;
        return Task.CompletedTask;
    }

    private async Task OpenViewerAtImageAsync(int imageId)
    {
        _viewerSideTab = PreferredViewerSideTab;
        _isViewerOpen = true;
        await HandleActiveImageChangedAsync(imageId);
    }

    private async Task CloseViewerAsync()
    {
        _isViewerOpen = false;
        _viewerSideTab = ViewerSideTab.Info;
        await ClearActiveCommentMarkAsync();
        _markLoadingCommentId = null;
        _markErrorCommentId = null;
        _markError = null;

        if (_isCommentPlacementMode)
        {
            _isCommentPlacementMode = false;
        }
    }

    private Task BeginCommentPlacementAsync()
    {
        if (viewer is null || viewer.Images.Count == 0)
        {
            return Task.CompletedTask;
        }

        _viewerSideTab = ViewerSideTab.Comments;
        _isViewerOpen = true;
        _activeImageId = _draftCommentMark?.PostImageId ?? ResolvedActiveImageId;
        if (_activeImageId == 0)
        {
            _activeImageId = viewer.Images[0].Id;
        }

        _isCommentPlacementMode = true;
        _activeCommentMark = null;
        _activeCommentId = null;
        _markLoadingCommentId = null;
        _markErrorCommentId = null;
        _markError = null;
        _commentMarkRequestVersion++;
        return Task.CompletedTask;
    }

    private Task HandleCommentPlacementSelectedAsync(ViewerMarkDraftDto draft)
    {
        _viewerSideTab = ViewerSideTab.Comments;
        _draftCommentMark = draft;
        _activeImageId = draft.PostImageId;
        _isCommentPlacementMode = false;
        return Task.CompletedTask;
    }

    private Task CancelCommentPlacementAsync()
    {
        _isCommentPlacementMode = false;
        return Task.CompletedTask;
    }

    private Task RemoveDraftCommentMarkAsync()
    {
        _draftCommentMark = null;
        _isCommentPlacementMode = false;
        return Task.CompletedTask;
    }

    private async Task HandleCommentAddedAsync(CommentDto createdComment)
    {
        _viewerSideTab = ViewerSideTab.Comments;

        if (_draftCommentMark is not null && createdComment.HasViewerMark)
        {
            var mark = new CommentMarkDto
            {
                CommentId = createdComment.Id,
                PostImageId = createdComment.MarkedPostImageId ?? _draftCommentMark.PostImageId,
                NormalizedX = _draftCommentMark.NormalizedX,
                NormalizedY = _draftCommentMark.NormalizedY
            };

            _commentMarkCache[createdComment.Id] = mark;
            _activeCommentId = createdComment.Id;
            _activeCommentMark = mark;
            _activeImageId = mark.PostImageId;
        }

        _draftCommentMark = null;
        _isCommentPlacementMode = false;
        _markError = null;
        _markErrorCommentId = null;
        _markLoadingCommentId = null;
        await ReloadCommentsAsync();
    }

    private async Task ToggleCommentMarkAsync(CommentDto comment)
    {
        _viewerSideTab = ViewerSideTab.Comments;

        if (_activeCommentId == comment.Id)
        {
            await ClearActiveCommentMarkAsync();
            return;
        }

        _commentMarkRequestVersion++;
        var requestVersion = _commentMarkRequestVersion;

        if (comment.MarkedPostImageId.HasValue)
        {
            _activeImageId = comment.MarkedPostImageId.Value;
        }

        _isViewerOpen = true;
        _activeCommentId = comment.Id;
        _activeCommentMark = null;
        _markErrorCommentId = null;
        _markError = null;
        _markLoadingCommentId = comment.Id;
        _isCommentPlacementMode = false;

        if (!_commentMarkCache.TryGetValue(comment.Id, out var mark))
        {
            try
            {
                mark = await CommentMarkService.GetByCommentIdAsync(comment.Id, comment.IsDeleted);
            }
            catch
            {
                if (requestVersion != _commentMarkRequestVersion || _activeCommentId != comment.Id)
                {
                    return;
                }

                _markLoadingCommentId = null;
                _markErrorCommentId = comment.Id;
                _markError = "We couldn't show this marker right now.";
                return;
            }

            if (requestVersion != _commentMarkRequestVersion || _activeCommentId != comment.Id)
            {
                return;
            }

            _commentMarkCache[comment.Id] = mark;
        }

        _markLoadingCommentId = null;
        _markErrorCommentId = null;
        _markError = null;
        _activeCommentMark = mark;
        _activeImageId = mark.PostImageId;
    }

    private Task ClearActiveCommentMarkAsync()
    {
        _commentMarkRequestVersion++;
        _activeCommentId = null;
        _activeCommentMark = null;
        _markLoadingCommentId = null;
        _markErrorCommentId = null;
        _markError = null;
        return Task.CompletedTask;
    }

    private int? GetImageNumber(int? postImageId)
    {
        if (viewer is null || !postImageId.HasValue)
        {
            return null;
        }

        var index = viewer.Images.FindIndex(image => image.Id == postImageId.Value);
        return index >= 0 ? index + 1 : null;
    }

    private void ResetCommentViewerState()
    {
        _commentMarkCache.Clear();
        _isViewerOpen = false;
        _viewerSideTab = ViewerSideTab.Info;
        _activeCommentId = null;
        _activeCommentMark = null;
        _draftCommentMark = null;
        _isCommentPlacementMode = false;
        _markLoadingCommentId = null;
        _markErrorCommentId = null;
        _markError = null;
        _commentMarkRequestVersion = 0;
    }

    private static string GetThumbnailSource(PostViewerImageDto image) =>
        image.ThumbnailUrl
        ?? image.PreviewUrl
        ?? image.ImageUrl;

    private static string GetPreviewSource(PostViewerImageDto image) =>
        image.PreviewUrl
        ?? image.ImageUrl;

    private void SetViewerSideTab(ViewerSideTab tab)
    {
        _viewerSideTab = tab;
    }

    private enum ViewerSideTab
    {
        Info,
        Comments
    }
}
