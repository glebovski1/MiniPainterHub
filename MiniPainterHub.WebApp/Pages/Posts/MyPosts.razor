@using System
@using System.Security.Claims
@page "/posts/mine"
@attribute [Authorize]
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IProfileService ProfileService

<PageTitle>My posts</PageTitle>

<div class="page-shell content-stack">
    <PageHero Eyebrow="Your studio"
              Title="My posts"
              Description="Review your own gallery, open details quickly, and keep the authored-post list easy to scan."
              FrameName="My Posts Header" />

    <section class="surface-card">
        <SectionHeader Eyebrow="Authored work"
                       Title="@MyPostsTitle"
                       Description="Newest work appears first with the same card actions as the public feed."
                       TitleTag="h2"
                       TitleClass="section-heading__title h3 mb-0"
                       SectionName="My Posts List" />

        @if (!string.IsNullOrWhiteSpace(LoadError))
        {
            <div class="status-panel status-panel--error" data-testid="my-posts-error">
                <div class="status-panel__icon"><i class="bi bi-exclamation-triangle" aria-hidden="true"></i></div>
                <div>
                    <div class="status-panel__title">Could not load your posts</div>
                    <p class="status-panel__text mb-0">@LoadError</p>
                </div>
            </div>
        }
        else if (string.IsNullOrWhiteSpace(MyId))
        {
            <div class="status-panel status-panel--info" aria-live="polite" data-testid="my-posts-loading">
                <div class="status-panel__icon"><i class="bi bi-brush" aria-hidden="true"></i></div>
                <div>
                    <div class="status-panel__title">Loading your posts</div>
                    <p class="status-panel__text mb-0">Finding your profile and authored gallery.</p>
                </div>
            </div>
        }
        else
        {
            <UsersPost UserId="@MyId" UserName="@MyName" ShowTitle="false" />
        }
    </section>
</div>

@code {
    private string? MyId { get; set; }
    private string? MyName { get; set; }
    private string? LoadError { get; set; }
    private string MyPostsTitle => $"Posts by {(string.IsNullOrWhiteSpace(MyName) ? "you" : MyName)}";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated != true)
        {
            Navigation.NavigateTo($"/login?returnUrl={Uri.EscapeDataString(Navigation.Uri)}", true);
            return;
        }

        MyId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? user.FindFirst("sub")?.Value;
        MyName = user.Identity.Name;

        try
        {
            var myProfile = await ProfileService.GetMineAsync();
            if (myProfile is not null)
            {
                if (!string.IsNullOrWhiteSpace(myProfile.UserId))
                {
                    MyId = myProfile.UserId;
                }

                if (!string.IsNullOrWhiteSpace(myProfile.DisplayName))
                {
                    MyName = myProfile.DisplayName;
                }
            }
        }
        catch
        {
            // Keep claim-based identity fallback when profile loading fails.
        }

        if (string.IsNullOrWhiteSpace(MyId))
        {
            LoadError = "Could not determine your account. Please sign in again.";
        }
    }
}
