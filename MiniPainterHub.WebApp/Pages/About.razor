@page "/about"

<PageTitle>About MiniPainterHub</PageTitle>

<div class="page-shell content-stack about-page">
    <PageHero Eyebrow="A shared workbench."
              Title="Miniature painting is better when the process is shared."
              Description="MiniPainterHub is a place for painters to show the work behind the finished miniature: the experiments, recipes, questions, breakthroughs, and generous critique that help all of us grow."
              ClassName="about-page-hero"
              FrameName="About Manifesto">
        <Actions>
            <NavLink class="btn btn-primary" href="/posts/all">Explore community work</NavLink>
            <NavLink class="btn btn-outline-secondary" href="/posts/new">Share your work</NavLink>
        </Actions>
    </PageHero>

    <section class="surface-card about-section" aria-label="Built around the craft">
        <SectionHeader Eyebrow="Built around the craft"
                       Title="A place for the whole painting process"
                       Description="Finished pieces inspire us, but the choices behind them are what turn inspiration into something another painter can use."
                       SectionName="About Craft" />

        <div class="about-value-grid">
            @foreach (var value in CraftValues)
            {
                <article class="about-value-card">
                    <span class="about-value-card__mark" aria-hidden="true">@value.Number</span>
                    <h3>@value.Title</h3>
                    <p>@value.Description</p>
                </article>
            }
        </div>
    </section>

    <div class="about-belief-grid">
        <section class="surface-card about-section" aria-label="What belongs here">
            <SectionHeader Eyebrow="What belongs here"
                           Title="Work worth sharing at every stage"
                           Description="This is a gallery, notebook, and critique table in one."
                           SectionName="About Belonging" />

            <ul class="about-list">
                <li>Finished miniatures and display pieces.</li>
                <li>Works in progress, tests, and honest experiments.</li>
                <li>Paint recipes, basing notes, and technique guides.</li>
                <li>Questions that invite thoughtful, practical feedback.</li>
            </ul>
        </section>

        <section class="surface-card about-section about-section--promise" aria-label="Our community promise">
            <SectionHeader Eyebrow="Our community promise"
                           Title="Curious, generous, and specific"
                           Description="The best hobby spaces make room for ambition without turning growth into a contest."
                           SectionName="About Promise" />

            <ul class="about-list about-list--promise">
                <li><strong>Curiosity over gatekeeping.</strong> Every painter can ask, learn, and contribute.</li>
                <li><strong>Kind and specific feedback.</strong> Critique should leave someone with a useful next step.</li>
                <li><strong>Credit for inspiration.</strong> Name the painters, teachers, and references that shaped the work.</li>
            </ul>
        </section>
    </div>

    <section class="surface-card about-invitation" aria-labelledby="about-invitation-title">
        <div>
            <p class="section-label">Pull up a chair</p>
            <h2 id="about-invitation-title">Bring the piece on your desk.</h2>
            <p>Share what you tried, what surprised you, and what you want to solve next.</p>
        </div>
        <div class="about-actions">
            <NavLink class="btn btn-primary" href="/posts/new">Share your work</NavLink>
            <NavLink class="btn btn-outline-secondary" href="/search">Find a technique</NavLink>
        </div>
    </section>
</div>

@code {
    private static readonly AboutValue[] CraftValues =
    [
        new("01", "Show the process", "Share the awkward middle as well as the polished result. Progress becomes useful when other painters can see how it happened."),
        new("02", "Teach what worked", "Record the paint mix, tool, sequence, or small decision that made the difference."),
        new("03", "Give useful critique", "Be encouraging and precise. Point to what is working, then offer a practical next step."),
        new("04", "Find your people", "Follow painters who care about the same scales, styles, techniques, and tiny details you do.")
    ];

    private sealed record AboutValue(string Number, string Title, string Description);
}
