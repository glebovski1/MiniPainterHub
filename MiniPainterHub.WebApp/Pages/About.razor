@page "/about"
@using System.Reflection

<div class="about-page container py-4 py-lg-5">
    <section class="about-hero mb-5">
        <div class="about-hero__content">
            <span class="about-eyebrow">Portfolio Update</span>
            <h1 class="about-title">MiniPainterHub</h1>
            <p class="about-subtitle">
                A miniature-painting community app that now pairs social discovery with a richer post viewer,
                stronger moderation flows, and a cleaner responsive interface across feed, search, messaging,
                and admin tools.
            </p>
            <div class="about-actions">
                <a class="btn btn-primary btn-lg" href="/posts/all">Explore the live feed</a>
                <a class="btn btn-outline-secondary btn-lg" href="/posts/new">Create a post</a>
            </div>
            <div class="about-chip-row" aria-label="Recent capabilities">
                <span class="about-chip">Rich image viewer</span>
                <span class="about-chip">Anchored comment marks</span>
                <span class="about-chip">Moderation and reports</span>
                <span class="about-chip">Responsive UI refresh</span>
            </div>
        </div>

        <aside class="about-hero__panel" aria-label="Current project snapshot">
            <div class="about-panel-kicker">What changed recently</div>
            <ul class="about-panel-list">
                <li>Immersive post viewer with image-first browsing and comment context.</li>
                <li>Inline hide and restore actions for posts and comments in admin flows.</li>
                <li>Following feed, search discovery, messaging, and profile polish working together.</li>
                <li>Browser-reviewed UI work backed by smoke tests and solution-wide test coverage.</li>
            </ul>
            <div class="about-version">Build: @GetVersionString()</div>
        </aside>
    </section>

    <section class="mb-5" aria-labelledby="recent-highlights-title">
        <div class="about-section-heading">
            <span class="about-section-label">Recent Functionality</span>
            <h2 id="recent-highlights-title" class="about-section-title">What the portfolio now needs to show</h2>
            <p class="about-section-copy">
                The app has moved well beyond a basic posting flow. The current release emphasizes deeper viewing,
                stronger moderation, better discovery, and a more deliberate UI shell.
            </p>
        </div>

        <div class="about-highlight-grid">
            @foreach (var highlight in RecentHighlights)
            {
                <article class="about-highlight-card">
                    <div class="about-highlight-card__icon">
                        <i class="@($"bi {highlight.Icon}")" aria-hidden="true"></i>
                    </div>
                    <div>
                        <h3>@highlight.Title</h3>
                        <p>@highlight.Description</p>
                    </div>
                </article>
            }
        </div>
    </section>

    <section class="mb-5" aria-labelledby="portfolio-tour-title">
        <div class="about-section-heading">
            <span class="about-section-label">UI Tour</span>
            <h2 id="portfolio-tour-title" class="about-section-title">Recent screens and workflows</h2>
            <p class="about-section-copy">
                These views cover the app’s core product loop: browse, post, inspect, discover, message, and moderate.
            </p>
        </div>

        <div class="about-shot-grid">
            @foreach (var shot in PortfolioShots)
            {
                <article class="about-shot-card">
                    <img class="about-shot-card__image" src="@shot.ImagePath" alt="@shot.Alt" />
                    <div class="about-shot-card__body">
                        <div class="about-shot-card__eyebrow">@shot.Eyebrow</div>
                        <h3>@shot.Title</h3>
                        <p>@shot.Caption</p>
                    </div>
                </article>
            }
        </div>
    </section>

    <section class="about-details mb-5" aria-labelledby="delivery-title">
        <article class="about-detail-card">
            <span class="about-section-label">Product Direction</span>
            <h2 id="delivery-title" class="about-section-title">Functionality that now defines the project</h2>
            <ul class="about-detail-list">
                <li>Tagged posts, following feed, and global search make discovery feel intentional rather than purely chronological.</li>
                <li>Profiles, follows, and direct messaging give the community layer real continuity beyond comments and likes.</li>
                <li>Reports, moderation actions, and audit views make the admin surface part of the portfolio, not an afterthought.</li>
                <li>The post details experience now supports richer image presentation and more contextual conversation flows.</li>
            </ul>
        </article>

        <article class="about-detail-card">
            <span class="about-section-label">Implementation Notes</span>
            <h2 class="about-section-title">Delivery stack and quality gates</h2>
            <div class="about-stack">
                <span class="badge text-bg-dark">.NET 8</span>
                <span class="badge text-bg-primary">Blazor WebAssembly</span>
                <span class="badge text-bg-secondary">ASP.NET Core API</span>
                <span class="badge text-bg-info">Entity Framework Core</span>
                <span class="badge text-bg-success">JWT Auth</span>
                <span class="badge text-bg-warning">Playwright Smoke</span>
                <span class="badge text-bg-light border">bUnit + xUnit</span>
            </div>
            <p class="about-detail-copy">
                Recent UI work has been reviewed through browser-based smoke coverage and targeted page updates instead of one-off styling tweaks.
                That lets the portfolio present both functionality and delivery discipline.
            </p>
        </article>
    </section>

    <section class="about-cta text-center" aria-labelledby="about-cta-title">
        <div class="about-cta__panel">
            <span class="about-section-label">Next Click</span>
            <h2 id="about-cta-title" class="about-section-title">See the current experience in motion</h2>
            <p class="about-section-copy mb-0">
                Browse the feed, open a post, create one of your own, or inspect the admin workflows to see how the recent UI refresh supports the newer features.
            </p>
            <div class="about-actions justify-content-center mt-4">
                <a class="btn btn-primary btn-lg" href="/posts/all">Open portfolio flows</a>
                <a class="btn btn-outline-secondary btn-lg" href="/search">Try discovery</a>
            </div>
        </div>
    </section>
</div>

@code {
    private static readonly PortfolioHighlight[] RecentHighlights =
    {
        new(
            "Rich Post Viewing",
            "Post details now support a fuller image-viewing experience with stronger visual hierarchy for artwork inspection and discussion.",
            "bi-image-alt"),
        new(
            "Comment Marks and Context",
            "Recent work introduced anchored marks and thread-first comment context so feedback can map back to a specific part of an image.",
            "bi-chat-square-quote"),
        new(
            "Admin Moderation Flows",
            "Reports, hide and restore actions, and audit visibility give moderators practical tools instead of background-only data.",
            "bi-shield-check"),
        new(
            "Discovery and Social Depth",
            "Following feed, global search, direct messaging, and richer profiles now connect creation and community into a coherent loop.",
            "bi-compass"),
    };

    private static readonly PortfolioShot[] PortfolioShots =
    {
        new(
            "Home Feed",
            "The feed highlights posts as the primary entry point into the product and showcases the refreshed card-based browsing experience.",
            "/images/portfolio/01-home-feed.png",
            "Feed view showing recent miniature painting posts.",
            "Browse"),
        new(
            "Create Post",
            "Multi-image posting, captions, and tags keep the publishing flow focused on hobby progress and technique sharing.",
            "/images/portfolio/02-create-post.png",
            "Create-post screen with image upload and form controls.",
            "Create"),
        new(
            "Post Details",
            "The project’s core view combines artwork presentation, comments, likes, and moderation-aware detail flows in one place.",
            "/images/portfolio/03-post-details.png",
            "Post details screen with artwork, metadata, and comments.",
            "Inspect"),
        new(
            "Search and Discovery",
            "Cross-entity search ties posts, tags, and users together so discovery feels like a real feature area rather than a filter add-on.",
            "/images/portfolio/04-search-discovery.png",
            "Search screen showing results for posts and discovery flows.",
            "Discover"),
        new(
            "Messaging",
            "Direct messages and connection flows extend the app beyond public posting into ongoing community interaction.",
            "/images/portfolio/05-messages.png",
            "Messaging view showing a conversation list and active thread.",
            "Connect"),
        new(
            "Reports and Admin",
            "The admin surface now exposes actionable moderation workflows that are strong enough to include in the portfolio itself.",
            "/images/portfolio/06-admin-reports.png",
            "Admin reports screen with moderation queue information.",
            "Moderate"),
    };

    private static string GetVersionString()
        => Assembly.GetExecutingAssembly().GetName().Version?.ToString() ?? "0.0.0";

    private sealed record PortfolioHighlight(string Title, string Description, string Icon);

    private sealed record PortfolioShot(
        string Title,
        string Caption,
        string ImagePath,
        string Alt,
        string Eyebrow);
}
