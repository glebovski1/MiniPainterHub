@page "/guides"
@using MiniPainterHub.Common.DTOs
@using MiniPainterHub.WebApp.Services.Http
@inject IPaintingGuideService GuideService

<PageTitle>Painting guides</PageTitle>

<div class="page-shell content-stack">
    <PageHero Eyebrow="Guides"
              Title="Painting guides"
              Description="Step-by-step recipes from painters who want to show the whole process, not just the final photo."
              FrameName="Guide List Header">
        <Actions>
            <AuthorizeView>
                <Authorized>
                    <NavLink class="btn btn-primary" href="/guides/new" data-testid="guides-new-link">
                        <i class="bi bi-journal-plus" aria-hidden="true"></i>
                        <span>Write guide</span>
                    </NavLink>
                </Authorized>
            </AuthorizeView>
        </Actions>
    </PageHero>

    <section class="surface-card">
        <SectionHeader Eyebrow="Tutorials"
                       Title="Latest guides"
                       Description="Browse color recipes, techniques, and photo-backed steps."
                       TitleTag="h2"
                       TitleClass="section-heading__title h3 mb-0"
                       SectionName="Guide List" />

        @if (!string.IsNullOrWhiteSpace(_loadError))
        {
            <div class="status-panel status-panel--error" role="alert" data-testid="guides-error">
                <div class="status-panel__icon"><i class="bi bi-exclamation-circle" aria-hidden="true"></i></div>
                <div>
                    <div class="status-panel__title">Couldn't load guides</div>
                    <p class="status-panel__text mb-0">@_loadError</p>
                </div>
                <button class="btn btn-link btn-sm ms-auto" @onclick="LoadGuidesAsync">Retry</button>
            </div>
        }
        else if (_isLoading)
        {
            <div class="status-panel status-panel--info" aria-live="polite" data-testid="guides-loading">
                <div class="status-panel__icon"><i class="bi bi-journal-text" aria-hidden="true"></i></div>
                <div>
                    <div class="status-panel__title">Loading guides</div>
                    <p class="status-panel__text mb-0">Preparing the latest walkthroughs.</p>
                </div>
            </div>
        }
        else if (_guides.Count == 0)
        {
            <EmptyState IconClass="bi bi-journal-text"
                        Title="No guides yet"
                        Description="The first painting walkthrough will appear here."
                        TitleClass="empty-state__title h4" />
        }
        else
        {
            <div class="guide-card-grid" data-testid="guide-list">
                @foreach (var guide in _guides)
                {
                    <article class="guide-card" data-testid="guide-card">
                        @if (!string.IsNullOrWhiteSpace(guide.CoverImageUrl))
                        {
                            <NavLink class="guide-card__media" href="@($"/guides/{guide.Id}")">
                                <img src="@guide.CoverImageUrl" alt="@guide.Title" loading="lazy" />
                            </NavLink>
                        }
                        else
                        {
                            <div class="guide-card__placeholder">
                                <i class="bi bi-journal-text" aria-hidden="true"></i>
                            </div>
                        }

                        <div class="guide-card__body">
                            <div class="guide-card__meta">
                                <span>@guide.StepCount step(s)</span>
                                <span>@guide.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</span>
                            </div>
                            <NavLink class="guide-card__title" href="@($"/guides/{guide.Id}")">@guide.Title</NavLink>
                            <p>@guide.Snippet</p>
                            <NavLink class="guide-card__open" href="@($"/guides/{guide.Id}")">
                                <span>Open guide</span>
                                <i class="bi bi-arrow-right-short" aria-hidden="true"></i>
                            </NavLink>
                        </div>
                    </article>
                }
            </div>
        }
    </section>
</div>

@code {
    private const int PageSize = 12;
    private List<PaintingGuideSummaryDto> _guides = new();
    private bool _isLoading = true;
    private string? _loadError;

    protected override async Task OnInitializedAsync()
    {
        await LoadGuidesAsync();
    }

    private async Task LoadGuidesAsync()
    {
        _isLoading = true;
        _loadError = null;

        var result = await GuideService.GetAllAsync(1, PageSize);
        if (!result.Success)
        {
            _guides = new List<PaintingGuideSummaryDto>();
            _loadError = "Guide list is unavailable right now.";
            _isLoading = false;
            return;
        }

        _guides = (result.Value?.Items ?? Array.Empty<PaintingGuideSummaryDto>()).ToList();
        _isLoading = false;
    }
}
