@page "/register"
@inject IAuthService AuthService
@inject NavigationManager Nav

<PageTitle>Register</PageTitle>

<EditForm Model="@registration" OnValidSubmit="HandleRegister" data-testid="register-form">
    <DataAnnotationsValidator />
    <div class="container">
        <div class="row justify-content-center align-items-center vh-100">
            <div class="col-12 col-sm-8 col-md-6 col-lg-4">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h1 class="visually-hidden">Register</h1>
                        <h4 class="card-title text-center mb-4">Register</h4>
                        <ValidationSummary class="text-danger small mb-3" />

                        <div class="mb-3">
                            <label for="reg-username" class="form-label">Username</label>
                            <InputText id="reg-username"
                                       class="form-control"
                                       autocomplete="username"
                                       data-testid="register-username"
                                       @bind-Value="registration.UserName" />
                        </div>

                        <div class="mb-3">
                            <label for="reg-email" class="form-label">Email</label>
                            <InputText id="reg-email"
                                       type="email"
                                       class="form-control"
                                       autocomplete="email"
                                       data-testid="register-email"
                                       @bind-Value="registration.Email" />
                        </div>

                        <div class="mb-4">
                            <label for="reg-password" class="form-label">Password</label>
                            <InputText id="reg-password"
                                       type="password"
                                       class="form-control"
                                       autocomplete="new-password"
                                       data-testid="register-password"
                                       @bind-Value="registration.Password" />
                        </div>

                        <button type="submit" class="btn btn-success w-100 mb-3" data-testid="register-submit">
                            Create Account
                        </button>

                        @if (!string.IsNullOrEmpty(error))
                        {
                            <div class="alert alert-danger text-center mb-0" data-testid="register-error">@error</div>
                        }

                        <div class="text-center mt-3">
                            <small>
                                Already have an account?
                                <NavLink href="/login">Sign In</NavLink>
                            </small>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</EditForm>

@code {
    private RegisterDto registration = new();
    private string? error;

    private async Task HandleRegister()
    {
        error = null;
        var success = await AuthService.RegisterAsync(registration);
        if (success)
        {
            Nav.NavigateTo("/login");
        }
        else
        {
            error = "Registration failed.";
        }
    }
}
