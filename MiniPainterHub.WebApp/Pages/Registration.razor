@page "/register"
@inject IAuthService AuthService
@inject NavigationManager Nav
@using MiniPainterHub.WebApp.Services.Auth

<PageTitle>Register</PageTitle>

<div class="page-shell">
    <div class="auth-shell auth-shell--split">
        <section class="surface-card auth-shell__intro">
            <p class="section-label mb-2">Join the studio</p>
            <h1 class="auth-shell__headline">Build your place in the community.</h1>
            <p class="auth-shell__copy">Create an account to publish miniatures, curate a profile, follow painters, and keep a personal space for your own feed and conversations.</p>

            <div class="auth-shell__metrics">
                <div class="metric-chip">
                    <span class="metric-chip__label">Publish</span>
                    <strong class="metric-chip__value">Share work</strong>
                </div>
                <div class="metric-chip">
                    <span class="metric-chip__label">Profile</span>
                    <strong class="metric-chip__value">Show style</strong>
                </div>
                <div class="metric-chip">
                    <span class="metric-chip__label">Network</span>
                    <strong class="metric-chip__value">Follow painters</strong>
                </div>
            </div>

            <div class="auth-shell__note">
                <div class="auth-shell__note-icon"><i class="bi bi-stars" aria-hidden="true"></i></div>
                <div>
                    <div class="auth-shell__note-title">Designed for hobby sharing</div>
                    <p class="mb-0">The app keeps the core posting and browsing flows simple, but gives your account a clearer home once you join.</p>
                </div>
            </div>
        </section>

        <EditForm Model="@registration" OnValidSubmit="HandleRegister" data-testid="register-form" class="w-100">
            <DataAnnotationsValidator />

            <section class="surface-card auth-card mx-auto">
                <SectionHeader Eyebrow="Join the community"
                               Title="Create your painter account"
                               Description="Set up your place in MiniPainterHub and start sharing finished models, work-in-progress shots, and technique notes."
                               TitleTag="h1"
                               TitleClass="auth-card__title"
                               ClassName="section-heading section-heading--auth"
                               SectionName="Registration Card" />

                @if (_outcome == RegistrationOutcome.ConfirmationSent)
                {
                    <div class="status-panel status-panel--success mt-4" role="status" data-testid="register-confirmation-sent">
                        <div class="status-panel__icon"><i class="bi bi-envelope-check" aria-hidden="true"></i></div>
                        <div>
                            <div class="status-panel__title">Check your email</div>
                            <p class="status-panel__text mb-0">Your account is ready. Open the confirmation link we sent to <strong>@registration.Email</strong> before signing in.</p>
                        </div>
                    </div>
                    <div class="d-grid gap-2 mt-4">
                        <NavLink class="btn btn-primary" href="@LoginUrl">Continue to sign in</NavLink>
                        <NavLink class="btn btn-outline-secondary" href="/resend-confirmation">Didn't receive the email?</NavLink>
                    </div>
                }
                else if (_outcome == RegistrationOutcome.ConfirmationPendingDelivery)
                {
                    <div class="status-panel status-panel--warning mt-4" role="alert" data-testid="register-confirmation-pending">
                        <div class="status-panel__icon"><i class="bi bi-envelope-exclamation" aria-hidden="true"></i></div>
                        <div>
                            <div class="status-panel__title">Account created, but email was not sent</div>
                            <p class="status-panel__text mb-0">Your account is safely pending confirmation. Use resend when you're ready; do not create the account again.</p>
                        </div>
                    </div>
                    <NavLink class="btn btn-primary w-100 mt-4" href="/resend-confirmation">Resend confirmation email</NavLink>
                }
                else
                {
                    <ExternalSignInActions ReturnUrl="@ReturnUrl" />

                    <ValidationSummary class="text-danger small mt-3 mb-0" />

                    <div class="form-grid mt-4">
                        <div>
                            <label for="reg-username" class="form-label">Username</label>
                            <InputText id="reg-username"
                                       class="form-control"
                                       autocomplete="username"
                                       data-testid="register-username"
                                       @bind-Value="registration.UserName" />
                        </div>

                        <div>
                            <label for="reg-email" class="form-label">Email</label>
                            <InputText id="reg-email"
                                       type="email"
                                       class="form-control"
                                       autocomplete="email"
                                       data-testid="register-email"
                                       @bind-Value="registration.Email" />
                        </div>

                        <div>
                            <label for="reg-password" class="form-label">Password</label>
                            <InputText id="reg-password"
                                       type="password"
                                       class="form-control"
                                       autocomplete="new-password"
                                       data-testid="register-password"
                                       @bind-Value="registration.Password" />
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 mt-4" data-testid="register-submit" disabled="@_isSubmitting">
                        @(_isSubmitting ? "Creating account..." : "Create Account")
                    </button>

                    @if (!string.IsNullOrEmpty(error))
                    {
                        <div class="status-panel status-panel--error mt-3" data-testid="register-error">
                            <div class="status-panel__icon"><i class="bi bi-exclamation-circle" aria-hidden="true"></i></div>
                            <div>
                                <div class="status-panel__title">Registration failed</div>
                                <p class="status-panel__text mb-0">@error</p>
                            </div>
                        </div>
                    }
                }

                <div class="auth-card__footer">
                    Already have an account?
                    <NavLink href="/login">Sign In</NavLink>
                </div>
            </section>
        </EditForm>
    </div>
</div>

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private RegisterDto registration = new();
    private string? error;
    private RegistrationOutcome? _outcome;
    private bool _isSubmitting;

    private string LoginUrl => $"/login?returnUrl={Uri.EscapeDataString(GetSafeReturnUrl())}";

    private async Task HandleRegister()
    {
        if (_isSubmitting)
        {
            return;
        }

        error = null;
        _isSubmitting = true;
        registration.ReturnUrl = GetSafeReturnUrl();
        try
        {
            _outcome = await AuthService.RegisterAsync(registration);
            if (_outcome == RegistrationOutcome.Success)
            {
                Nav.NavigateTo(LoginUrl);
                return;
            }

            error = _outcome switch
            {
                RegistrationOutcome.ValidationFailure => "Check your account details and try again.",
                RegistrationOutcome.RateLimited => "Too many registration attempts. Wait before trying again.",
                RegistrationOutcome.Unavailable => "Registration is unavailable right now. Please try again.",
                _ => null
            };
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private string GetSafeReturnUrl()
    {
        var suppliedReturnUrl = LocalReturnUrl.GetQueryParameter(Nav.Uri, "returnUrl") ?? ReturnUrl;
        return LocalReturnUrl.Normalize(suppliedReturnUrl, new Uri(Nav.BaseUri));
    }
}
