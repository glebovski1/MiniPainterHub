@page "/home"
<PageTitle>Community highlights | Roll &amp; Paint</PageTitle>

<div class="page-shell content-stack">
    <PageHero Eyebrow="Community highlights"
              Title="Discover the Community's Favourites"
              Description="A rotating showcase of standout miniatures shared by painters over the last month."
              ClassName="page-hero--compact"
              FrameName="Highlights Header">
        <Actions>
            <NavLink class="btn btn-primary" href="/posts/top">
                <i class="bi bi-trophy" aria-hidden="true"></i>
                <span>Open ranked showcase</span>
            </NavLink>
            <NavLink class="btn btn-outline-secondary" href="/posts/all">
                <i class="bi bi-grid-1x2" aria-hidden="true"></i>
                <span>Explore all posts</span>
            </NavLink>
        </Actions>
        <Metrics>
            <div class="metric-grid">
                <div class="metric-chip">
                    <span class="metric-chip__label">Window</span>
                    <strong class="metric-chip__value">30 days</strong>
                </div>
                <div class="metric-chip">
                    <span class="metric-chip__label">Focus</span>
                    <strong class="metric-chip__value">The artwork</strong>
                </div>
                <div class="metric-chip">
                    <span class="metric-chip__label">Updated</span>
                    <strong class="metric-chip__value">Daily</strong>
                </div>
            </div>
        </Metrics>
    </PageHero>

    <section class="surface-card feed-surface">
        <SectionHeader Eyebrow="Showcase"
                       Title="Top Posts"
                       Description="A curated selection of the highest-rated recent artwork."
                       SectionName="Top Posts">
            <Actions>
                <NavLink class="btn btn-outline-secondary btn-sm" href="/posts/top">See the full ranking</NavLink>
            </Actions>
        </SectionHeader>

        <div class="card border-0 bg-transparent shadow-none mb-0">
            <div class="card-body p-0">
                <TopPostsShowcase HeightPx="520" LookbackDays="30" />
            </div>
        </div>
    </section>
</div>
