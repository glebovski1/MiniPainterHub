{
  "ConnectionStrings": {
    "DefaultConnection": "<match Azure ConnectionStrings__DefaultConnection>"
  },
  "Jwt": {
    "Key": "<match Azure Jwt__Key>",
    "Issuer": "MiniPainterHubApi",
    "Audience": "MiniPainterHubClient",
    "ExpiryMinutes": 60
  },
  "ImageStorage": {
    "AzureConnectionString": "<match Azure ImageStorage__AzureConnectionString>",
    "AzureContainer": "<match Azure ImageStorage__AzureContainer>"
  },
  "SeedAdmin": {
    "Enabled": true,
    "Email": "<match Azure SeedAdmin__Email>",
    "Password": "<match Azure SeedAdmin__Password>"
  },
  "Maintenance": {
    "Enabled": false
  }
}
