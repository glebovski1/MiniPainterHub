{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "rollandpaint.com;www.rollandpaint.com;minipainterhub-dqandpbghpgbfgf3.canadacentral-01.azurewebsites.net",
  "Site": {
    "BrandName": "Roll & Paint",
    "PublicOrigin": "https://rollandpaint.com",
    "DefaultTitle": "Roll & Paint | Miniature Painting Community",
