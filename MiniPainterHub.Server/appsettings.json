{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=MiniPainterHub;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "Jwt": {
    "Issuer": "MiniPainterHubApi",
    "Audience": "MiniPainterHubClient",
    "ExpiryMinutes": 60
  },
  "Images": {
    "Enabled": true,
    "KeepOriginal": false,
    "Quality": 80,
    "PreferredFormat": "webp",
    "Max": {
      "Width": 1920,
      "Height": 1080
    },
    "Preview": {
      "Width": 1280,
      "Height": 1280
    },
    "Thumb": {
      "Width": 320,
      "Height": 320
    }
  }
}
