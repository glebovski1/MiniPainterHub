{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=MiniPainterHub;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "Jwt": {
    "Issuer": "MiniPainterHubApi",
    "Audience": "MiniPainterHubClient",
    "ExpiryMinutes": 60
  },
  "Authentication": {
    "Google": {
      "Enabled": false,
      "CallbackPath": "/signin-google",
      "UseFakeProvider": false
    }
  },
  "ForwardedHeaders": {
    "Enabled": false,
    "TrustAllProxies": false,
    "KnownProxies": []
  },
  "Images": {
    "Enabled": true,
    "KeepOriginal": false,
    "Quality": 80,
    "MaxSourceWidth": 8000,
    "MaxSourceHeight": 8000,
    "MaxSourceMegapixels": 50,
    "PreferredFormat": "webp",
    "Max": {
      "Width": 1920,
      "Height": 1080
    },
    "Preview": {
      "Width": 960,
      "Height": 960
    },
    "Thumb": {
      "Width": 320,
      "Height": 320
    }
  },
  "TrafficShaping": {
    "Auth": {
      "PermitLimit": 10,
      "WindowSeconds": 60
    },
    "Search": {
      "PermitLimit": 60,
      "WindowSeconds": 60
    },
    "Write": {
      "PermitLimit": 30,
      "WindowSeconds": 60
    },
    "Upload": {
      "PermitLimit": 6,
      "WindowSeconds": 60
    },
    "Realtime": {
      "PermitLimit": 30,
      "WindowSeconds": 60
    },
    "GlobalUploadConcurrency": 8,
    "PerClientUploadConcurrency": 2
  }
}
