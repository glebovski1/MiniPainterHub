{
  "ConnectionStrings": {
    "DefaultConnection": "<match Azure ConnectionStrings__DefaultConnection>"
  },
  "Jwt": {
    "Key": "<match Azure Jwt__Key>",
    "Issuer": "MiniPainterHubApi",
    "Audience": "MiniPainterHubClient",
    "ExpiryMinutes": 60
  },
  "ImageStorage": {
    "AzureConnectionString": "<match Azure ImageStorage__AzureConnectionString>",
    "AzureContainer": "<match Azure ImageStorage__AzureContainer>"
  },
  "Authentication": {
    "Google": {
      "Enabled": false,
      "ClientId": "<match Azure Authentication__Google__ClientId>",
      "ClientSecret": "<match Azure Authentication__Google__ClientSecret>",
      "CallbackPath": "/signin-google",
      "PublicOrigin": "https://rollandpaint.com",
      "UseFakeProvider": false
    },
    "Discord": {
      "Enabled": false,
      "ClientId": "<match Azure Authentication__Discord__ClientId>",
      "ClientSecret": "<match Azure Authentication__Discord__ClientSecret>",
      "CallbackPath": "/signin-discord",
      "PublicOrigin": "https://rollandpaint.com",
      "UseFakeProvider": false
    }
  },
  "EmailConfirmation": {
    "Enabled": true,
    "Provider": "AzureCommunicationServices",
    "PublicOrigin": "https://rollandpaint.com",
    "Endpoint": "<match Azure EmailConfirmation__Endpoint>",
    "SenderAddress": "<match Azure EmailConfirmation__SenderAddress>",
    "SenderDisplayName": "Roll & Paint"
  },
  "Site": {
    "BrandName": "Roll & Paint",
    "PublicOrigin": "https://rollandpaint.com",
    "DefaultTitle": "Roll & Paint | Miniature Painting Community",
    "DefaultDescription": "A miniature painting community for sharing painted miniatures, works in progress, paint recipes, techniques, and thoughtful critique.",
    "DefaultSocialImagePath": "/brand/roll-and-paint-social.png",
    "CanonicalRedirectsEnabled": true,
    "SupportEmail": "<match Azure Site__SupportEmail>"
  },
  "ForwardedHeaders": {
    "Enabled": true,
    "TrustAllProxies": true
  },
  "DataProtection": {
    "KeysPath": "D:\\home\\data-protection-keys"
  },
  "SeedAdmin": {
    "Enabled": true,
    "Email": "<match Azure SeedAdmin__Email>",
    "Password": "<match Azure SeedAdmin__Password>"
  },
  "Maintenance": {
    "Enabled": false
  }
}
