    "Issuer": "MiniPainterHubApi",
    "Audience": "MiniPainterHubClient",
    "ExpiryMinutes": 60
  },
  "ImageStorage": {
    "AzureConnectionString": "<match Azure ImageStorage__AzureConnectionString>",
    "AzureContainer": "<match Azure ImageStorage__AzureContainer>"
  },
  "Authentication": {
    "Google": {
      "Enabled": false,
      "ClientId": "<match Azure Authentication__Google__ClientId>",
      "ClientSecret": "<match Azure Authentication__Google__ClientSecret>",
      "CallbackPath": "/signin-google",
      "PublicOrigin": "https://minipainterhub-dqandpbghpgbfgf3.canadacentral-01.azurewebsites.net",
      "UseFakeProvider": false
    },
    "Discord": {
      "Enabled": false,
      "ClientId": "<match Azure Authentication__Discord__ClientId>",
      "ClientSecret": "<match Azure Authentication__Discord__ClientSecret>",
      "CallbackPath": "/signin-discord",
      "PublicOrigin": "https://minipainterhub-dqandpbghpgbfgf3.canadacentral-01.azurewebsites.net",
      "UseFakeProvider": false
    }
  },
  "EmailConfirmation": {
    "Enabled": true,
    "Provider": "AzureCommunicationServices",
    "PublicOrigin": "https://minipainterhub-dqandpbghpgbfgf3.canadacentral-01.azurewebsites.net",
